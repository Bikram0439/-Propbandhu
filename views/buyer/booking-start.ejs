<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="flex items-center">
                        <span class="text-xl font-bold text-gray-900">Propbandhu</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/buyer/dashboard" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-home mr-1"></i>Dashboard
                    </a>
                    <a href="/buyer/my-bookings" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-receipt mr-1"></i>My Bookings
                    </a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600">
                        <i class="fas fa-sign-out-alt mr-1"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-4xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <!-- Progress Steps -->
        <div class="mb-12">
            <div class="flex items-center justify-center">
                <div class="flex items-center">
                    <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center">
                        <i class="fas fa-shopping-cart"></i>
                    </div>
                    <div class="ml-2 text-sm font-medium text-blue-600">Visit Confirmed</div>
                </div>
                
                <div class="flex-1 h-1 mx-4 bg-blue-300"></div>
                
                <div class="flex items-center">
                    <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center">
                        1
                    </div>
                    <div class="ml-2 text-sm font-medium text-blue-600">Start Booking</div>
                </div>
                
                <div class="flex-1 h-1 mx-4 bg-gray-300"></div>
                
                <div class="flex items-center">
                    <div class="w-10 h-10 rounded-full bg-gray-300 text-gray-600 flex items-center justify-center">
                        2
                    </div>
                    <div class="ml-2 text-sm font-medium text-gray-500">Details & KYC</div>
                </div>
                
                <div class="flex-1 h-1 mx-4 bg-gray-300"></div>
                
                <div class="flex items-center">
                    <div class="w-10 h-10 rounded-full bg-gray-300 text-gray-600 flex items-center justify-center">
                        3
                    </div>
                    <div class="ml-2 text-sm font-medium text-gray-500">Payment</div>
                </div>
                
                <div class="flex-1 h-1 mx-4 bg-gray-300"></div>
                
                <div class="flex items-center">
                    <div class="w-10 h-10 rounded-full bg-gray-300 text-gray-600 flex items-center justify-center">
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="ml-2 text-sm font-medium text-gray-500">Confirmation</div>
                </div>
            </div>
        </div>

        <!-- Booking Summary Card -->
        <div class="bg-white rounded-xl shadow-lg p-8 mb-8">
            <h1 class="text-2xl font-bold text-gray-900 mb-2">Book Property</h1>
            <p class="text-gray-600 mb-6">Complete the booking process to reserve this property</p>
            
            <div class="border-t border-gray-200 pt-6">
                <div class="flex flex-col md:flex-row">
                    <!-- Property Info -->
                    <div class="md:w-2/3 mb-6 md:mb-0 md:pr-8">
                        <h2 class="text-xl font-semibold text-gray-900 mb-4"><%= property.title %></h2>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                            <div>
                                <p class="text-sm text-gray-600 mb-1">Property ID</p>
                                <p class="font-medium"><%= property._id %></p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-600 mb-1">Location</p>
                                <p class="font-medium">
                                    <%= property.address.area %>, <%= property.address.city %>
                                </p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-600 mb-1">Property Type</p>
                                <p class="font-medium"><%= property.property_type %></p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-600 mb-1">Full Price</p>
                                <p class="font-bold text-blue-600 text-lg"><%= property.formatted_price %></p>
                            </div>
                        </div>
                        
                        <!-- Booking Terms -->
                        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                            <h3 class="font-semibold text-blue-800 mb-2">Booking Terms</h3>
                            <ul class="text-sm text-blue-700 space-y-2">
                                <li class="flex items-start">
                                    <i class="fas fa-check-circle mt-1 mr-2 text-blue-600"></i>
                                    <span>Booking amount is <b><%= property.booking_percentage %>%</b> of property price</span>
                                </li>
                                <li class="flex items-start">
                                    <i class="fas fa-check-circle mt-1 mr-2 text-blue-600"></i>
                                    <span>Booking confirms your intent to purchase the property</span>
                                </li>
                                <li class="flex items-start">
                                    <i class="fas fa-check-circle mt-1 mr-2 text-blue-600"></i>
                                    <span>Remaining amount to be paid as per agreement terms</span>
                                </li>
                                <li class="flex items-start">
                                    <i class="fas fa-check-circle mt-1 mr-2 text-blue-600"></i>
                                    <span>Booking amount is refundable as per cancellation policy</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                    <!-- Booking Summary -->
                    <div class="md:w-1/3">
                        <div class="bg-gray-50 border border-gray-200 rounded-lg p-6">
                            <h3 class="font-semibold text-gray-900 mb-4">Booking Summary</h3>
                            
                            <div class="space-y-4">
                                <div class="flex justify-between">
                                    <span class="text-gray-600">Property Price</span>
                                    <span class="font-medium"><%= property.formatted_price %></span>
                                </div>
                                
                                <div class="flex justify-between">
                                    <span class="text-gray-600">Booking Percentage</span>
                                    <span class="font-medium"><%= property.booking_percentage %>%</span>
                                </div>
                                
                                <div class="border-t border-gray-200 pt-4">
                                    <div class="flex justify-between items-center">
                                        <span class="text-lg font-semibold text-gray-900">Booking Amount</span>
                                        <span class="text-2xl font-bold text-green-600"><%= property.booking_amount %></span>
                                    </div>
                                    <p class="text-xs text-gray-500 mt-1">To be paid now to reserve property</p>
                                </div>
                            </div>
                            
                            <button onclick="startBookingProcess()" 
                                    class="w-full mt-6 bg-green-600 text-white py-3 rounded-lg hover:bg-green-700 font-semibold flex items-center justify-center">
                                <i class="fas fa-lock mr-2"></i>Proceed to Secure Payment
                            </button>
                            
                            <p class="text-xs text-gray-500 text-center mt-4">
                                <i class="fas fa-shield-alt mr-1"></i>
                                Your payment is secure and encrypted
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Buyer Info (Auto-filled) -->
        <div class="bg-white rounded-xl shadow p-6 mb-6">
            <h3 class="font-semibold text-gray-900 mb-4">Your Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <p class="text-sm text-gray-600 mb-1">Name</p>
                    <p class="font-medium"><%= user.name %></p>
                </div>
                <div>
                    <p class="text-sm text-gray-600 mb-1">Email</p>
                    <p class="font-medium"><%= user.email %></p>
                </div>
                <div>
                    <p class="text-sm text-gray-600 mb-1">Phone</p>
                    <p class="font-medium"><%= user.phone %></p>
                </div>
                <div>
                    <p class="text-sm text-gray-600 mb-1">User ID</p>
                    <p class="font-medium"><%= user._id %></p>
                </div>
            </div>
        </div>
        
        <!-- Important Notes -->
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-6">
            <h3 class="font-semibold text-yellow-800 mb-3 flex items-center">
                <i class="fas fa-exclamation-triangle mr-2"></i>Important Information
            </h3>
            <ul class="text-sm text-yellow-700 space-y-2">
                <li>• Booking amount is a token amount to reserve the property</li>
                <li>• Full payment terms will be discussed with seller after booking</li>
                <li>• You will need to submit KYC documents after payment</li>
                <li>• Booking can be cancelled as per cancellation policy (7-day window)</li>
                <li>• Property viewing should be completed before booking confirmation</li>
            </ul>
        </div>
    </div>

    <script>
        async function startBookingProcess() {
            try {
                const response = await fetch('/buyer/api/booking/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        propertyId: '<%= property._id %>',
                        booking_type: 'token'
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    // Redirect to next step (KYC & details)
                    window.location.href = `/buyer/booking-details/${result.bookingId}`;
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Failed to start booking process. Please try again.');
            }
        }
        
        // Add to main app.js
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Booking page loaded for property:', '<%= property._id %>');
        });
    </script>
</body>
</html>