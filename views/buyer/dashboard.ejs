<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }
        
        /* Notification Badge */
        .notification-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            font-size: 11px;
            font-weight: bold;
            min-width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 4px;
            box-shadow: 0 2px 4px rgba(239, 68, 68, 0.3);
            animation: pulse 2s infinite;
        }
        
        /* Notification Dropdown */
        .notification-dropdown {
            display: none;
            position: absolute;
            top: 100%;
            right: 0;
            width: 380px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 20px 40px -12px rgba(0, 0, 0, 0.25);
            z-index: 1000;
            margin-top: 12px;
            border: 1px solid #f0f0f0;
            overflow: hidden;
        }
        
        .notification-dropdown.show {
            display: block;
            animation: slideDown 0.3s ease-out;
        }
        
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .notification-item {
            padding: 16px;
            border-bottom: 1px solid #f3f4f6;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }
        
        .notification-item:hover {
            background-color: #f9fafb;
            transform: translateX(4px);
        }
        
        .notification-item.unread {
            background: linear-gradient(to right, #f0f9ff, white);
            border-left: 4px solid #3b82f6;
        }
        
        .notification-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            flex-shrink: 0;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
        }
        
        /* Welcome Banner */
        .welcome-banner {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            position: relative;
            overflow: hidden;
        }
        
        .welcome-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 50%);
            animation: rotate 30s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        
        /* Stat Cards */
        .stat-card {
            transition: all 0.3s;
            background: white;
            border-radius: 16px;
            border: 1px solid #f0f0f0;
            position: relative;
            overflow: hidden;
        }
        
        .stat-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(to bottom, #3b82f6, #8b5cf6);
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .stat-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.15);
        }
        
        .stat-card:hover::after {
            opacity: 1;
        }
        
        /* Quick Action Cards */
        .quick-action-card {
            transition: all 0.3s;
            background: white;
            border-radius: 16px;
            border: 1px solid #f0f0f0;
            position: relative;
            overflow: hidden;
        }
        
        .quick-action-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.05), rgba(139, 92, 246, 0.05));
            opacity: 0;
            transition: opacity 0.3s;
        }
        
        .quick-action-card:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.15);
        }
        
        .quick-action-card:hover::before {
            opacity: 1;
        }
        
        /* Property Cards */
        .property-card {
            transition: all 0.3s;
            border-radius: 16px;
            border: 1px solid #f0f0f0;
            background: white;
            overflow: hidden;
        }
        
        .property-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 30px -10px rgba(0, 0, 0, 0.15);
        }
        
        /* Loading Spinner */
        .loading-spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid #3b82f6;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        /* Pulse Animation */
        @keyframes pulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }
        
        /* Custom Scrollbar */
        .overflow-y-auto::-webkit-scrollbar {
            width: 6px;
        }
        
        .overflow-y-auto::-webkit-scrollbar-track {
            background: #f1f1f1;
            border-radius: 10px;
        }
        
        .overflow-y-auto::-webkit-scrollbar-thumb {
            background: #cbd5e0;
            border-radius: 10px;
        }
        
        .overflow-y-auto::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">
    <!-- Navigation -->
    <nav class="bg-white shadow-sm sticky top-0 z-50 border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <!-- Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex items-center space-x-3 group">
                        <div class="w-10 h-10 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform">
                            <span class="text-white font-bold text-xl">P</span>
                        </div>
                        <span class="text-2xl font-bold bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">
                            Propbandhu
                        </span>
                    </a>
                </div>
                
                <!-- Navigation Links -->
                <div class="flex items-center space-x-2">
                    <span class="hidden md:flex items-center bg-gradient-to-r from-blue-50 to-indigo-50 px-4 py-2 rounded-xl">
                        <span class="text-gray-700 font-medium">👋 <%= user.name %></span>
                        <span class="ml-2 px-2 py-1 bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-xs rounded-full">Buyer</span>
                    </span>
                    
                    <a href="/buyer/dashboard" class="text-gray-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-all flex items-center">
                        <i class="fas fa-home mr-2"></i>
                        <span class="hidden md:inline">Dashboard</span>
                    </a>
                    
                    <a href="/buyer/properties" class="text-gray-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-all flex items-center">
                        <i class="fas fa-search mr-2"></i>
                        <span class="hidden md:inline">Browse</span>
                    </a>
                    
                    <a href="/buyer/cart" class="text-gray-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-all flex items-center relative">
                        <i class="fas fa-shopping-cart mr-2"></i>
                        <span class="hidden md:inline">Cart</span>
                        <% if (stats.cartCount > 0) { %>
                        <span class="ml-1 bg-red-500 text-white text-xs font-bold rounded-full h-5 w-5 flex items-center justify-center">
                            <%= stats.cartCount %>
                        </span>
                        <% } %>
                    </a>
                    
                    <a href="/buyer/visits" class="text-gray-600 hover:text-blue-600 px-4 py-2 rounded-xl hover:bg-blue-50 transition-all flex items-center">
                        <i class="fas fa-calendar-day mr-2"></i>
                        <span class="hidden md:inline">Visits</span>
                    </a>
                    
                    <!-- NOTIFICATIONS BUTTON -->
                    <div class="relative ml-2">
                        <button onclick="toggleNotifications()" 
                                class="relative w-10 h-10 bg-gray-100 hover:bg-blue-100 rounded-xl flex items-center justify-center transition-all hover:scale-110">
                            <i class="fas fa-bell text-gray-600 hover:text-blue-600 text-lg"></i>
                            <span class="notification-badge" style="<%= unreadCount > 0 ? '' : 'display:none;' %>">
                                <%= unreadCount > 9 ? '9+' : unreadCount %>
                            </span>
                        </button>
                        
                        <!-- Notifications Dropdown -->
                        <div id="notificationsDropdown" class="notification-dropdown">
                            <div class="p-4 bg-gradient-to-r from-blue-600 to-indigo-600 text-white">
                                <div class="flex justify-between items-center">
                                    <h3 class="font-bold">Notifications</h3>
                                    <% if (unreadCount > 0) { %>
                                        <button onclick="markAllAsRead()" 
                                                class="text-sm bg-white bg-opacity-20 hover:bg-opacity-30 px-3 py-1 rounded-full transition-all">
                                            Mark all as read
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                            
                            <div id="notificationsList" class="max-h-96 overflow-y-auto">
                                <!-- Notifications will be loaded here -->
                                <div class="p-8 text-center">
                                    <div class="inline-block loading-spinner mb-4"></div>
                                    <p class="text-gray-600">Loading notifications...</p>
                                </div>
                            </div>
                            
                            <div class="p-4 border-t border-gray-100 bg-gray-50">
                                <a href="/buyer/notifications" 
                                   class="block text-center text-blue-600 hover:text-blue-800 font-medium text-sm py-2 hover:bg-blue-50 rounded-xl transition-all">
                                    <i class="fas fa-list mr-2"></i>View all notifications
                                </a>
                            </div>
                        </div>
                    </div>
                    
                    <a href="/logout" class="bg-gradient-to-r from-red-500 to-red-600 text-white px-4 py-2 rounded-xl hover:from-red-600 hover:to-red-700 transition-all flex items-center ml-2">
                        <i class="fas fa-sign-out-alt mr-2"></i>
                        <span class="hidden md:inline">Logout</span>
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <!-- Welcome Banner -->
        <div class="welcome-banner rounded-2xl p-8 text-white mb-8 relative">
            <div class="relative z-10">
                <h1 class="text-3xl md:text-4xl font-bold mb-2">Welcome back, <%= user.name %>! 👋</h1>
                <p class="text-blue-100 text-lg mb-4">Your dream property is just a few clicks away</p>
                <div class="flex space-x-4">
                    <a href="/buyer/properties" class="bg-white text-blue-600 px-6 py-3 rounded-xl font-semibold hover:bg-opacity-90 transition-all flex items-center">
                        <i class="fas fa-search mr-2"></i>Browse Properties
                    </a>
                    <a href="/buyer/cart" class="bg-blue-500 bg-opacity-30 text-white px-6 py-3 rounded-xl font-semibold hover:bg-opacity-40 transition-all flex items-center backdrop-blur-sm">
                        <i class="fas fa-shopping-cart mr-2"></i>View Cart
                    </a>
                </div>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <!-- Cart Count -->
            <div class="stat-card p-6">
                <div class="flex items-center">
                    <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mr-4 shadow-lg">
                        <i class="fas fa-shopping-cart text-white text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Properties in Cart</p>
                        <p class="text-3xl font-bold text-gray-900"><%= stats.cartCount %></p>
                        <p class="text-xs text-gray-500 mt-1">Maximum 5 properties</p>
                    </div>
                </div>
                <div class="mt-3 w-full bg-gray-200 rounded-full h-2">
                    <div class="bg-blue-600 h-2 rounded-full" style="width: <%= (stats.cartCount / 5) * 100 %>%"></div>
                </div>
            </div>
            
            <!-- Scheduled Visits -->
            <div class="stat-card p-6">
                <div class="flex items-center">
                    <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-emerald-600 rounded-xl flex items-center justify-center mr-4 shadow-lg">
                        <i class="fas fa-calendar-check text-white text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Scheduled Visits</p>
                        <p class="text-3xl font-bold text-gray-900"><%= stats.visitsScheduled %></p>
                        <p class="text-xs text-green-600 mt-1">Confirmed visits</p>
                    </div>
                </div>
            </div>
            
            <!-- Pending Visits -->
            <div class="stat-card p-6">
                <div class="flex items-center">
                    <div class="w-14 h-14 bg-gradient-to-br from-yellow-500 to-amber-600 rounded-xl flex items-center justify-center mr-4 shadow-lg">
                        <i class="fas fa-clock text-white text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Pending Visits</p>
                        <p class="text-3xl font-bold text-gray-900"><%= stats.visitsPending %></p>
                        <p class="text-xs text-yellow-600 mt-1">Awaiting schedule</p>
                    </div>
                </div>
            </div>
            
            <!-- Notifications -->
            <div class="stat-card p-6">
                <div class="flex items-center">
                    <div class="w-14 h-14 bg-gradient-to-br from-purple-500 to-purple-600 rounded-xl flex items-center justify-center mr-4 shadow-lg">
                        <i class="fas fa-bell text-white text-2xl"></i>
                    </div>
                    <div>
                        <p class="text-sm text-gray-500 font-medium">Notifications</p>
                        <div class="flex items-baseline">
                            <p class="text-3xl font-bold text-gray-900" id="notificationStatCount">
                                <% if (unreadCount > 0) { %>
                                    <span class="text-red-600"><%= unreadCount %></span>
                                <% } else { %>
                                    0
                                <% } %>
                            </p>
                            <% if (unreadCount > 0) { %>
                                <span class="ml-2 text-sm text-red-600 font-medium">unread</span>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <h2 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
            <i class="fas fa-bolt text-yellow-500 mr-2"></i>
            Quick Actions
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <a href="/buyer/properties" class="quick-action-card p-6 group">
                <div class="flex items-center">
                    <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-search text-blue-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900">Browse Properties</h3>
                        <p class="text-sm text-gray-500">Find your dream home</p>
                    </div>
                </div>
            </a>
            
            <a href="/buyer/cart" class="quick-action-card p-6 group">
                <div class="flex items-center">
                    <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-shopping-cart text-green-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900">View Cart</h3>
                        <p class="text-sm text-gray-500"><%= stats.cartCount %> items saved</p>
                    </div>
                </div>
            </a>
            
            <a href="/buyer/visits" class="quick-action-card p-6 group">
                <div class="flex items-center">
                    <div class="w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                        <i class="fas fa-calendar-day text-yellow-600 text-xl"></i>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900">My Visits</h3>
                        <p class="text-sm text-gray-500"><%= stats.visitsScheduled + stats.visitsPending %> visits</p>
                    </div>
                </div>
            </a>
            
            <a href="/buyer/notifications" class="quick-action-card p-6 group">
                <div class="flex items-center">
                    <div class="w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center mr-4 group-hover:scale-110 transition-transform relative">
                        <i class="fas fa-bell text-purple-600 text-xl"></i>
                        <% if (unreadCount > 0) { %>
                        <span class="absolute -top-1 -right-1 bg-red-500 text-white text-xs rounded-full h-5 w-5 flex items-center justify-center">
                            <%= unreadCount > 9 ? '9+' : unreadCount %>
                        </span>
                        <% } %>
                    </div>
                    <div>
                        <h3 class="font-semibold text-gray-900">Notifications</h3>
                        <p class="text-sm text-gray-500"><%= unreadCount %> unread</p>
                    </div>
                </div>
            </a>
        </div>

        <!-- Cart Preview -->
        <% if (cart.items && cart.items.length > 0) { %>
        <div class="mb-8">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-900 flex items-center">
                    <i class="fas fa-shopping-cart text-blue-600 mr-2"></i>
                    Recently Added to Cart
                </h2>
                <a href="/buyer/cart" class="text-blue-600 hover:text-blue-800 text-sm font-medium flex items-center">
                    View All <i class="fas fa-arrow-right ml-1"></i>
                </a>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% cart.items.slice(0, 2).forEach(item => { 
                    const daysLeft = Math.ceil((new Date(item.added_at).getTime() + 7*24*60*60*1000 - Date.now()) / (1000*60*60*24));
                %>
                <div class="property-card p-6">
                    <div class="flex items-start">
                        <% if (item.property.images && item.property.images.length > 0) { %>
                        <img src="<%= item.property.images[0].url %>" 
                             alt="<%= item.property.title %>" 
                             class="w-24 h-24 object-cover rounded-xl mr-4">
                        <% } else { %>
                        <div class="w-24 h-24 bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl flex items-center justify-center mr-4">
                            <i class="fas fa-home text-gray-400 text-3xl"></i>
                        </div>
                        <% } %>
                        
                        <div class="flex-1">
                            <h3 class="font-bold text-lg text-gray-900 mb-1"><%= item.property.title %></h3>
                            <p class="text-sm text-gray-600 mb-2">
                                <i class="fas fa-map-marker-alt text-gray-400 mr-1"></i>
                                <%= item.property.location || 'Location not specified' %>
                            </p>
                            <div class="flex justify-between items-center">
                                <span class="text-xl font-bold text-blue-600">₹<%= item.property.price.toLocaleString() %></span>
                                <% if (daysLeft <= 3) { %>
                                <span class="text-xs text-red-600 font-medium bg-red-50 px-2 py-1 rounded-full">
                                    <i class="fas fa-clock mr-1"></i><%= daysLeft %> days left
                                </span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-4 flex justify-end space-x-3">
                        <a href="/buyer/schedule-visit/<%= item.property._id %>" 
                           class="text-sm bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition-all">
                            <i class="fas fa-calendar-plus mr-1"></i>Schedule Visit
                        </a>
                        <a href="/buyer/properties/<%= item.property._id %>" 
                           class="text-sm text-blue-600 hover:text-blue-800 bg-blue-50 px-4 py-2 rounded-lg hover:bg-blue-100 transition-all">
                            View Details
                        </a>
                    </div>
                </div>
                <% }); %>
            </div>
            
            <% if (cart.items.length > 2) { %>
            <div class="mt-4 text-center">
                <a href="/buyer/cart" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium">
                    View all <%= cart.items.length %> properties in cart 
                    <i class="fas fa-arrow-right ml-2"></i>
                </a>
            </div>
            <% } %>
        </div>
        <% } %>

        <!-- Recently Viewed -->
        <% if (recentProperties && recentProperties.length > 0) { %>
        <div>
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold text-gray-900 flex items-center">
                    <i class="fas fa-history text-purple-600 mr-2"></i>
                    Recently Viewed
                </h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% recentProperties.slice(0, 4).forEach(property => { %>
                <div class="property-card p-4 flex items-center">
                    <% if (property.images && property.images.length > 0) { %>
                    <img src="<%= property.images[0].url %>" 
                         alt="<%= property.title %>" 
                         class="w-16 h-16 object-cover rounded-lg mr-4">
                    <% } else { %>
                    <div class="w-16 h-16 bg-gradient-to-br from-gray-100 to-gray-200 rounded-lg flex items-center justify-center mr-4">
                        <i class="fas fa-home text-gray-400 text-2xl"></i>
                    </div>
                    <% } %>
                    
                    <div class="flex-1">
                        <h3 class="font-semibold text-gray-900"><%= property.title %></h3>
                        <p class="text-sm text-gray-600"><%= property.location || 'Location not specified' %></p>
                        <div class="flex justify-between items-center mt-1">
                            <span class="text-blue-600 font-bold">₹<%= property.price.toLocaleString() %></span>
                            <a href="/buyer/properties/<%= property._id %>" class="text-xs text-blue-600 hover:text-blue-800">
                                View <i class="fas fa-arrow-right ml-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
        <% } %>
    </div>

    <!-- Footer -->
    <footer class="bg-white border-t border-gray-200 mt-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <div>
                    <div class="flex items-center space-x-2 mb-4">
                        <div class="w-8 h-8 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-lg flex items-center justify-center">
                            <span class="text-white font-bold">P</span>
                        </div>
                        <span class="text-lg font-bold text-gray-900">Propbandhu</span>
                    </div>
                    <p class="text-gray-600 text-sm">Your trusted partner in finding the perfect property.</p>
                </div>
                
                <div>
                    <h4 class="font-semibold text-gray-900 mb-4">Quick Links</h4>
                    <ul class="space-y-2">
                        <li><a href="/buyer/properties" class="text-gray-600 hover:text-blue-600 text-sm">Browse Properties</a></li>
                        <li><a href="/buyer/cart" class="text-gray-600 hover:text-blue-600 text-sm">My Cart</a></li>
                        <li><a href="/buyer/visits" class="text-gray-600 hover:text-blue-600 text-sm">My Visits</a></li>
                        <li><a href="/buyer/notifications" class="text-gray-600 hover:text-blue-600 text-sm">Notifications</a></li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-gray-900 mb-4">Support</h4>
                    <ul class="space-y-2">
                        <li><a href="/faq" class="text-gray-600 hover:text-blue-600 text-sm">FAQ</a></li>
                        <li><a href="/contact" class="text-gray-600 hover:text-blue-600 text-sm">Contact Us</a></li>
                        <li><a href="/privacy" class="text-gray-600 hover:text-blue-600 text-sm">Privacy Policy</a></li>
                        <li><a href="/terms" class="text-gray-600 hover:text-blue-600 text-sm">Terms of Service</a></li>
                    </ul>
                </div>
                
                <div>
                    <h4 class="font-semibold text-gray-900 mb-4">Contact</h4>
                    <ul class="space-y-2">
                        <li class="text-gray-600 text-sm flex items-center">
                            <i class="fas fa-phone text-blue-600 mr-2 w-4"></i>
                            1800-123-4567
                        </li>
                        <li class="text-gray-600 text-sm flex items-center">
                            <i class="fas fa-envelope text-blue-600 mr-2 w-4"></i>
                            support@propbandhu.com
                        </li>
                        <li class="text-gray-600 text-sm flex items-center">
                            <i class="fas fa-clock text-blue-600 mr-2 w-4"></i>
                            Mon-Sat: 9 AM - 8 PM
                        </li>
                    </ul>
                </div>
            </div>
            
            <div class="mt-8 pt-8 border-t border-gray-200 text-center text-gray-500 text-sm">
                <p>© <%= new Date().getFullYear() %> Propbandhu. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script>
        // Notification Functions
        let notificationsDropdownVisible = false;
        
        function toggleNotifications() {
            const dropdown = document.getElementById('notificationsDropdown');
            dropdown.classList.toggle('show');
            notificationsDropdownVisible = !notificationsDropdownVisible;
            
            if (notificationsDropdownVisible) {
                loadNotifications();
                document.addEventListener('click', closeNotificationsOnClickOutside);
            } else {
                document.removeEventListener('click', closeNotificationsOnClickOutside);
            }
        }
        
        function closeNotificationsOnClickOutside(event) {
            const dropdown = document.getElementById('notificationsDropdown');
            const bellButton = document.querySelector('.fa-bell')?.closest('button');
            
            if (!dropdown.contains(event.target) && (!bellButton || !bellButton.contains(event.target))) {
                dropdown.classList.remove('show');
                notificationsDropdownVisible = false;
                document.removeEventListener('click', closeNotificationsOnClickOutside);
            }
        }
        
        async function loadNotifications() {
            try {
                const response = await fetch('/buyer/api/notifications/recent');
                const data = await response.json();
                
                const notificationsList = document.getElementById('notificationsList');
                
                if (data.success && data.notifications.length > 0) {
                    notificationsList.innerHTML = '';
                    
                    data.notifications.slice(0, 5).forEach(notification => {
                        const item = document.createElement('div');
                        item.className = `notification-item ${!notification.is_read ? 'unread' : ''}`;
                        item.innerHTML = `
                            <div class="flex items-start">
                                <div class="notification-icon ${getNotificationIconColor(notification.type)}">
                                    <i class="${getNotificationIcon(notification.type)} text-white"></i>
                                </div>
                                <div class="flex-1">
                                    <div class="flex justify-between items-start">
                                        <p class="font-medium text-gray-900 text-sm">${notification.title}</p>
                                        <span class="text-xs text-gray-500">${notification.time_ago}</span>
                                    </div>
                                    <p class="text-gray-600 text-sm mt-1">${notification.message.substring(0, 60)}${notification.message.length > 60 ? '...' : ''}</p>
                                    ${notification.data && notification.data.action_url ? 
                                        `<a href="${notification.data.action_url}" class="text-blue-600 text-xs mt-2 inline-block hover:underline">View Details →</a>` : ''}
                                </div>
                            </div>
                        `;
                        
                        item.addEventListener('click', async (e) => {
                            if (e.target.tagName !== 'A' && !notification.is_read) {
                                await markNotificationAsRead(notification._id, item);
                            }
                        });
                        
                        notificationsList.appendChild(item);
                    });
                    
                    if (data.notifications.length > 5) {
                        const viewAll = document.createElement('div');
                        viewAll.className = 'p-3 text-center border-t border-gray-100';
                        viewAll.innerHTML = '<a href="/buyer/notifications" class="text-blue-600 text-sm font-medium hover:underline">View all notifications</a>';
                        notificationsList.appendChild(viewAll);
                    }
                } else {
                    notificationsList.innerHTML = `
                        <div class="p-8 text-center">
                            <i class="fas fa-bell-slash text-4xl mb-3 text-gray-300"></i>
                            <p class="text-gray-600 font-medium">No notifications yet</p>
                            <p class="text-sm text-gray-500 mt-1">We'll notify you when something arrives</p>
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error loading notifications:', error);
                document.getElementById('notificationsList').innerHTML = `
                    <div class="p-8 text-center text-red-500">
                        <i class="fas fa-exclamation-triangle text-4xl mb-3"></i>
                        <p>Failed to load notifications</p>
                        <p class="text-sm mt-1">Please try again later</p>
                    </div>
                `;
            }
        }
        
        function getNotificationIcon(type) {
            const icons = {
                'property_added_to_cart': 'fas fa-shopping-cart',
                'cart_item_expiring': 'fas fa-clock',
                'property_price_drop': 'fas fa-tag',
                'visit_scheduled': 'fas fa-calendar-alt',
                'visit_confirmed': 'fas fa-calendar-check',
                'booking_started': 'fas fa-file-contract',
                'payment_successful': 'fas fa-credit-card',
                'default': 'fas fa-bell'
            };
            return icons[type] || icons['default'];
        }
        
        function getNotificationIconColor(type) {
            const colors = {
                'property_added_to_cart': 'bg-pink-500',
                'cart_item_expiring': 'bg-yellow-500',
                'property_price_drop': 'bg-green-500',
                'visit_scheduled': 'bg-blue-500',
                'visit_confirmed': 'bg-teal-500',
                'booking_started': 'bg-orange-500',
                'payment_successful': 'bg-emerald-500',
                'default': 'bg-purple-500'
            };
            return colors[type] || colors['default'];
        }
        
        async function markNotificationAsRead(notificationId, element) {
            try {
                const response = await fetch(`/buyer/api/notifications/${notificationId}/read`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    element.classList.remove('unread');
                    
                    const badge = document.querySelector('.notification-badge');
                    if (badge) {
                        let count = parseInt(badge.textContent) || 0;
                        if (count > 1) {
                            badge.textContent = count > 9 ? '9+' : (count - 1);
                        } else {
                            badge.style.display = 'none';
                        }
                    }
                    
                    const statCount = document.getElementById('notificationStatCount');
                    if (statCount) {
                        const currentText = statCount.innerHTML;
                        const match = currentText.match(/\d+/);
                        if (match) {
                            let count = parseInt(match[0]);
                            if (count > 1) {
                                statCount.innerHTML = `<span class="text-red-600">${count - 1}</span>`;
                            } else {
                                statCount.textContent = '0';
                            }
                        }
                    }
                }
            } catch (error) {
                console.error('Error marking notification as read:', error);
            }
        }
        
        async function markAllAsRead() {
            try {
                const response = await fetch('/buyer/api/notifications/read-all', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                if (response.ok) {
                    document.querySelectorAll('.notification-item.unread').forEach(item => {
                        item.classList.remove('unread');
                    });
                    
                    const badge = document.querySelector('.notification-badge');
                    if (badge) {
                        badge.style.display = 'none';
                    }
                    
                    const statCount = document.getElementById('notificationStatCount');
                    if (statCount) {
                        statCount.textContent = '0';
                    }
                    
                    const markAllBtn = document.querySelector('button[onclick="markAllAsRead()"]');
                    if (markAllBtn) {
                        markAllBtn.style.display = 'none';
                    }
                }
            } catch (error) {
                console.error('Error marking all as read:', error);
            }
        }
        
        async function updateNotificationCount() {
            try {
                const response = await fetch('/buyer/api/notifications/unread-count');
                const data = await response.json();
                
                if (data.success) {
                    const badge = document.querySelector('.notification-badge');
                    const statCount = document.getElementById('notificationStatCount');
                    
                    if (data.count > 0) {
                        if (badge) {
                            badge.textContent = data.count > 9 ? '9+' : data.count;
                            badge.style.display = 'flex';
                        }
                        if (statCount) {
                            statCount.innerHTML = `<span class="text-red-600">${data.count}</span>`;
                        }
                    } else {
                        if (badge) {
                            badge.style.display = 'none';
                        }
                        if (statCount) {
                            statCount.textContent = '0';
                        }
                    }
                }
            } catch (error) {
                console.error('Error updating notification count:', error);
            }
        }
        
        // Initialize
        document.addEventListener('DOMContentLoaded', function() {
            updateNotificationCount();
            setInterval(updateNotificationCount, 60000);
        });
    </script>
</body>
</html>