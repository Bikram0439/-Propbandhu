                <input type="hidden" id="availableShares">
                <button type="submit" id="investSubmitBtn" class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white py-3.5 rounded-xl font-bold text-lg shadow-md hover:shadow-xl transition">
                    <i class="fas fa-check-circle"></i> Proceed to Invest
                </button>
            </form>
        </div>
    </div>
    
    <!-- Floating Contact Button -->
    <div class="floating-contact">
        <a href="tel:+919876543210" class="bg-blue-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:bg-blue-700 transition transform hover:scale-105">
            <i class="fas fa-phone-alt text-xl"></i>
        </a>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <i class="fab fa-facebook-f text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-twitter text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-linkedin-in text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-instagram text-gray-400 hover:text-pink-400 cursor-pointer transition text-xl"></i>
            </div>
            <p class="text-gray-400 text-sm">© 2025 Propbandhu | Fractional Ownership Marketplace</p>
            <p class="text-gray-500 text-xs mt-2">SEBI Registered | RERA Compliant | Your gateway to premium real estate investments</p>
        </div>
    </footer>

    <script>
        // Modal functions
        const modal = document.getElementById('investmentModal');
        let currentSharesAvailable = 0;
        
        function openInvestmentModal(propertyName, sharePrice, available) {
            document.getElementById('modalPropertyName').innerHTML = propertyName;
            document.getElementById('propertyName').value = propertyName;
            document.getElementById('sharePrice').value = sharePrice;
            document.getElementById('sharePriceDisplay').innerHTML = '₹' + parseInt(sharePrice).toLocaleString('en-IN');
            document.getElementById('availableShares').value = available;
            currentSharesAvailable = parseInt(available);
            
            const sharesInput = document.getElementById('invShares');
            sharesInput.max = available;
            sharesInput.value = 1;
            updateTotalInvestment();
            
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        
        function closeInvestmentModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = 'auto';
        }
        
        function updateTotalInvestment() {
            const shares = parseInt(document.getElementById('invShares').value) || 0;
            const sharePrice = parseInt(document.getElementById('sharePrice').value) || 0;
            const total = shares * sharePrice;
            document.getElementById('totalInvestment').innerHTML = '₹' + total.toLocaleString('en-IN');
        }
        
        // Update total when shares change
        document.getElementById('invShares').addEventListener('input', function() {
            let val = parseInt(this.value);
            if (val > currentSharesAvailable) {
                this.value = currentSharesAvailable;
                val = currentSharesAvailable;
            }
            if (val < 1) this.value = 1;
            updateTotalInvestment();
        });
        
        // Close modal on outside click
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeInvestmentModal();
            }
        });
        
        // Investment Form Submission
        const investmentForm = document.getElementById('investmentForm');
        const investSubmitBtn = document.getElementById('investSubmitBtn');
        
        investmentForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const name = document.getElementById('invName').value.trim();
            const email = document.getElementById('invEmail').value.trim();
            const phone = document.getElementById('invPhone').value.trim();
            const property = document.getElementById('propertyName').value;
            const shares = document.getElementById('invShares').value;
            
            if (!name || !email || !phone) {
                alert('❌ Please fill in all required fields.');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                alert('❌ Please enter a valid 10-digit mobile number.');
                return;
            }
            
            // Show loading state
            const originalText = investSubmitBtn.innerHTML;
            investSubmitBtn.innerHTML = '<span class="loading-spinner"></span> Processing...';
            investSubmitBtn.disabled = true;
            
            // Simulate API call
            setTimeout(() => {
                console.log('Investment Interest:', { name, email, phone, property, shares });
                alert(`✓ Thank you ${name}! Your interest in ${property} has been recorded. Our investment advisor will contact you within 2 hours.`);
                investmentForm.reset();
                closeInvestmentModal();
                investSubmitBtn.innerHTML = originalText;
                investSubmitBtn.disabled = false;
            }, 800);
        });
        
        // Add image fallback handling
        document.querySelectorAll('.property-image img').forEach(img => {
            img.onerror = function() {
                this.src = 'https://placehold.co/600x400/3b82f6/white?text=Premium+Property';
            };
        });
        
        // Heart icon toggle functionality
        document.querySelectorAll('.fa-heart').forEach(heart => {
            heart.addEventListener('click', function() {
                this.classList.toggle('text-red-500');
                this.classList.toggle('text-gray-300');
            });
        });
    </script>
</body>
</html>