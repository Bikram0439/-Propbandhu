                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                        <!-- Calculator Form -->
                        <div>
                            <div class="space-y-5">
                                <div>
                                    <label class="block text-sm font-semibold text-gray-700 mb-2">🏠 Property Price (₹)</label>
                                    <input type="range" id="propertyPrice" min="1000000" max="20000000" step="500000" value="5000000" class="w-full">
