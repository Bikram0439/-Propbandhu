                <!-- 4. Documents Required -->
                <div id="documents" class="bg-white rounded-2xl shadow-xl p-6 section-card">
                    <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fas fa-file-alt text-orange-600"></i> 4. Documents Required
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <h3 class="font-bold text-green-600 mb-3 flex items-center gap-2"><i class="fas fa-user-check"></i> For Buyers</h3>
                            <ul class="space-y-2">
                                <li class="checklist-item"><i class="fas fa-check-circle text-green-500 mr-2"></i>Identity Proof (Aadhar/PAN/Passport)</li>
