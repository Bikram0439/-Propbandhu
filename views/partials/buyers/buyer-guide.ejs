                            <ul class="space-y-2">
                                <li class="checklist-item"><i class="fas fa-check-circle text-blue-500 mr-2"></i>Sale Deed</li>
                                <li class="checklist-item"><i class="fas fa-check-circle text-blue-500 mr-2"></i>Mother Deed</li>
                                <li class="checklist-item"><i class="fas fa-check-circle text-blue-500 mr-2"></i>Encumbrance Certificate</li>
                                <li class="checklist-item"><i class="fas fa-check-circle text-blue-500 mr-2"></i>Tax Receipts</li>
                                <li class="checklist-item"><i class="fas fa-check-circle text-blue-500 mr-2"></i>Building Plan Approval</li>
                                <li class="checklist-item"><i class="fas fa-check-circle text-blue-500 mr-2"></i>Occupancy Certificate</li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="mt-6 p-4 bg-yellow-50 rounded-xl flex flex-wrap justify-between items-center gap-3">
                        <div>
                            <i class="fas fa-download text-yellow-600 mr-2"></i>
                            <span class="font-semibold">Complete Checklist PDF</span>
                        </div>
                        <button onclick="downloadChecklist()" class="bg-blue-600 text-white px-5 py-2 rounded-lg hover:bg-blue-700 transition">Download PDF</button>
                    </div>
                </div>

                <!-- 7. Cost Calculator -->
                <div id="cost" class="bg-white rounded-2xl shadow-xl p-6 section-card">
                    <h2 class="text-2xl font-bold text-gray-900 mb-4 flex items-center gap-2">
                        <i class="fas fa-chart-pie text-indigo-600"></i> 7. Total Cost Calculator
                    </h2>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Property Value (₹)</label>
                                <input type="number" id="propertyValue" class="w-full px-4 py-3 border border-gray-300 rounded-xl" value="5000000">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Stamp Duty (%)</label>
                                <select id="stampDuty" class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-white">
                                    <option value="5">5% - Maharashtra</option>
                                    <option value="4">4% - Delhi NCR</option>
                                    <option value="3">3% - Karnataka</option>
                                    <option value="2">2% - Gujarat</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Registration Charges (₹)</label>
                                <input type="number" id="registrationCharges" class="w-full px-4 py-3 border border-gray-300 rounded-xl" value="50000">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">GST (%)</label>
                                <input type="number" id="gst" class="w-full px-4 py-3 border border-gray-300 rounded-xl" value="1" step="0.5">
                            </div>
                            <button onclick="calculateTotalCost()" class="bg-indigo-600 text-white px-6 py-3 rounded-xl font-semibold hover:bg-indigo-700 transition w-full">Calculate Total Cost</button>
                        </div>
                        <div class="bg-gradient-to-r from-indigo-50 to-blue-50 p-5 rounded-xl">
                            <h3 class="font-bold text-lg mb-3">Total Cost Breakdown</h3>
                            <div class="space-y-2">
                                <div class="flex justify-between"><span>Property Value:</span><span class="font-semibold" id="displayPropertyValue">₹0</span></div>
                                <div class="flex justify-between"><span>Stamp Duty:</span><span class="font-semibold text-orange-600" id="stampDutyAmount">₹0</span></div>
                                <div class="flex justify-between"><span>Registration:</span><span class="font-semibold text-orange-600" id="displayRegistration">₹0</span></div>
                                <div class="flex justify-between"><span>GST:</span><span class="font-semibold text-orange-600" id="gstAmount">₹0</span></div>
                                <div class="border-t pt-2 mt-2"><div class="flex justify-between font-bold text-lg"><span>Total Cost:</span><span class="text-indigo-600" id="totalCost">₹0</span></div></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Pro Tips Section -->
                <div class="bg-gradient-to-r from-orange-500 to-red-500 rounded-2xl shadow-xl p-6 text-white">
                    <h2 class="text-2xl font-bold mb-4 flex items-center gap-2"><i class="fas fa-lightbulb"></i> Pro Tips for Buyers</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        <div class="tip-card flex items-start gap-2"><i class="fas fa-check-circle mt-1"></i><span>Always verify property documents with a lawyer</span></div>
                        <div class="tip-card flex items-start gap-2"><i class="fas fa-check-circle mt-1"></i><span>Check RERA registration for new projects</span></div>
                        <div class="tip-card flex items-start gap-2"><i class="fas fa-check-circle mt-1"></i><span>Visit property at different times of the day</span></div>
                        <div class="tip-card flex items-start gap-2"><i class="fas fa-check-circle mt-1"></i><span>Negotiate on price and payment terms</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Loan Application Modal -->
    <div id="loanModal" class="fixed inset-0 bg-black bg-opacity-60 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4 modal-content">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800"><i class="fas fa-hand-holding-usd text-blue-600"></i> Apply for Home Loan</h3>
                <button onclick="closeLoanModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            <form id="loanForm">
                <input type="hidden" id="selectedBank">
                <div class="space-y-4">
                    <div><label class="block text-sm font-semibold mb-1">Full Name *</label><input type="text" required class="w-full px-4 py-3 border rounded-xl"></div>
                    <div><label class="block text-sm font-semibold mb-1">Email *</label><input type="email" required class="w-full px-4 py-3 border rounded-xl"></div>
                    <div><label class="block text-sm font-semibold mb-1">Phone *</label><input type="tel" required class="w-full px-4 py-3 border rounded-xl"></div>
                    <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-xl font-bold">Submit Application</button>
                    <button type="button" onclick="closeLoanModal()" class="w-full text-gray-500 py-2">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <i class="fab fa-facebook-f text-gray-400 hover:text-blue-400 cursor-pointer text-xl"></i>
                <i class="fab fa-twitter text-gray-400 hover:text-blue-400 cursor-pointer text-xl"></i>
                <i class="fab fa-linkedin-in text-gray-400 hover:text-blue-400 cursor-pointer text-xl"></i>
                <i class="fab fa-instagram text-gray-400 hover:text-pink-400 cursor-pointer text-xl"></i>
            </div>
            <p class="text-gray-400 text-sm">© 2025 Propbandhu | Complete Buyer's Guide - Empowering Your Home Buying Journey</p>
        </div>
    </footer>

    <script>
        let emiChart = null;

        function calculateEMI() {
            const price = parseFloat(document.getElementById('propertyPrice').value);
            const downPayment = parseFloat(document.getElementById('downPaymentSlider').value);
            const rate = parseFloat(document.getElementById('interestRate').value) / 12 / 100;
            const tenureMonths = parseFloat(document.getElementById('tenure').value) * 12;
            
            const loanAmount = price - downPayment;
            let emi = 0, totalPayment = 0, totalInterest = 0;
            
            if (loanAmount > 0 && rate > 0) {
                emi = loanAmount * rate * Math.pow(1 + rate, tenureMonths) / (Math.pow(1 + rate, tenureMonths) - 1);
                totalPayment = emi * tenureMonths;
                totalInterest = totalPayment - loanAmount;
            }
            
            document.getElementById('priceValue').innerHTML = '₹' + price.toLocaleString('en-IN');
            document.getElementById('downPaymentValue').innerHTML = '₹' + downPayment.toLocaleString('en-IN');
            document.getElementById('rateValue').innerHTML = document.getElementById('interestRate').value + '%';
            document.getElementById('tenureValue').innerHTML = document.getElementById('tenure').value + ' Years';
            document.getElementById('emiAmount').innerHTML = '₹' + (emi || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('totalInterest').innerHTML = '₹' + (totalInterest || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('totalPayment').innerHTML = '₹' + (totalPayment || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('loanAmount').innerHTML = '₹' + (loanAmount || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            
            if (emiChart) emiChart.destroy();
            const ctx = document.getElementById('emiChart').getContext('2d');
            emiChart = new Chart(ctx, {
                type: 'doughnut',
                data: { labels: ['Principal Amount', 'Total Interest'], datasets: [{ data: [loanAmount, totalInterest], backgroundColor: ['#3b82f6', '#f97316'], borderWidth: 0 }] },
                options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom' } } }
            });
        }

        document.getElementById('eligibilityForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const income = parseFloat(document.getElementById('monthlyIncome').value);
            const existingEMI = parseFloat(document.getElementById('existingEMI').value) || 0;
            const creditScore = parseFloat(document.getElementById('creditScore').value);
            
            const maxEMI = income * 0.5;
            const availableEMI = maxEMI - existingEMI;
            const rate = 8.5 / 12 / 100;
            const tenure = 20 * 12;
            const eligibleLoan = availableEMI > 0 ? availableEMI * (Math.pow(1 + rate, tenure) - 1) / (rate * Math.pow(1 + rate, tenure)) : 0;
            
            let status, color, message;
            if (creditScore >= 750 && availableEMI > 0) { status = 'Eligible'; color = 'green'; message = `Congratulations! You are eligible for a loan up to ₹${eligibleLoan.toLocaleString('en-IN')}`; }
            else if (creditScore >= 650 && availableEMI > 0) { status = 'Partially Eligible'; color = 'orange'; message = `You may get loan with higher interest rate. Eligible amount: ₹${eligibleLoan.toLocaleString('en-IN')}`; }
            else { status = 'Not Eligible'; color = 'red'; message = 'Improve your credit score or reduce existing debt to become eligible.'; }
            
            const resultDiv = document.getElementById('eligibilityResult');
            resultDiv.className = `mt-4 p-4 rounded-xl bg-${color}-50 border border-${color}-200`;
            resultDiv.innerHTML = `<h3 class="font-bold text-${color}-800">Status: ${status}</h3><p class="text-${color}-700">${message}</p><p class="text-sm text-${color}-600 mt-1">Monthly EMI Capacity: ₹${maxEMI.toLocaleString('en-IN')} | Available: ₹${availableEMI.toLocaleString('en-IN')}</p>`;
            resultDiv.classList.remove('hidden');
        });

        function calculateTotalCost() {
            const value = parseFloat(document.getElementById('propertyValue').value);
            const stampPercent = parseFloat(document.getElementById('stampDuty').value);
            const registration = parseFloat(document.getElementById('registrationCharges').value);
            const gstPercent = parseFloat(document.getElementById('gst').value);
            const stampAmount = value * stampPercent / 100;
            const gstAmount = value * gstPercent / 100;
            const total = value + stampAmount + registration + gstAmount;
            document.getElementById('displayPropertyValue').innerHTML = '₹' + value.toLocaleString('en-IN');
            document.getElementById('stampDutyAmount').innerHTML = '₹' + stampAmount.toLocaleString('en-IN');
            document.getElementById('displayRegistration').innerHTML = '₹' + registration.toLocaleString('en-IN');
            document.getElementById('gstAmount').innerHTML = '₹' + gstAmount.toLocaleString('en-IN');
            document.getElementById('totalCost').innerHTML = '₹' + total.toLocaleString('en-IN');
        }

        function applyForLoan(bank) { document.getElementById('selectedBank').value = bank; document.getElementById('loanModal').classList.remove('hidden'); document.getElementById('loanModal').classList.add('flex'); }
        function closeLoanModal() { document.getElementById('loanModal').classList.add('hidden'); document.getElementById('loanModal').classList.remove('flex'); }
        function downloadChecklist() { alert('✓ Checklist PDF is being generated and will download shortly.'); }
        
        document.getElementById('loanForm').addEventListener('submit', function(e) { e.preventDefault(); alert('✓ Loan application submitted! Our representative will contact you within 24 hours.'); closeLoanModal(); this.reset(); });
        document.getElementById('propertyPrice').addEventListener('input', calculateEMI);
        document.getElementById('downPaymentSlider').addEventListener('input', calculateEMI);
        document.getElementById('interestRate').addEventListener('input', calculateEMI);
        document.getElementById('tenure').addEventListener('input', calculateEMI);
        
        calculateEMI();
        calculateTotalCost();
    </script>
</body>
</html>