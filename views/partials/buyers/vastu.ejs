    <script>
        // Vastu Calculator Logic
        const vastuForm = document.getElementById('vastuForm');
        const vastuResultDiv = document.getElementById('vastuResult');
        const vastuScoreSpan = document.getElementById('vastuScore');
        const scoreBar = document.getElementById('scoreBar');
        const vastuFeedback = document.getElementById('vastuFeedback');
        const vastuTipsDiv = document.getElementById('vastuTips');
        const tipTextSpan = document.getElementById('tipText');
        
        vastuForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const facing = document.getElementById('facing').value;
            const shape = document.getElementById('shape').value;
            const entrance = document.getElementById('entrance').value;
            const kitchen = document.getElementById('kitchen').value;
            
            let score = 0;
            let feedback = '';
            let tip = '';
            
            // Facing scores (out of 60)
            const facingScores = {
                north: 52, south: 40, east: 50, west: 42,
                northeast: 58, northwest: 38, southeast: 35, southwest: 45
            };
            score += facingScores[facing] || 40;
            
            // Shape points (out of 15)
            if (shape === 'square') score += 15;
            else if (shape === 'rectangle') score += 8;
            else score -= 5;
            
            // Entrance compatibility (out of 15)
            if (entrance === facing) score += 12;
            else if (entrance === 'northeast') score += 15;
            else if (entrance === 'east' || entrance === 'north') score += 8;
            else score += 2;
            
            // Kitchen location (out of 10)
            if (kitchen === 'southeast') score += 10;
            else if (kitchen === 'northwest') score += 5;
            else if (kitchen === 'northeast' || kitchen === 'southwest') score -= 8;
            else score += 0;
            
            // Clamp score between 0-100
            score = Math.min(100, Math.max(0, Math.round(score)));
            
            // Determine feedback and tips
            if (score >= 85) {
                feedback = "✨ Excellent! Your property has outstanding Vastu compliance. Positive energy will flow abundantly.";
                tip = "Maintain cleanliness in North-East corner and keep a Tulsi plant for continuous blessings.";
                scoreBar.className = 'progress-bar bg-green-500 h-4 rounded-full';
            } else if (score >= 70) {
                feedback = "🙏 Good Vastu! Minor improvements can make it perfect. You're on the right track.";
                tip = "Consider placing a mirror on North wall or adding more windows in East direction.";
                scoreBar.className = 'progress-bar bg-emerald-500 h-4 rounded-full';
            } else if (score >= 50) {
                feedback = "⚠️ Average Vastu compliance. Some areas need attention. Expert consultation recommended.";
                tip = "Avoid heavy construction in North-East and ensure kitchen is not directly in front of main door.";
                scoreBar.className = 'progress-bar bg-yellow-500 h-4 rounded-full';
            } else {
                feedback = "🔧 Needs significant improvement. Strongly recommend professional Vastu consultation for remedies.";
                tip = "Consider Vastu yantra placements and color corrections. Our experts can guide you with simple remedies.";
                scoreBar.className = 'progress-bar bg-red-500 h-4 rounded-full';
            }
            
            // Animate score display
            vastuScoreSpan.classList.remove('score-value');
            void vastuScoreSpan.offsetWidth; // Force reflow
            vastuScoreSpan.classList.add('score-value');
            vastuScoreSpan.innerHTML = score + '%';
            
            // Update progress bar width
            scoreBar.style.width = score + '%';
            vastuFeedback.innerHTML = feedback;
            tipTextSpan.innerHTML = tip;
            vastuTipsDiv.classList.remove('hidden');
            vastuResultDiv.classList.remove('hidden');
            
            // Smooth scroll to result
            vastuResultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
        
        // Modal Functions
        const modal = document.getElementById('consultationModal');
        
        function openConsultationModal() {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        
        function closeConsultationModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = 'auto';
        }
        
        // Close modal when clicking outside
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeConsultationModal();
            }
        });
        
        // Consultation Form Submission
        const consultationForm = document.getElementById('consultationForm');
        const submitBtn = document.getElementById('submitConsultBtn');
        
        consultationForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const name = document.getElementById('consultName').value.trim();
            const phone = document.getElementById('consultPhone').value.trim();
            const email = document.getElementById('consultEmail').value.trim();
            const consultType = document.getElementById('consultType').value;
            
            if (!name || !phone || !email || !consultType) {
                alert('❌ Please fill in all required fields.');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                alert('❌ Please enter a valid 10-digit mobile number.');
                return;
            }
            
            // Show loading state
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loading-spinner"></span> Booking...';
            submitBtn.disabled = true;
            
            // Simulate API call
            setTimeout(() => {
                console.log('Vastu Consultation Booking:', { name, phone, email, consultType });
                alert('✓ Consultation booked successfully! Our Vastu expert will contact you within 24 hours.');
                consultationForm.reset();
                closeConsultationModal();
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }, 800);
        });
        
        // Set default values for better UX
        document.getElementById('kitchen').value = 'southeast';
        
        // Add tooltip functionality
        const infoTooltips = document.querySelectorAll('.info-tooltip');
        infoTooltips.forEach(tooltip => {
            tooltip.setAttribute('title', tooltip.getAttribute('title') || 'More information');
        });
    </script>
</body>
</html>