    <script>
        // FAQ Accordion functionality with smooth toggle
        document.querySelectorAll('.faq-question').forEach(button => {
            button.addEventListener('click', () => {
                const answer = button.nextElementSibling;
                const icon = button.querySelector('i');
                
                // Toggle visibility
                if (answer.classList.contains('hidden')) {
                    answer.classList.remove('hidden');
                    icon.classList.remove('fa-chevron-down');
                    icon.classList.add('fa-chevron-up');
                } else {
                    answer.classList.add('hidden');
                    icon.classList.remove('fa-chevron-up');
                    icon.classList.add('fa-chevron-down');
                }
            });
        });
        
        // Form submission with validation and API simulation
        const form = document.getElementById('legalConsultForm');
        const successDiv = document.getElementById('successMessage');
        const submitBtn = document.getElementById('submitBtn');
        
        form.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Basic validation
            const name = document.getElementById('consultName').value.trim();
            const phone = document.getElementById('consultPhone').value.trim();
            const email = document.getElementById('consultEmail').value.trim();
            const service = document.getElementById('consultService').value;
            
            if (!name || !phone || !email || !service) {
                alert('❌ Please fill in all required fields.');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                alert('❌ Please enter a valid 10-digit mobile number.');
                return;
            }
            
            if (!email.includes('@')) {
                alert('❌ Please enter a valid email address.');
                return;
            }
            
            // Disable button and show loading state
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loading-spinner"></span> Submitting...';
            submitBtn.disabled = true;
            
            // Simulate API call (replace with actual backend endpoint if needed)
            setTimeout(() => {
                // Success flow
                successDiv.classList.remove('hidden');
                form.reset();
                
                // Reset button
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
                
                // Auto scroll to success message
                successDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                
                // Hide success message after 6 seconds
                setTimeout(() => {
                    successDiv.classList.add('hidden');
                }, 6000);
                
                // Optional: console log for demo
                console.log('Legal Consultation Request:', { name, phone, email, service, message: document.getElementById('consultMessage').value });
                
            }, 800);
        });
        
        // Additional interactive hover effect for service icons
        const serviceCards = document.querySelectorAll('.service-card');
        serviceCards.forEach(card => {
            card.addEventListener('mouseenter', () => {
                const iconDiv = card.querySelector('.icon-container');
                if (iconDiv) iconDiv.style.transform = 'scale(1.05)';
            });
            card.addEventListener('mouseleave', () => {
                const iconDiv = card.querySelector('.icon-container');
                if (iconDiv) iconDiv.style.transform = 'scale(1)';
            });
        });
    </script>
</body>
</html>