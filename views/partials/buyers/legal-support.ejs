    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* ========== COMPLETE CUSTOM CSS FOR LEGAL SUPPORT PAGE ========== */
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        }

        /* Smooth transitions for all interactive elements */
        .service-card,
        .faq-question,
        button,
        a {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Service card hover effects */
        .service-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.2s ease;
        }
        
        .service-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -12px rgba(0, 0, 0, 0.15), 0 4px 8px -4px rgba(0, 0, 0, 0.05);
            border-color: #93c5fd !important;
        }

        /* Icon container animations */
        .icon-container {
            transition: transform 0.2s ease, background-color 0.3s ease;
        }

        .service-card:hover .icon-container {
            transform: scale(1.08);
        }

        /* FAQ section custom styling */
        .faq-question {
            cursor: pointer;
            padding: 0.75rem 0;
            border-radius: 0.75rem;
            transition: background-color 0.2s ease;
        }

        .faq-question:hover {
            background-color: #f8fafc;
        }

        .faq-question i {
            transition: transform 0.25s ease;
        }

        .faq-answer {
            padding: 0.5rem 0 0.75rem 1rem;
            border-left: 3px solid #3b82f6;
            margin-left: 0.5rem;
            animation: fadeSlideDown 0.3s ease-out;
        }

        @keyframes fadeSlideDown {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Form input focus effects */
        input:focus, select:focus, textarea:focus {
            outline: none;
            ring: 2px solid #3b82f6;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        /* Sticky card glass effect */
        .sticky-card {
            backdrop-filter: blur(2px);
            border: 1px solid rgba(255,255,255,0.6);
        }

        /* Button ripple and press effect */
        .btn-primary {
            position: relative;
            overflow: hidden;
        }
        
        .btn-primary:active {
            transform: scale(0.97);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #e2e8f0;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #94a3b8;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #64748b;
        }

        /* Success message animation */
        .success-toast {
            animation: slideUpFade 0.4s ease-out forwards;
        }
        
        @keyframes slideUpFade {
            from {
                opacity: 0;
                transform: translateY(15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Service badge styling */
        .price-badge {
            background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
            display: inline-block;
        }

        /* Phone number hover effect */
        .phone-number {
            transition: all 0.2s;
        }
        .phone-number:hover {
            transform: scale(1.02);
            color: #1e40af;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .service-card {
                margin-bottom: 0.5rem;
            }
            .faq-answer {
                font-size: 0.9rem;
            }
        }

        /* Loading spinner for form submission (optional) */
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid #ffffff;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 0.6s linear infinite;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Header wave effect */
        .hero-gradient {
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        }

        /* Tooltip custom */
        [data-tooltip] {
            position: relative;
            cursor: help;
        }
        [data-tooltip]:before {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: #1e293b;
            color: white;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 12px;
            white-space: nowrap;
            display: none;
            z-index: 10;
        }
        [data-tooltip]:hover:before {
            display: block;
        }
    </style>
</head>
