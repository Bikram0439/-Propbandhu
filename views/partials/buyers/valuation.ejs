    <script>
        // City rates database (₹ per sq ft)
        const cityRates = {
            mumbai: 28000,
            delhi: 20000,
            bangalore: 16500,
            pune: 13000,
            hyderabad: 12000,
            chennai: 11000,
            kolkata: 9500,
            ahmedabad: 9000
        };
        
        // Property type multipliers
        const typeMultiplier = {
            apartment: 1,
            villa: 1.55,
            plot: 0.85,
            commercial: 1.35
        };
        
        // Package selection logic
        let selectedPackageName = "comprehensive";
        let selectedPackagePrice = 12000;
        
        const packageCards = document.querySelectorAll('.package-card');
        packageCards.forEach(card => {
            card.addEventListener('click', () => {
                packageCards.forEach(c => c.classList.remove('selected'));
                card.classList.add('selected');
                selectedPackageName = card.getAttribute('data-package');
                selectedPackagePrice = parseInt(card.getAttribute('data-price'));
                document.getElementById('selectedPackage').value = selectedPackageName;
                document.getElementById('selectedPackagePrice').value = selectedPackagePrice;
            });
        });
        
        // Set default selected package (Comprehensive)
        document.querySelector('.package-card[data-package="comprehensive"]').classList.add('selected');
        
        // Valuation Calculator Form Submission
        const valuationForm = document.getElementById('valuationForm');
        const calcBtn = document.getElementById('calcBtn');
        const valuationResultDiv = document.getElementById('valuationResult');
        const estimatedValueSpan = document.getElementById('estimatedValue');
        
        valuationForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const area = parseFloat(document.getElementById('area').value);
            const city = document.getElementById('city').value;
            const propertyType = document.getElementById('propertyType').value;
            const age = parseFloat(document.getElementById('age').value) || 0;
            const furnishing = document.getElementById('furnishing').value;
            
            if (!area || area <= 0) {
                alert('❌ Please enter a valid area in sq. ft.');
                return;
            }
            
            let baseRate = cityRates[city] || 12000;
            let estimatedValue = area * baseRate * typeMultiplier[propertyType];
            
            // Depreciation: 1% per year, max 30%
            if (age > 0) {
                let depreciation = Math.min(0.3, age * 0.01);
                estimatedValue *= (1 - depreciation);
            }
            
            // Furnishing adjustment
            if (furnishing === 'semi') estimatedValue *= 1.08;
            if (furnishing === 'fully') estimatedValue *= 1.18;
            
            // Round to nearest thousand
            estimatedValue = Math.round(estimatedValue / 1000) * 1000;
            
            // Format and display
            estimatedValueSpan.innerHTML = '₹' + estimatedValue.toLocaleString('en-IN');
            valuationResultDiv.classList.remove('hidden');
            
            // Smooth scroll to result
            valuationResultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
        
        // Inspection Booking Form Submission
        const inspectionForm = document.getElementById('inspectionForm');
        const bookBtn = document.getElementById('bookBtn');
        const inspectionSuccess = document.getElementById('inspectionSuccess');
        
        inspectionForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const name = document.getElementById('inspectionName').value.trim();
            const phone = document.getElementById('inspectionPhone').value.trim();
            const email = document.getElementById('inspectionEmail').value.trim();
            const address = document.getElementById('inspectionAddress').value.trim();
            
            if (!name || !phone || !email || !address) {
                alert('❌ Please fill in all required fields.');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                alert('❌ Please enter a valid 10-digit mobile number.');
                return;
            }
            
            if (!email.includes('@')) {
                alert('❌ Please enter a valid email address.');
                return;
            }
            
            // Show loading state
            const originalBtnText = bookBtn.innerHTML;
            bookBtn.innerHTML = '<span class="loading-spinner"></span> Booking...';
            bookBtn.disabled = true;
            
            // Simulate API call
            setTimeout(() => {
                // Store booking data (in real app, send to backend)
                const bookingData = {
                    name,
                    phone,
                    email,
                    address,
                    preferredDate: document.getElementById('inspectionDate').value,
                    package: selectedPackageName,
                    packagePrice: selectedPackagePrice,
                    timestamp: new Date().toISOString()
                };
                console.log('Inspection Booking:', bookingData);
                
                // Show success message
                inspectionSuccess.classList.remove('hidden');
                
                // Reset form
                inspectionForm.reset();
                
                // Keep package selection
                document.querySelector('.package-card[data-package="comprehensive"]').classList.add('selected');
                selectedPackageName = "comprehensive";
                selectedPackagePrice = 12000;
                
                // Reset button
                bookBtn.innerHTML = originalBtnText;
                bookBtn.disabled = false;
                
                // Scroll to success
                inspectionSuccess.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                
                // Auto hide after 6 seconds
                setTimeout(() => {
                    inspectionSuccess.classList.add('hidden');
                }, 6000);
            }, 800);
        });
        
        // Set minimum date for date picker to today
        const today = new Date().toISOString().split('T')[0];
        const dateInput = document.getElementById('inspectionDate');
        if (dateInput) dateInput.min = today;
        
        // Add tooltip functionality
        const tooltipIcons = document.querySelectorAll('.tooltip-icon');
        tooltipIcons.forEach(icon => {
            icon.addEventListener('mouseenter', (e) => {
                // Tooltip already handled by CSS data-tooltip
            });
        });
    </script>
</body>
</html>