                                <div class="service-icon w-12 h-12 bg-yellow-100 rounded-xl flex items-center justify-center">
                                    <i class="fas fa-bolt text-yellow-600 text-xl"></i>
                                </div>
                                <div>
                                    <p class="font-bold text-gray-800">Emergency Electrician</p>
                                    <p class="text-xs text-gray-500">Short circuit, power failure, wiring</p>
                                </div>
                            </div>
                            <button onclick="callNow('+919876543211')" class="call-btn bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-green-700">
                                <i class="fas fa-phone-alt mr-1"></i> Call
                            </button>
                        </div>
                        
                        <div class="service-card border rounded-xl p-4 flex justify-between items-center hover:border-red-300">
                            <div class="flex items-center gap-3">
                                <div class="service-icon w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
