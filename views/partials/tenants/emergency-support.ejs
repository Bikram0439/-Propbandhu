    <script>
        function callNow(number) {
            window.location.href = `tel:${number}`;
        }
        
        const emergencyForm = document.getElementById('emergencyForm');
        const submitBtn = document.getElementById('submitBtn');
        
        emergencyForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Validate form
            const serviceType = document.getElementById('serviceType').value;
            const name = document.getElementById('name').value.trim();
            const phone = document.getElementById('phone').value.trim();
            const address = document.getElementById('address').value.trim();
            const consent = document.getElementById('emergencyConsent').checked;
            
            if (!serviceType || !name || !phone || !address) {
                showToast('❌ Please fill in all required fields', 'error');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                showToast('❌ Please enter a valid 10-digit mobile number', 'error');
                return;
            }
            
            if (!consent) {
                showToast('❌ Please confirm that this is an emergency', 'error');
                return;
            }
            
            const urgency = document.getElementById('urgency').value;
            let responseTime = '';
            if (urgency === 'high') responseTime = 'within 1 hour';
            else if (urgency === 'medium') responseTime = 'within 3 hours';
            else responseTime = 'within 24 hours';
            
            const serviceTypeText = document.getElementById('serviceType').options[document.getElementById('serviceType').selectedIndex]?.text || serviceType;
            
            // Show loading state
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loading-spinner"></span> Sending Emergency Request...';
            submitBtn.disabled = true;
            
            // Simulate API call
            setTimeout(() => {
                // Log emergency request
                console.log('Emergency Request:', {
                    serviceType, name, phone, address, urgency,
                    description: document.getElementById('description').value,
                    timestamp: new Date().toISOString()
                });
                
                // Show success message with details
                showEmergencyAlert(serviceTypeText, responseTime);
                
                // Reset form
                emergencyForm.reset();
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }, 1000);
        });
        
        function showEmergencyAlert(serviceType, responseTime) {
            // Create custom modal-like alert
            const alertDiv = document.createElement('div');
            alertDiv.className = 'fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center z-50';
            alertDiv.innerHTML = `
                <div class="bg-white rounded-2xl p-6 max-w-md mx-4 text-center success-message">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-check-circle text-green-600 text-3xl"></i>
                    </div>
                    <h3 class="text-xl font-bold text-gray-800 mb-2">Emergency Request Sent!</h3>
                    <p class="text-gray-600 mb-3">Service: <strong>${serviceType}</strong></p>
                    <p class="text-gray-600 mb-3">Response Time: <strong class="text-red-600">${responseTime}</strong></p>
                    <p class="text-sm text-gray-500 mb-4">Our emergency team will contact you shortly at your provided number.</p>
                    <div class="bg-red-50 p-3 rounded-xl mb-4">
                        <p class="text-sm text-red-700"><i class="fas fa-phone-alt"></i> In case of extreme emergency, call our helpline: <strong>1800-123-4567</strong></p>
                    </div>
                    <button onclick="this.parentElement.parentElement.remove()" class="bg-red-600 text-white px-6 py-2 rounded-xl font-semibold hover:bg-red-700">OK</button>
                </div>
            `;
            document.body.appendChild(alertDiv);
            
            // Auto remove after 8 seconds
            setTimeout(() => {
                if (alertDiv) alertDiv.remove();
            }, 8000);
        }
        
        function showToast(message, type = 'error') {
            const existingToast = document.querySelector('.toast-notification');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-triangle' : 'info-circle'}"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 4000);
        }
        
        // Update urgency display based on selection
        const urgencySelect = document.getElementById('urgency');
        urgencySelect.addEventListener('change', function() {
            const serviceSelect = document.getElementById('serviceType');
            if (this.value === 'high' && serviceSelect.value === 'gas') {
                showToast('⚠️ Gas leak is critical - Our team will respond immediately', 'info');
            }
        });
    </script>
</body>
</html>