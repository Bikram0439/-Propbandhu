<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Emergency Support - Propbandhu | 24/7 Property Emergency Assistance</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* ========== COMPLETE CUSTOM CSS FOR EMERGENCY SUPPORT PAGE ========== */
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        }

        /* Emergency banner pulse animation */
        .emergency-banner {
            animation: emergencyPulse 2s infinite;
            position: relative;
            overflow: hidden;
        }
        
        @keyframes emergencyPulse {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(220, 38, 38, 0.4);
            }
            50% {
                box-shadow: 0 0 0 15px rgba(220, 38, 38, 0);
            }
        }
        
        .emergency-banner::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: rotateGlow 8s linear infinite;
        }
        
        @keyframes rotateGlow {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Service card hover effects */
        .service-card {
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .service-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.15);
            border-color: #ef4444;
        }

        /* Call button hover */
        .call-btn {
            transition: all 0.2s ease;
        }
        
        .call-btn:hover {
            transform: scale(1.05);
            background-color: #16a34a;
        }

        /* Form input focus effects */
        input:focus, select:focus, textarea:focus {
            outline: none;
            ring: 2px solid #ef4444;
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
        }

        /* Button press effect */
        .btn-submit {
            position: relative;
            overflow: hidden;
        }
        
        .btn-submit:active {
            transform: scale(0.97);
        }

        /* Loading spinner */
        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 2px solid #ffffff;
            border-radius: 50%;
            border-top-color: transparent;
            animation: spin 0.6s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }
        
        ::-webkit-scrollbar-track {
            background: #fecaca;
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: #ef4444;
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: #dc2626;
        }

        /* Toast notification */
        .toast-notification {
            position: fixed;
            bottom: 24px;
            right: 24px;
            background: #1e293b;
            color: white;
            padding: 12px 20px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
            z-index: 1000;
            animation: slideInRight 0.3s ease-out;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        
        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(100px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Urgency badge styling */
        .urgency-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
        }
        
        .urgency-high { background: #fee2e2; color: #dc2626; }
        .urgency-medium { background: #fed7aa; color: #ea580c; }
        .urgency-low { background: #dcfce7; color: #16a34a; }

        /* Safety tips hover */
        .safety-tip {
            transition: all 0.2s ease;
        }
        
        .safety-tip:hover {
            transform: translateX(5px);
            background-color: #fef3c7;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .emergency-banner {
                padding: 20px;
            }
            .emergency-banner h2 {
                font-size: 1.5rem;
            }
            .emergency-banner p {
                font-size: 1.25rem;
            }
        }

        /* Floating emergency button */
        .floating-emergency {
            position: fixed;
            bottom: 30px;
            left: 30px;
            z-index: 40;
            animation: bounce 2s infinite;
        }
        
        @keyframes bounce {
            0%, 100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        /* Service icon animation */
        .service-icon {
            transition: transform 0.2s;
        }
        
        .service-card:hover .service-icon {
            transform: scale(1.1);
        }

        /* Form success animation */
        .success-message {
            animation: successPop 0.4s ease-out;
        }
        
        @keyframes successPop {
            from {
                opacity: 0;
                transform: scale(0.95);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        
        /* Siren animation for emergency banner */
        .siren {
            display: inline-block;
            animation: sirenFlash 1s infinite;
        }
        
        @keyframes sirenFlash {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
    </style>
</head>
