                                </div>
                            </div>
                            <button onclick="callNow('+919876543212')" class="call-btn bg-green-600 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-green-700">
                                <i class="fas fa-phone-alt mr-1"></i> Call
                            </button>
