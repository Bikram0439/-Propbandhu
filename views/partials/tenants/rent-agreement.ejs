    <script>
        // Maintenance field toggle
        const includeMaintenance = document.getElementById('includeMaintenance');
        const maintenanceField = document.getElementById('maintenanceField');
        
        includeMaintenance.addEventListener('change', function() {
            if (this.checked) {
                maintenanceField.classList.remove('hidden');
            } else {
                maintenanceField.classList.add('hidden');
            }
        });
        
        // Set minimum date to today
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('startDate').min = today;
        document.getElementById('startDate').value = today;
        
        // Tooltip functionality (simple)
        const infoIcons = document.querySelectorAll('[data-tooltip]');
        infoIcons.forEach(icon => {
            icon.setAttribute('title', icon.getAttribute('data-tooltip'));
        });
        
        // Form submission with validation and API simulation
        const agreementForm = document.getElementById('agreementForm');
        const generateBtn = document.getElementById('generateBtn');
        
        agreementForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Validation
            const tenantName = document.getElementById('tenantName').value.trim();
            const ownerName = document.getElementById('ownerName').value.trim();
            const propertyAddress = document.getElementById('propertyAddress').value.trim();
            const monthlyRent = document.getElementById('monthlyRent').value;
            const startDate = document.getElementById('startDate').value;
            
            if (!tenantName || !ownerName || !propertyAddress || !monthlyRent || !startDate) {
                alert('❌ Please fill in all required fields marked with *');
                return;
            }
            
            if (parseFloat(monthlyRent) <= 0) {
                alert('❌ Please enter a valid monthly rent amount');
                return;
            }
            
            // Show loading state
            const originalText = generateBtn.innerHTML;
            generateBtn.innerHTML = '<span class="loading-spinner"></span> Generating Agreement...';
            generateBtn.disabled = true;
            
            // Prepare data
            const agreementData = {
                tenantName: tenantName,
                ownerName: ownerName,
                propertyAddress: propertyAddress,
                monthlyRent: parseFloat(monthlyRent),
                securityDeposit: parseFloat(document.getElementById('securityDeposit').value) || 0,
                startDate: startDate,
                duration: parseInt(document.getElementById('duration').value),
                noticePeriod: parseInt(document.getElementById('noticePeriod').value) || 30,
                rentDueDay: parseInt(document.getElementById('rentDueDay').value),
                includeMaintenance: document.getElementById('includeMaintenance').checked,
                maintenanceCharges: parseFloat(document.getElementById('maintenanceCharges').value) || 0,
                includeParking: document.getElementById('includeParking').checked,
                includeElectricity: document.getElementById('includeElectricity').checked,
                generatedAt: new Date().toISOString()
            };
            
            // Simulate API call (in production, replace with actual backend endpoint)
            setTimeout(() => {
                // Log for debugging
                console.log('Rent Agreement Data:', agreementData);
                
                // Generate end date
                const endDate = new Date(startDate);
                endDate.setMonth(endDate.getMonth() + agreementData.duration);
                const formattedEndDate = endDate.toLocaleDateString('en-IN');
                const formattedStartDate = new Date(startDate).toLocaleDateString('en-IN');
                
                // Create a simple preview/success message
                const totalRent = agreementData.monthlyRent * agreementData.duration;
                const totalMaintenance = agreementData.includeMaintenance ? agreementData.maintenanceCharges * agreementData.duration : 0;
                
                alert(`✅ Rent Agreement Generated Successfully!\n\n` +
                    `📄 Agreement Details:\n` +
                    `Tenant: ${agreementData.tenantName}\n` +
                    `Owner: ${agreementData.ownerName}\n` +
                    `Property: ${agreementData.propertyAddress.substring(0, 50)}...\n` +
                    `Monthly Rent: ₹${agreementData.monthlyRent.toLocaleString()}\n` +
                    `Duration: ${agreementData.duration} months\n` +
                    `Period: ${formattedStartDate} to ${formattedEndDate}\n` +
                    `Security Deposit: ₹${agreementData.securityDeposit.toLocaleString()}\n\n` +
                    `📎 A download link has been sent to your email. The PDF agreement is ready for e-signature.`);
                
                // Simulate PDF download
                const dummyPDF = `data:application/pdf,${encodeURIComponent(JSON.stringify(agreementData, null, 2))}`;
                // In real scenario, would trigger download via backend
                
                // Reset button
                generateBtn.innerHTML = originalText;
                generateBtn.disabled = false;
                
                // Reset form (optional - can keep data for reference)
                // agreementForm.reset();
                // document.getElementById('startDate').value = today;
                // maintenanceField.classList.add('hidden');
                // document.getElementById('includeMaintenance').checked = false;
                
                // Add success animation to button
                generateBtn.classList.add('success-pulse');
                setTimeout(() => {
                    generateBtn.classList.remove('success-pulse');
                }, 500);
                
            }, 1500);
        });
        
        // Add input validation for numeric fields
        const numberInputs = document.querySelectorAll('input[type="number"]');
        numberInputs.forEach(input => {
            input.addEventListener('input', function() {
                if (this.value < 0) this.value = 0;
            });
        });
        
        // Preview helper - update end date when duration changes
        const durationSelect = document.getElementById('duration');
        const startDateInput = document.getElementById('startDate');
        
        function updateEndDatePreview() {
            if (startDateInput.value) {
                const endDate = new Date(startDateInput.value);
                endDate.setMonth(endDate.getMonth() + parseInt(durationSelect.value));
                // Could display preview - optional
            }
        }
        
        durationSelect.addEventListener('change', updateEndDatePreview);
        startDateInput.addEventListener('change', updateEndDatePreview);
    </script>
</body>
</html>