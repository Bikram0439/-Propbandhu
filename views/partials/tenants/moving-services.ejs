    <script>
        // Distance database (simplified)
        const distanceMap = {
            'mumbai-delhi': 1400, 'delhi-mumbai': 1400,
            'mumbai-bangalore': 980, 'bangalore-mumbai': 980,
            'mumbai-pune': 150, 'pune-mumbai': 150,
            'mumbai-chennai': 1330, 'chennai-mumbai': 1330,
            'mumbai-hyderabad': 710, 'hyderabad-mumbai': 710,
            'mumbai-kolkata': 1940, 'kolkata-mumbai': 1940,
            'delhi-bangalore': 2150, 'bangalore-delhi': 2150,
            'delhi-pune': 1450, 'pune-delhi': 1450,
            'delhi-chennai': 2200, 'chennai-delhi': 2200,
            'delhi-hyderabad': 1550, 'hyderabad-delhi': 1550,
            'bangalore-pune': 860, 'pune-bangalore': 860,
            'bangalore-chennai': 350, 'chennai-bangalore': 350,
            'bangalore-hyderabad': 570, 'hyderabad-bangalore': 570
        };
        
        function getDistance(from, to) {
            const key1 = `${from.toLowerCase()}-${to.toLowerCase()}`;
            const key2 = `${to.toLowerCase()}-${from.toLowerCase()}`;
            return distanceMap[key1] || distanceMap[key2] || 500; // default 500km
        }
        
        function getDeliveryDays(distance) {
            if (distance < 200) return '1-2 days';
            if (distance < 500) return '2-3 days';
            if (distance < 1000) return '3-4 days';
            return '5-7 days';
        }
        
        function calculateMovingCost() {
            const fromCity = document.getElementById('fromCity').value.trim();
            const toCity = document.getElementById('toCity').value.trim();
            const propertySize = parseInt(document.getElementById('propertySize').value);
            const vehicleType = document.getElementById('vehicleType').value;
            
            if (!fromCity || !toCity) {
                showToast('⚠️ Please enter both source and destination cities');
                return;
            }
            
            if (fromCity.toLowerCase() === toCity.toLowerCase()) {
                showToast('⚠️ Source and destination cities cannot be the same');
                return;
            }
            
            // Calculate distance
            const distance = getDistance(fromCity, toCity);
            const deliveryDays = getDeliveryDays(distance);
            
            // Base price calculation
            let basePrice = 3500;
            const sizeMultiplier = {1: 1, 2: 1.6, 3: 2.3, 4: 3.2};
            const vehicleMultiplier = {small: 0.9, medium: 1.2, large: 1.6};
            
            let estimatedCost = basePrice * sizeMultiplier[propertySize] * vehicleMultiplier[vehicleType];
            
            // Distance factor: add per km charge
            const perKmCharge = 8;
            estimatedCost += distance * perKmCharge;
            
            // Add fuel surcharge
            estimatedCost = Math.round(estimatedCost / 100) * 100; // Round to nearest 100
            
            // Update UI
            document.getElementById('estimatedCost').innerHTML = '₹' + estimatedCost.toLocaleString('en-IN');
            document.getElementById('distanceEstimate').innerHTML = `~${distance} km`;
            document.getElementById('deliveryTime').innerHTML = deliveryDays;
            document.getElementById('priceResult').classList.remove('hidden');
            
            // Smooth scroll to result
            document.getElementById('priceResult').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        
        function bookService(serviceName) {
            showToast(`✅ Thank you! ${serviceName} will contact you within 30 minutes.`);
        }
        
        function showToast(message) {
            // Remove existing toast
            const existingToast = document.querySelector('.toast-notification');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas fa-info-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 4000);
        }
        
        // Add city autocomplete suggestion (simple)
        const cityInputs = ['fromCity', 'toCity'];
        const cities = ['Mumbai', 'Delhi', 'Bangalore', 'Pune', 'Chennai', 'Hyderabad', 'Kolkata', 'Ahmedabad', 'Jaipur', 'Lucknow'];
        
        cityInputs.forEach(id => {
            const input = document.getElementById(id);
            input.addEventListener('input', function() {
                // Simple placeholder - in production add datalist
            });
        });
        
        // Add some sample values for demo
        document.getElementById('fromCity').placeholder = 'e.g., Mumbai';
        document.getElementById('toCity').placeholder = 'e.g., Bangalore';
    </script>
</body>
