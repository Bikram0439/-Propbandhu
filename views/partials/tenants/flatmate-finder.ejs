                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Full Name <span class="text-red-500">*</span></label>
                    <input type="text" id="postName" required placeholder="Enter your full name" class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-400">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Gender <span class="text-red-500">*</span></label>
                    <select id="postGender" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-400 bg-white">
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Age</label>
                    <input type="number" id="postAge" placeholder="e.g., 25" class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Profession <span class="text-red-500">*</span></label>
                    <select id="postProfession" required class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-blue-400 bg-white">
                        <option value="working">Working Professional</option>
                        <option value="student">Student</option>
                        <option value="business">Business</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">City <span class="text-red-500">*</span></label>
                    <input type="text" id="postCity" required placeholder="e.g., Bangalore" class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Preferred Rent Budget (₹/month)</label>
                    <input type="number" id="postBudget" placeholder="e.g., 15000" class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Dietary Preference</label>
                    <select id="postDiet" class="w-full px-4 py-3 border border-gray-300 rounded-xl bg-white">
                        <option value="veg">Vegetarian</option>
                        <option value="nonveg">Non-Vegetarian</option>
                        <option value="both">No Preference</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Additional Info</label>
                    <textarea id="postInfo" rows="3" placeholder="Describe what you're looking for in a flatmate..." class="w-full px-4 py-3 border border-gray-300 rounded-xl"></textarea>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Phone Number <span class="text-red-500">*</span></label>
                    <input type="tel" id="postPhone" required placeholder="9876543210" class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white py-3 rounded-xl font-bold text-lg">Post Requirement</button>
                <button type="button" onclick="closePostModal()" class="w-full text-gray-500 py-2 hover:text-gray-700">Cancel</button>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <i class="fab fa-facebook-f text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-twitter text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-linkedin-in text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-instagram text-gray-400 hover:text-pink-400 cursor-pointer transition text-xl"></i>
            </div>
            <p class="text-gray-400 text-sm">© 2025 Propbandhu | Find Your Perfect Roommate - Safe & Verified Community</p>
            <p class="text-gray-500 text-xs mt-2">Verified profiles | Background checked | 50,000+ Happy Roommates</p>
        </div>
    </footer>

    <script>
        let allProfiles = [];
        
        // Initialize profiles array
        function initProfiles() {
            const profileCards = document.querySelectorAll('.profile-card');
            allProfiles = Array.from(profileCards);
            updateProfileCount();
        }
        
        function filterProfiles() {
            const city = document.getElementById('filterCity').value.toLowerCase();
            const gender = document.getElementById('filterGender').value.toLowerCase();
            const budget = document.getElementById('filterBudget').value;
            const profession = document.getElementById('filterProfession').value.toLowerCase();
            
            let visibleCount = 0;
            
            allProfiles.forEach(profile => {
                const profileCity = profile.getAttribute('data-city') || '';
                const profileGender = profile.getAttribute('data-gender') || '';
                const profileBudget = parseInt(profile.getAttribute('data-budget')) || 0;
                const profileProfession = profile.getAttribute('data-profession') || '';
                
                let show = true;
                
                if (city && profileCity !== city) show = false;
                if (gender && gender !== 'any' && profileGender !== gender) show = false;
                if (budget) {
                    if (budget === '5000' && profileBudget > 5000) show = false;
                    else if (budget === '10000' && (profileBudget <= 5000 || profileBudget > 10000)) show = false;
                    else if (budget === '15000' && (profileBudget <= 10000 || profileBudget > 15000)) show = false;
                    else if (budget === '20000' && (profileBudget <= 15000 || profileBudget > 20000)) show = false;
                    else if (budget === '20000+' && profileBudget <= 20000) show = false;
                }
                if (profession && profileProfession !== profession) show = false;
                
                profile.style.display = show ? 'block' : 'none';
                if (show) visibleCount++;
            });
            
            updateProfileCount(visibleCount);
            showEmptyState(visibleCount === 0);
            
            // Show toast
            showToast(`🔍 Found ${visibleCount} roommate${visibleCount !== 1 ? 's' : ''} matching your criteria`);
        }
        
        function updateProfileCount(count = null) {
            const visibleCount = count !== null ? count : document.querySelectorAll('.profile-card[style="display: block"], .profile-card:not([style])').length;
            document.getElementById('profileCount').innerText = visibleCount;
        }
        
        function showEmptyState(show) {
            const emptyState = document.getElementById('emptyState');
            const profilesGrid = document.getElementById('profilesGrid');
            if (show) {
                emptyState.classList.remove('hidden');
                profilesGrid.classList.add('hidden');
            } else {
                emptyState.classList.add('hidden');
                profilesGrid.classList.remove('hidden');
            }
        }
        
        function connectWith(name) {
            showToast(`🤝 Connection request sent to ${name}! They will be notified within 24 hours.`);
        }
        
        function openPostModal() {
            document.getElementById('postModal').classList.remove('hidden');
            document.getElementById('postModal').classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        
        function closePostModal() {
            document.getElementById('postModal').classList.add('hidden');
            document.getElementById('postModal').classList.remove('flex');
            document.body.style.overflow = 'auto';
        }
        
        function showToast(message) {
            const existingToast = document.querySelector('.toast-notification');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas fa-info-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 4000);
        }
        
        // Post Requirement Form Submission
        const postForm = document.getElementById('postRequirementForm');
        postForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const name = document.getElementById('postName').value.trim();
            const phone = document.getElementById('postPhone').value.trim();
            const city = document.getElementById('postCity').value.trim();
            
            if (!name || !phone || !city) {
                showToast('❌ Please fill in all required fields');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                showToast('❌ Please enter a valid 10-digit mobile number');
                return;
            }
            
            // Show success message
            showToast('✅ Requirement posted successfully! Your profile will appear in search results within 24 hours.');
            closePostModal();
            postForm.reset();
        });
        
        // Close modal on outside click
        const modal = document.getElementById('postModal');
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closePostModal();
            }
        });
        
        // Initialize on page load
        initProfiles();
    </script>
</body>
</html>