    <script>
        let selectedFiles = [];
        
        function previewImages(input) {
            const previewContainer = document.getElementById('imagePreviewContainer');
            const files = Array.from(input.files);
            
            if (selectedFiles.length + files.length > 10) {
                alert('You can upload maximum 10 images');
                return;
            }
            
            files.forEach(file => {
                if (file.type.startsWith('image/')) {
                    selectedFiles.push(file);
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const previewDiv = document.createElement('div');
                        previewDiv.className = 'preview-item';
                        previewDiv.innerHTML = `
                            <img src="${e.target.result}" alt="Preview">
                            <div class="preview-remove" onclick="removeImage(this, '${file.name}')">
                                <i class="fas fa-times"></i>
                            </div>
                        `;
                        previewContainer.appendChild(previewDiv);
                    };
                    reader.readAsDataURL(file);
                }
            });
        }
        
        function removeImage(element, fileName) {
            const index = selectedFiles.findIndex(f => f.name === fileName);
            if (index !== -1) {
                selectedFiles.splice(index, 1);
                element.closest('.preview-item').remove();
            }
        }
        
        function showToast(message, isError = false) {
            const existingToast = document.querySelector('.success-toast');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'success-toast';
            toast.style.background = isError ? '#ef4444' : '#22c55e';
            toast.innerHTML = `<i class="fas fa-${isError ? 'exclamation-triangle' : 'check-circle'}"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 4000);
        }
        
        document.getElementById('postPropertyForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            // Validate required fields
            const title = document.getElementById('title').value.trim();
            const price = document.getElementById('price').value;
            const location = document.getElementById('location').value.trim();
            const contactName = document.getElementById('contactName').value.trim();
            const contactPhone = document.getElementById('contactPhone').value.trim();
            const terms = document.getElementById('terms').checked;
            
            if (!title || !price || !location || !contactName || !contactPhone) {
                showToast('❌ Please fill in all required fields', true);
                return;
            }
            
            if (!/^\d{10}$/.test(contactPhone)) {
                showToast('❌ Please enter a valid 10-digit mobile number', true);
                return;
            }
            
            if (!terms) {
                showToast('❌ Please accept the terms and conditions', true);
                return;
            }
            
            if (selectedFiles.length === 0) {
                showToast('❌ Please upload at least one property image', true);
                return;
            }
            
            const submitBtn = document.getElementById('submitBtn');
            const originalText = submitBtn.innerHTML;
            submitBtn.innerHTML = '<span class="loading-spinner"></span> Posting Property...';
            submitBtn.disabled = true;
            
            const formData = new FormData();
            formData.append('title', title);
            formData.append('purpose', document.getElementById('purpose').value);
            formData.append('propertyType', document.getElementById('propertyType').value);
            formData.append('price', price);
            formData.append('area', document.getElementById('area').value);
            formData.append('bhk', document.getElementById('bhk').value);
            formData.append('furnishing', document.getElementById('furnishing').value);
            formData.append('location', location);
            formData.append('address', document.getElementById('address').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('contactName', contactName);
            formData.append('contactPhone', contactPhone);
            
            selectedFiles.forEach(file => {
                formData.append('images', file);
            });
            
            setTimeout(() => {
                console.log('Property Data:', Object.fromEntries(formData));
                showToast('✅ Property posted successfully! Our team will review and publish it within 24 hours.');
                document.getElementById('postPropertyForm').reset();
                document.getElementById('imagePreviewContainer').innerHTML = '';
                selectedFiles = [];
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
                
                setTimeout(() => {
                    window.location.href = '/seller/dashboard';
                }, 2000);
            }, 1500);
        });
    </script>
</body>
</html>