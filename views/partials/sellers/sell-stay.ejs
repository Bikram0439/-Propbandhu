<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>ROI Calculator - Propbandhu | Real Estate Investment Returns</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        /* ========== ENHANCED CUSTOM CSS FOR ROI CALCULATOR PAGE ========== */
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: linear-gradient(135deg, #f0f9ff 0%, #e0e7ff 50%, #fae8ff 100%);
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
        }

        /* Animated gradient background for cards */
        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* Result card animations */
        .roi-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            animation: fadeSlideUp 0.5s ease-out;
            background: linear-gradient(135deg, #059669, #2563eb, #7c3aed);
            background-size: 200% 200%;
            animation: gradientBG 4s ease infinite, fadeSlideUp 0.5s ease-out;
        }
        
        @keyframes fadeSlideUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ROI percentage animation */
        .roi-percentage {
            animation: numberPop 0.6s ease-out;
            display: inline-block;
        }
        
        @keyframes numberPop {
            0% {
                transform: scale(0.3);
                opacity: 0;
            }
            60% {
                transform: scale(1.1);
            }
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        /* Form input focus effects with glow */
        input:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
            transition: all 0.2s ease;
        }

        input {
            transition: all 0.2s ease;
        }

        /* Button press effect with ripple */
        .btn-calculate {
            position: relative;
            overflow: hidden;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, #2563eb, #4f46e5);
        }
        
        .btn-calculate:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
        }
        
        .btn-calculate:active {
            transform: scale(0.98);
        }

        /* Custom scrollbar - modern thin design */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        
        ::-webkit-scrollbar-track {
            background: #e2e8f0;
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: 10px;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(135deg, #2563eb, #7c3aed);
        }

        /* Tip card hover effects */
        .tip-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            cursor: pointer;
        }
        
        .tip-card:hover {
            transform: translateY(-5px);
            background: linear-gradient(135deg, #eff6ff, #f5f3ff);
            box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.1);
        }
        
        .tip-card:hover .tip-icon {
            transform: scale(1.1);
        }
        
        .tip-icon {
            transition: transform 0.3s ease;
        }

        /* Responsive adjustments */
        @media (max-width: 768px) {
            .roi-card h3 {
                font-size: 0.9rem;
            }
            .roi-percentage {
                font-size: 2rem;
            }
        }

        /* Readonly input styling */
        input[readonly] {
            background: linear-gradient(135deg, #f1f5f9, #f8fafc);
            cursor: not-allowed;
            font-weight: 500;
        }

        /* Number input spinner custom */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button {
            opacity: 0.5;
            cursor: pointer;
        }

        /* Breakdown item hover animation */
        .breakdown-item {
            transition: all 0.25s ease;
            border-radius: 12px;
        }
        
        .breakdown-item:hover {
            transform: translateX(6px);
            background: linear-gradient(135deg, #f8fafc, #eff6ff);
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        /* Form card glass morphism effect */
        .form-card {
            background: rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(2px);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* Floating label effect for inputs */
        .input-wrapper {
            position: relative;
        }

        /* Chart container styling */
        .chart-container {
            position: relative;
        }

        /* ROI Benchmark badges */
        .benchmark-item {
            transition: all 0.2s ease;
            cursor: pointer;
        }
        
        .benchmark-item:hover {
            transform: scale(1.05);
        }

        /* Glass morphism for empty state */
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.3);
        }

        /* Smooth section transitions */
        .section-transition {
            animation: fadeIn 0.6s ease-out;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Icon pulse animation for tips */
        @keyframes iconPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        .pulse-icon {
            animation: iconPulse 2s ease infinite;
        }
    </style>
</head>
