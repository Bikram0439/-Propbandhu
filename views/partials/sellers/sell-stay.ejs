    <script>
        let roiChart = null;
        
        function updateLoanAmount() {
            const price = parseFloat(document.getElementById('propertyPrice').value) || 0;
            const downPayment = parseFloat(document.getElementById('downPayment').value) || 0;
            const loanAmount = Math.max(0, price - downPayment);
            document.getElementById('loanAmount').value = Math.round(loanAmount);
            return loanAmount;
        }
        
        document.getElementById('propertyPrice').addEventListener('input', function() {
            updateLoanAmount();
            calculateROI();
        });
        
        document.getElementById('downPayment').addEventListener('input', function() {
            const price = parseFloat(document.getElementById('propertyPrice').value) || 0;
            let downPayment = parseFloat(this.value) || 0;
            if (downPayment > price) {
                downPayment = price;
                this.value = price;
            }
            updateLoanAmount();
            calculateROI();
        });
        
        const inputs = ['interestRate', 'loanTenure', 'monthlyRent', 'appreciation', 'maintenance', 'propertyTax'];
        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', calculateROI);
        });
        
        function calculateROI() {
            const price = parseFloat(document.getElementById('propertyPrice').value) || 0;
            const downPayment = parseFloat(document.getElementById('downPayment').value) || 0;
            const loanAmount = price - downPayment;
            const annualRate = parseFloat(document.getElementById('interestRate').value) || 8.5;
            const tenureYears = parseFloat(document.getElementById('loanTenure').value) || 20;
            const monthlyRent = parseFloat(document.getElementById('monthlyRent').value) || 0;
            const appreciationPercent = parseFloat(document.getElementById('appreciation').value) || 0;
            const maintenance = parseFloat(document.getElementById('maintenance').value) || 0;
            const propertyTax = parseFloat(document.getElementById('propertyTax').value) || 0;
            
            const monthlyRate = annualRate / 12 / 100;
            const tenureMonths = tenureYears * 12;
            let emi = 0;
            if (loanAmount > 0 && monthlyRate > 0) {
                emi = loanAmount * monthlyRate * Math.pow(1 + monthlyRate, tenureMonths) / (Math.pow(1 + monthlyRate, tenureMonths) - 1);
            } else if (loanAmount > 0) {
                emi = loanAmount / tenureMonths;
            }
            
            const annualEMI = emi * 12;
            const annualRent = monthlyRent * 12;
            const totalExpenses = maintenance + propertyTax;
            const netAnnualIncome = annualRent - annualEMI - totalExpenses;
            const annualAppreciation = price * (appreciationPercent / 100);
            const totalReturn = netAnnualIncome + annualAppreciation;
            const roi = downPayment > 0 ? (totalReturn / downPayment) * 100 : 0;
            
            document.getElementById('monthlyEMI').innerHTML = '₹' + Math.round(emi).toLocaleString('en-IN');
            document.getElementById('rentalIncome').innerHTML = '₹' + monthlyRent.toLocaleString('en-IN');
            const netMonthly = monthlyRent - emi;
            document.getElementById('netCashFlow').innerHTML = '₹' + Math.round(netMonthly).toLocaleString('en-IN');
            document.getElementById('annualAppreciation').innerHTML = '₹' + Math.round(annualAppreciation).toLocaleString('en-IN');
            document.getElementById('totalReturn').innerHTML = '₹' + Math.round(totalReturn).toLocaleString('en-IN');
            document.getElementById('roiPercentage').innerHTML = Math.round(roi) + '%';
            
            const roiRating = document.getElementById('roiRating');
            let ratingText = '', ratingColor = '';
            if (roi >= 12) { ratingText = '🌟 Excellent ROI! This is a high-performing investment.'; ratingColor = 'text-green-300'; }
            else if (roi >= 8) { ratingText = '👍 Good ROI. Solid investment with decent returns.'; ratingColor = 'text-blue-300'; }
            else if (roi >= 5) { ratingText = '📊 Average ROI. Consider improving rental income or negotiating price.'; ratingColor = 'text-yellow-300'; }
            else { ratingText = '⚠️ Low ROI. Review your investment strategy or consider alternative options.'; ratingColor = 'text-red-300'; }
            roiRating.innerHTML = ratingText;
            roiRating.className = `mt-3 text-sm font-semibold ${ratingColor}`;
            
            if (roiChart) roiChart.destroy();
            const ctx = document.getElementById('roiChart').getContext('2d');
            roiChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Rental Income', 'Appreciation', 'Net Return'],
                    datasets: [{
                        label: 'Amount (₹)',
                        data: [annualRent, annualAppreciation, totalReturn],
                        backgroundColor: ['#10b981', '#3b82f6', '#8b5cf6'],
                        borderRadius: 10,
                        barPercentage: 0.6,
                        hoverBackgroundColor: ['#059669', '#2563eb', '#7c3aed']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: { callbacks: { label: (ctx) => '₹' + ctx.raw.toLocaleString('en-IN') } }
                    },
                    scales: {
                        y: {
                            grid: { color: '#e2e8f0' },
                            ticks: { callback: (value) => '₹' + (value / 100000).toFixed(1) + 'L' }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
            
            document.getElementById('roiResults').classList.remove('hidden');
            document.getElementById('emptyState').classList.add('hidden');
        }
        
        updateLoanAmount();
        calculateROI();
    </script>
</body>
</html>