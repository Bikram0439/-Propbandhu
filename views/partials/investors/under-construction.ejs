                    <span class="rera-badge absolute top-3 right-3 text-white px-2 py-1 rounded-lg text-xs font-bold shadow-md">
                        <i class="fas fa-certificate"></i> RERA Registered
                    </span>
                    <span class="absolute bottom-3 left-3 bg-black/60 text-white px-2 py-1 rounded-lg text-xs">🚧 20% Completed</span>
                </div>
                <div class="p-5">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-xl text-gray-800">Urban Forest</h3>
                        <span class="roi-highlight text-orange-700 text-xs font-bold px-2 py-1 rounded-full">🔥 15% ROI</span>
                    </div>
                    <p class="text-gray-500 text-sm mb-3"><i class="fas fa-map-marker-alt text-blue-500 mr-1"></i> Gurgaon, Delhi NCR</p>
                    <div class="flex justify-between items-baseline mb-3">
                        <span class="text-2xl font-bold text-blue-600">₹2.8 Cr*</span>
                        <span class="text-gray-500 text-sm">4/5 BHK</span>
                    </div>
                    <div class="flex justify-between text-sm text-gray-600 mb-3">
                        <span><i class="fas fa-calendar-alt"></i> Possession: Dec 2026</span>
                        <span><i class="fas fa-chart-line"></i> Est. Appreciation: 15%</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-1.5 mb-4">
                        <div class="progress-bar bg-green-500 h-1.5 rounded-full" style="width: 20%"></div>
                    </div>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="amenity-tag"><i class="fas fa-golf-ball"></i> Golf Course</span>
                        <span class="amenity-tag"><i class="fas fa-spa"></i> Spa</span>
                        <span class="amenity-tag"><i class="fas fa-car"></i> EV Charging</span>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="viewProject('Urban Forest')" class="flex-1 bg-blue-600 text-white py-2.5 rounded-xl font-semibold hover:bg-blue-700 transition">View Details</button>
                        <button onclick="investNow('Urban Forest')" class="flex-1 bg-gradient-to-r from-green-600 to-green-700 text-white py-2.5 rounded-xl font-semibold hover:shadow-lg transition">Invest Now</button>
                    </div>
                </div>
            </div>

            <!-- Project 6 - Tech Park Residences -->
            <div class="project-card bg-white rounded-2xl shadow-xl overflow-hidden" data-city="bangalore" data-budget="100to200" data-possession="2025" data-type="2bhk">
                <div class="project-image h-52 relative">
                    <img src="https://images.unsplash.com/photo-1560185007-cde436f6a4d0?w=500&h=350&fit=crop" alt="Tech Park Residences" class="w-full h-full object-cover">
                    <span class="rera-badge absolute top-3 right-3 text-white px-2 py-1 rounded-lg text-xs font-bold shadow-md">
                        <i class="fas fa-certificate"></i> RERA Registered
                    </span>
                    <span class="absolute bottom-3 left-3 bg-black/60 text-white px-2 py-1 rounded-lg text-xs">🚧 80% Completed</span>
                </div>
                <div class="p-5">
                    <div class="flex justify-between items-start mb-2">
                        <h3 class="font-bold text-xl text-gray-800">Tech Park Residences</h3>
                        <span class="roi-highlight text-orange-700 text-xs font-bold px-2 py-1 rounded-full">🔥 24% ROI</span>
                    </div>
                    <p class="text-gray-500 text-sm mb-3"><i class="fas fa-map-marker-alt text-blue-500 mr-1"></i> Electronic City, Bangalore</p>
                    <div class="flex justify-between items-baseline mb-3">
                        <span class="text-2xl font-bold text-blue-600">₹95 Lakhs*</span>
                        <span class="text-gray-500 text-sm">2/3 BHK</span>
                    </div>
                    <div class="flex justify-between text-sm text-gray-600 mb-3">
                        <span><i class="fas fa-calendar-alt"></i> Possession: Aug 2025</span>
                        <span><i class="fas fa-chart-line"></i> Est. Appreciation: 24%</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-1.5 mb-4">
                        <div class="progress-bar bg-green-500 h-1.5 rounded-full" style="width: 80%"></div>
                    </div>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <span class="amenity-tag"><i class="fas fa-laptop-code"></i> IT Hub</span>
                        <span class="amenity-tag"><i class="fas fa-bus"></i> Transport</span>
                        <span class="amenity-tag"><i class="fas fa-utensils"></i> Food Court</span>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="viewProject('Tech Park Residences')" class="flex-1 bg-blue-600 text-white py-2.5 rounded-xl font-semibold hover:bg-blue-700 transition">View Details</button>
                        <button onclick="investNow('Tech Park Residences')" class="flex-1 bg-gradient-to-r from-green-600 to-green-700 text-white py-2.5 rounded-xl font-semibold hover:shadow-lg transition">Invest Now</button>
