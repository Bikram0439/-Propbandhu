        <!-- Empty State (hidden by default) -->
        <div id="emptyState" class="empty-state hidden mt-8">
            <i class="fas fa-hard-hat text-5xl text-gray-400 mb-4"></i>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">No projects found</h3>
            <p class="text-gray-500">Try adjusting your filters to see more projects</p>
            <button onclick="resetFilters()" class="mt-4 bg-blue-600 text-white px-6 py-2 rounded-lg">Clear Filters</button>
        </div>
    </div>

    <!-- Investment Modal -->
    <div id="investmentModal" class="fixed inset-0 bg-black bg-opacity-60 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4 modal-content">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-2xl font-bold text-gray-800"><i class="fas fa-chart-line text-green-600"></i> Invest in <span id="modalProjectName">Project</span></h3>
                <button onclick="closeInvestmentModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            <form id="investmentForm" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Full Name *</label>
                    <input type="text" id="invName" required class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Email *</label>
                    <input type="email" id="invEmail" required class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Phone *</label>
                    <input type="tel" id="invPhone" required class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Preferred Budget (₹)</label>
                    <input type="text" id="invBudget" placeholder="e.g., 1.2 Cr" class="w-full px-4 py-3 border border-gray-300 rounded-xl">
                </div>
                <button type="submit" class="w-full bg-gradient-to-r from-green-600 to-green-700 text-white py-3 rounded-xl font-bold text-lg">Schedule Callback</button>
                <button type="button" onclick="closeInvestmentModal()" class="w-full text-gray-500 py-2">Cancel</button>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <i class="fab fa-facebook-f text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-twitter text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-linkedin-in text-gray-400 hover:text-blue-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-instagram text-gray-400 hover:text-pink-400 cursor-pointer transition text-xl"></i>
            </div>
            <p class="text-gray-400 text-sm">© 2025 Propbandhu | Under Construction Projects - Invest in Future Growth</p>
            <p class="text-gray-500 text-xs mt-2">All projects are RERA registered | Payment plans available | T&C apply</p>
        </div>
    </footer>

    <script>
        let currentProjectName = '';
        
        function filterProjects() {
            const city = document.getElementById('filterCity').value;
            const budget = document.getElementById('filterBudget').value;
            const possession = document.getElementById('filterPossession').value;
            const type = document.getElementById('filterType').value;
            
            const projects = document.querySelectorAll('.project-card');
            let visibleCount = 0;
            
            projects.forEach(project => {
                let show = true;
                
                if (city && project.getAttribute('data-city') !== city) show = false;
                if (budget && project.getAttribute('data-budget') !== budget) show = false;
                if (possession && project.getAttribute('data-possession') !== possession) show = false;
                if (type && project.getAttribute('data-type') !== type) show = false;
                
                project.style.display = show ? 'block' : 'none';
                if (show) visibleCount++;
            });
            
            document.getElementById('projectCount').innerText = visibleCount;
            const emptyState = document.getElementById('emptyState');
            const projectsGrid = document.getElementById('projectsGrid');
            
            if (visibleCount === 0) {
                emptyState.classList.remove('hidden');
                projectsGrid.classList.add('hidden');
            } else {
                emptyState.classList.add('hidden');
                projectsGrid.classList.remove('hidden');
            }
            
            showToast(`🔍 Found ${visibleCount} project${visibleCount !== 1 ? 's' : ''} matching your criteria`);
        }
        
        function resetFilters() {
            document.getElementById('filterCity').value = '';
            document.getElementById('filterBudget').value = '';
            document.getElementById('filterPossession').value = '';
            document.getElementById('filterType').value = '';
            filterProjects();
        }
        
        function viewProject(name) {
            showToast(`📋 Viewing details of ${name}. A detailed brochure will be sent to your email.`);
        }
        
        function investNow(name) {
            currentProjectName = name;
            document.getElementById('modalProjectName').innerText = name;
            document.getElementById('investmentModal').classList.remove('hidden');
            document.getElementById('investmentModal').classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        
        function closeInvestmentModal() {
            document.getElementById('investmentModal').classList.add('hidden');
            document.getElementById('investmentModal').classList.remove('flex');
            document.body.style.overflow = 'auto';
        }
        
        function showToast(message) {
            const existingToast = document.querySelector('.toast-notification');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas fa-info-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 4000);
        }
        
        // Investment Form Submission
        const investmentForm = document.getElementById('investmentForm');
        investmentForm.addEventListener('submit', function(e) {
            e.preventDefault();
            
            const name = document.getElementById('invName').value.trim();
            const phone = document.getElementById('invPhone').value.trim();
            const email = document.getElementById('invEmail').value.trim();
            
            if (!name || !phone || !email) {
                showToast('❌ Please fill in all required fields');
                return;
            }
            
            if (!/^\d{10}$/.test(phone)) {
                showToast('❌ Please enter a valid 10-digit mobile number');
                return;
            }
            
            showToast(`✅ Thank you! Our investment advisor will contact you within 24 hours regarding ${currentProjectName}`);
            closeInvestmentModal();
            investmentForm.reset();
        });
        
        // Close modal on outside click
        const modal = document.getElementById('investmentModal');
        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeInvestmentModal();
            }
        });
        
        // Initialize progress bars animation on scroll
        const observerOptions = { threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const progressBar = entry.target.querySelector('.progress-bar');
                    if (progressBar) {
                        const width = progressBar.style.width;
                        progressBar.style.width = '0%';
                        setTimeout(() => { progressBar.style.width = width; }, 100);
                    }
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);
        
        document.querySelectorAll('.project-card').forEach(card => observer.observe(card));
    </script>
</body>
</html>