        </div>

        <!-- Expert Investment Tips -->
        <div class="bg-gradient-to-r from-yellow-50 to-amber-50 rounded-2xl p-6">
            <h3 class="font-bold text-xl text-gray-800 mb-4 flex items-center gap-2">
                <i class="fas fa-lightbulb text-yellow-600"></i> Expert Investment Tips for Developing Areas
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <div class="tip-card flex items-start gap-2 p-2 rounded-lg"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span class="text-sm">Check government infrastructure projects in the area</span></div>
                <div class="tip-card flex items-start gap-2 p-2 rounded-lg"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span class="text-sm">Verify RERA approval for all projects</span></div>
                <div class="tip-card flex items-start gap-2 p-2 rounded-lg"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span class="text-sm">Research upcoming metro, highway, or airport projects</span></div>
                <div class="tip-card flex items-start gap-2 p-2 rounded-lg"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span class="text-sm">Compare price with neighboring developed areas</span></div>
                <div class="tip-card flex items-start gap-2 p-2 rounded-lg"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span class="text-sm">Look for reputed builders entering the area</span></div>
                <div class="tip-card flex items-start gap-2 p-2 rounded-lg"><i class="fas fa-check-circle text-green-500 mt-0.5"></i><span class="text-sm">Consider rental demand and employment hubs nearby</span></div>
            </div>
        </div>
    </div>

    <!-- Projects Modal -->
    <div id="projectsModal" class="fixed inset-0 bg-black bg-opacity-60 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-6 max-w-3xl w-full mx-4 max-h-[85vh] overflow-y-auto modal-content">
            <div class="flex justify-between items-center mb-5">
                <h3 class="text-2xl font-bold text-gray-800" id="modalTitle">Projects in Area</h3>
                <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            <div id="projectsList" class="space-y-4">
                <!-- Projects will be loaded here -->
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <i class="fab fa-facebook-f text-gray-400 hover:text-green-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-twitter text-gray-400 hover:text-green-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-linkedin-in text-gray-400 hover:text-green-400 cursor-pointer transition text-xl"></i>
                <i class="fab fa-instagram text-gray-400 hover:text-green-400 cursor-pointer transition text-xl"></i>
            </div>
            <p class="text-gray-400 text-sm">© 2025 Propbandhu | Projects in Developing Areas - High Growth Investment Opportunities</p>
            <p class="text-gray-500 text-xs mt-2">RERA Registered Projects | Verified Data | Expert Investment Advisory</p>
        </div>
    </footer>

    <script>
        let growthChart = null;

        // Calculate Future Value
        function calculateFutureValue() {
            const currentPrice = parseFloat(document.getElementById('currentPrice').value);
            const appreciation = parseFloat(document.getElementById('appreciation').value) / 100;
            const years = parseFloat(document.getElementById('duration').value);
            
            if (!currentPrice || currentPrice <= 0) {
                document.getElementById('futureValue').innerHTML = '₹0';
                document.getElementById('totalProfit').innerHTML = 'Profit: ₹0';
                return;
            }
            
            const futureValue = currentPrice * Math.pow(1 + appreciation, years);
            const profit = futureValue - currentPrice;
            
            document.getElementById('futureValue').innerHTML = '₹' + futureValue.toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('totalProfit').innerHTML = `Profit: ₹${profit.toLocaleString('en-IN', {maximumFractionDigits: 0})}`;
            document.getElementById('displayDuration').innerHTML = years;
            
            updateChart(currentPrice, futureValue);
        }
        
        function updateChart(current, future) {
            if (growthChart) growthChart.destroy();
            
            const ctx = document.getElementById('growthChart').getContext('2d');
            growthChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['Current Value', 'Future Value'],
                    datasets: [{
                        label: 'Property Value (₹)',
                        data: [current, future],
                        backgroundColor: ['#22c55e', '#10b981'],
                        borderRadius: 8,
                        barPercentage: 0.6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { font: { size: 11 } } },
                        tooltip: { callbacks: { label: (ctx) => `₹${ctx.raw.toLocaleString('en-IN')}` } }
                    },
                    scales: {
                        y: {
                            ticks: { callback: (value) => '₹' + (value / 100000).toFixed(1) + 'L' }
                        }
                    }
                }
            });
        }
        
        // Projects database
        const projectsData = {
            'Noida Extension': [
                { name: 'ATS Greens', price: '45 Lakhs', possession: '2025', builder: 'ATS Group', area: 'Noida Extension' },
                { name: 'Paramount Golf Foreste', price: '52 Lakhs', possession: '2024', builder: 'Paramount Group', area: 'Noida Extension' },
                { name: 'Gaur City', price: '48 Lakhs', possession: '2024', builder: 'Gaur Group', area: 'Noida Extension' },
                { name: 'Mahagun Moderne', price: '58 Lakhs', possession: '2025', builder: 'Mahagun Group', area: 'Noida Extension' }
            ],
            'Dwarka Expressway': [
                { name: 'Signature Global City', price: '65 Lakhs', possession: '2025', builder: 'Signature Global', area: 'Dwarka Expressway' },
                { name: 'Godrej Properties', price: '78 Lakhs', possession: '2024', builder: 'Godrej Properties', area: 'Dwarka Expressway' },
                { name: 'Emaar India', price: '85 Lakhs', possession: '2025', builder: 'Emaar India', area: 'Dwarka Expressway' }
            ],
            'Panvel': [
                { name: 'Lodha Crown', price: '55 Lakhs', possession: '2025', builder: 'Lodha Group', area: 'Panvel' },
                { name: 'Runwal Forest', price: '48 Lakhs', possession: '2024', builder: 'Runwal Group', area: 'Panvel' },
                { name: 'Shapoorji Pallonji', price: '62 Lakhs', possession: '2026', builder: 'Shapoorji Pallonji', area: 'Panvel' }
            ],
            'Hinjewadi': [
                { name: 'Godrej Nest', price: '72 Lakhs', possession: '2025', builder: 'Godrej Properties', area: 'Hinjewadi' },
                { name: 'Kolte Patil', price: '65 Lakhs', possession: '2024', builder: 'Kolte Patil', area: 'Hinjewadi' },
                { name: 'Marvel Edge', price: '58 Lakhs', possession: '2025', builder: 'Marvel Group', area: 'Hinjewadi' }
            ],
            'Rajarhat': [
                { name: 'PS Group', price: '42 Lakhs', possession: '2025', builder: 'PS Group', area: 'Rajarhat' },
                { name: 'Merlin Group', price: '48 Lakhs', possession: '2024', builder: 'Merlin Group', area: 'Rajarhat' }
            ],
            'Mohali': [
                { name: 'DLF New Town', price: '68 Lakhs', possession: '2025', builder: 'DLF', area: 'Mohali' },
                { name: 'GMADA Aerocity', price: '75 Lakhs', possession: '2025', builder: 'GMADA', area: 'Mohali' }
            ]
        };
        
        function showProjects(area) {
            const projects = projectsData[area] || [];
            
            document.getElementById('modalTitle').innerHTML = `🏗️ Projects in ${area}`;
            
            let html = '';
            projects.forEach(project => {
                html += `
                    <div class="border border-gray-200 rounded-xl p-4 hover:shadow-md transition">
                        <div class="flex flex-col sm:flex-row justify-between items-start gap-3">
                            <div class="flex-1">
                                <h4 class="font-bold text-lg text-gray-800">${project.name}</h4>
                                <p class="text-sm text-gray-500"><i class="fas fa-building"></i> Builder: ${project.builder}</p>
                                <p class="text-sm text-gray-500"><i class="fas fa-calendar-alt"></i> Possession: ${project.possession}</p>
                                <p class="text-sm text-gray-500"><i class="fas fa-map-marker-alt"></i> ${project.area}</p>
                            </div>
                            <div class="text-right">
                                <p class="text-2xl font-bold text-green-600">₹${project.price}</p>
                                <button onclick="enquire('${project.name}')" class="btn-enquire mt-2 bg-green-600 text-white px-5 py-2 rounded-lg text-sm font-semibold hover:bg-green-700 transition">
                                    Enquire Now
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            document.getElementById('projectsList').innerHTML = html;
            document.getElementById('projectsModal').classList.remove('hidden');
            document.getElementById('projectsModal').classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        
        function closeModal() {
            document.getElementById('projectsModal').classList.add('hidden');
            document.getElementById('projectsModal').classList.remove('flex');
            document.body.style.overflow = 'auto';
        }
        
        function enquire(projectName) {
            showToast(`📞 Thank you for your interest in ${projectName}! Our investment expert will contact you within 2 hours.`);
            closeModal();
        }
        
        function showToast(message) {
            const existingToast = document.querySelector('.toast-notification');
            if (existingToast) existingToast.remove();
            
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas fa-info-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.remove();
            }, 4000);
        }
        
        // Event Listeners
        document.getElementById('currentPrice').addEventListener('input', calculateFutureValue);
        document.getElementById('appreciation').addEventListener('input', function() {
            document.getElementById('appreciationValue').innerHTML = this.value + '%';
            calculateFutureValue();
        });
        document.getElementById('duration').addEventListener('input', function() {
            document.getElementById('durationValue').innerHTML = this.value + ' Years';
            calculateFutureValue();
        });
        
        // Close modal on outside click
        const modal = document.getElementById('projectsModal');
        modal.addEventListener('click', function(e) {
            if (e.target === modal) closeModal();
        });
        
        // Initialize
        calculateFutureValue();
    </script>
</body>
</html>