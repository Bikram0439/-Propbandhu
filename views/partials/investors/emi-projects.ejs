                <i class="fas fa-university text-3xl text-blue-600 mb-2"></i>
                <p class="font-bold text-gray-800">ICICI</p>
                <p class="text-sm text-green-600 font-semibold">8.45% p.a.</p>
                <p class="text-xs text-gray-400">Zero Processing</p>
            </div>
            <div class="bank-card bg-white rounded-xl shadow p-4 text-center cursor-pointer hover:shadow-lg">
                <i class="fas fa-university text-3xl text-blue-600 mb-2"></i>
                <p class="font-bold text-gray-800">Axis Bank</p>
                <p class="text-sm text-green-600 font-semibold">8.55% p.a.</p>
                <p class="text-xs text-gray-400">Flexible EMI</p>
            </div>
        </div>

        <!-- Pre-Approved Loan Offer -->
        <div class="bg-gradient-to-r from-green-600 to-teal-600 rounded-2xl shadow-xl p-6 text-white text-center">
            <i class="fas fa-check-circle text-5xl mb-3"></i>
            <h3 class="text-2xl font-bold mb-2">Get Pre-Approved Home Loan</h3>
            <p class="mb-4">Check your eligibility in 2 minutes with our partner banks</p>
            <button onclick="checkPreApproval()" class="bg-white text-green-600 px-8 py-3 rounded-xl font-bold text-lg hover:bg-gray-100 transition shadow-lg">
                <i class="fas fa-bolt"></i> Check Now
            </button>
        </div>
    </div>

    <!-- Loan Application Modal -->
    <div id="loanModal" class="fixed inset-0 bg-black bg-opacity-60 hidden items-center justify-center z-50">
        <div class="bg-white rounded-2xl p-6 max-w-md w-full mx-4 modal-content">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800"><i class="fas fa-hand-holding-usd text-green-600"></i> Pre-Approved Loan</h3>
                <button onclick="closeLoanModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            <form id="loanForm" class="space-y-4">
                <div><label class="block text-sm font-semibold mb-1">Full Name *</label><input type="text" id="loanName" required class="w-full px-4 py-3 border rounded-xl"></div>
                <div><label class="block text-sm font-semibold mb-1">Email *</label><input type="email" id="loanEmail" required class="w-full px-4 py-3 border rounded-xl"></div>
                <div><label class="block text-sm font-semibold mb-1">Phone *</label><input type="tel" id="loanPhone" required class="w-full px-4 py-3 border rounded-xl"></div>
                <div><label class="block text-sm font-semibold mb-1">Annual Income (₹) *</label><input type="number" id="loanIncome" required class="w-full px-4 py-3 border rounded-xl"></div>
                <button type="submit" class="w-full bg-green-600 text-white py-3 rounded-xl font-bold">Submit Application</button>
                <button type="button" onclick="closeLoanModal()" class="w-full text-gray-500 py-2">Cancel</button>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white mt-12 py-8">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <div class="flex justify-center space-x-6 mb-4">
                <i class="fab fa-facebook-f text-gray-400 hover:text-blue-400 cursor-pointer text-xl"></i>
                <i class="fab fa-twitter text-gray-400 hover:text-blue-400 cursor-pointer text-xl"></i>
                <i class="fab fa-linkedin-in text-gray-400 hover:text-blue-400 cursor-pointer text-xl"></i>
                <i class="fab fa-instagram text-gray-400 hover:text-pink-400 cursor-pointer text-xl"></i>
            </div>
            <p class="text-gray-400 text-sm">© 2025 Propbandhu | Only EMI Projects - Easy Home Loan Options</p>
            <p class="text-gray-500 text-xs mt-2">Interest rates subject to change | T&C apply | EMI calculated on reducing balance</p>
        </div>
    </footer>

    <script>
        let emiChart = null;

        function calculateEMI() {
            const price = parseFloat(document.getElementById('propertyPrice').value);
            const downPayment = parseFloat(document.getElementById('downPayment').value);
            const rate = parseFloat(document.getElementById('interestRate').value) / 12 / 100;
            const tenureMonths = parseFloat(document.getElementById('tenure').value) * 12;
            
            const loanAmount = price - downPayment;
            let emi = 0, totalPayment = 0, totalInterest = 0;
            
            if (loanAmount > 0 && rate > 0) {
                emi = loanAmount * rate * Math.pow(1 + rate, tenureMonths) / (Math.pow(1 + rate, tenureMonths) - 1);
                totalPayment = emi * tenureMonths;
                totalInterest = totalPayment - loanAmount;
            }
            
            const affordability = loanAmount > 0 ? ((emi / (loanAmount * 0.01)) * 100).toFixed(0) : 0;
            
            document.getElementById('priceValue').innerHTML = '₹' + price.toLocaleString('en-IN');
            document.getElementById('downPaymentValue').innerHTML = '₹' + downPayment.toLocaleString('en-IN');
            document.getElementById('rateValue').innerHTML = document.getElementById('interestRate').value + '%';
            document.getElementById('tenureValue').innerHTML = document.getElementById('tenure').value + ' Years';
            document.getElementById('emiAmount').innerHTML = '₹' + (emi || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('loanAmount').innerHTML = '₹' + (loanAmount || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('totalInterest').innerHTML = '₹' + (totalInterest || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('totalPayment').innerHTML = '₹' + (totalPayment || 0).toLocaleString('en-IN', {maximumFractionDigits: 0});
            document.getElementById('affordabilityScore').innerHTML = affordability + '%';
            
            if (emiChart) emiChart.destroy();
            const ctx = document.getElementById('emiChart').getContext('2d');
            emiChart = new Chart(ctx, {
                type: 'doughnut',
                data: { labels: ['Principal Amount', 'Total Interest'], datasets: [{ data: [loanAmount, totalInterest], backgroundColor: ['#3b82f6', '#f97316'], borderWidth: 0 }] },
                options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { position: 'bottom' } } }
            });
        }
        
        function calculateProjectEMI(price) {
            document.getElementById('propertyPrice').value = price;
            document.getElementById('downPayment').value = price * 0.2;
            calculateEMI();
            document.getElementById('propertyPrice').scrollIntoView({ behavior: 'smooth', block: 'start' });
            showToast(`📊 EMI calculated for ₹${price.toLocaleString('en-IN')} property`);
        }
        
        function checkEligibility() {
            const emiText = document.getElementById('emiAmount').innerText;
            const emi = parseInt(emiText.replace(/[^0-9]/g, '')) || 0;
            showToast(`✅ Eligibility: Required monthly income ~₹${(emi * 2.5).toLocaleString()}. Our expert will contact you shortly!`);
        }
        
        function enquireProject(projectName) {
            showToast(`📞 Thank you! Expert will contact you for ${projectName} within 2 hours.`);
        }
        
        document.getElementById('comparisonForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const rent = parseFloat(document.getElementById('monthlyRent').value);
            const price = parseFloat(document.getElementById('comparePropertyPrice').value);
            const rate = 8.5 / 12 / 100;
            const tenure = 20 * 12;
            const loanAmount = price * 0.8;
            const emi = loanAmount * rate * Math.pow(1 + rate, tenure) / (Math.pow(1 + rate, tenure) - 1);
            
            document.getElementById('displayRent').innerHTML = '₹' + rent.toLocaleString();
            document.getElementById('displayEMI').innerHTML = '₹' + emi.toLocaleString('en-IN', {maximumFractionDigits: 0});
            const diff = emi - rent;
            document.getElementById('difference').innerHTML = '₹' + Math.abs(diff).toLocaleString();
            document.getElementById('comparisonResult').classList.remove('hidden');
            
            const recDiv = document.getElementById('recommendation');
            if (emi < rent) {
                recDiv.innerHTML = '✅ Buying is better! EMI is lower than rent. Start building equity!';
                recDiv.className = 'mt-3 p-3 rounded-xl text-center font-semibold bg-green-100 text-green-800';
            } else {
                recDiv.innerHTML = '⚠️ EMI is higher by ₹' + Math.abs(diff).toLocaleString() + '. Consider higher down payment or negotiate price.';
                recDiv.className = 'mt-3 p-3 rounded-xl text-center font-semibold bg-yellow-100 text-yellow-800';
            }
        });
        
        function checkPreApproval() { document.getElementById('loanModal').classList.remove('hidden'); document.getElementById('loanModal').classList.add('flex'); document.body.style.overflow = 'hidden'; }
        function closeLoanModal() { document.getElementById('loanModal').classList.add('hidden'); document.getElementById('loanModal').classList.remove('flex'); document.body.style.overflow = 'auto'; }
        
        function showToast(message) {
            const existing = document.querySelector('.toast-notification');
            if (existing) existing.remove();
            const toast = document.createElement('div');
            toast.className = 'toast-notification';
            toast.innerHTML = `<i class="fas fa-info-circle"></i><span>${message}</span>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }
        
        document.getElementById('loanForm').addEventListener('submit', function(e) {
            e.preventDefault();
            showToast('✅ Application submitted! Our loan expert will contact you within 24 hours.');
            closeLoanModal();
            this.reset();
        });
        
        document.getElementById('propertyPrice').addEventListener('input', calculateEMI);
        document.getElementById('downPayment').addEventListener('input', calculateEMI);
        document.getElementById('interestRate').addEventListener('input', calculateEMI);
        document.getElementById('tenure').addEventListener('input', calculateEMI);
        
        calculateEMI();
    </script>
</body>
</html>