                    <div class="flex items-center gap-2 mb-4">
                        <div class="logo-icon w-10 h-10">
                            <i class="fas fa-home text-white"></i>
                        </div>
                        <div>
                            <div class="text-white text-xl font-bold">Propbandhu</div>
                            <div class="text-gray-400 text-xs">by Bandhu Group</div>
                        </div>
                    </div>
