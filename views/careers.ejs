                    </p>
                    <div class="flex gap-3">
                        <a href="#" class="social-icon"><i class="fab fa-facebook-f text-gray-300"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-twitter text-gray-300"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-instagram text-gray-300"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-linkedin-in text-gray-300"></i></a>
                        <a href="#" class="social-icon"><i class="fab fa-youtube text-gray-300"></i></a>
