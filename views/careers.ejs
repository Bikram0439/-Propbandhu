                </div>
                <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
            </div>
            <form action="/careers/apply" method="POST">
                <input type="hidden" name="jobId" id="jobId">
                <input type="hidden" name="jobTitle" id="jobTitle">
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Full Name *</label>
                        <input type="text" name="name" required class="w-full px-4 py-2.5 input-modern rounded-xl focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Email *</label>
                        <input type="email" name="email" required class="w-full px-4 py-2.5 input-modern rounded-xl focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Phone *</label>
                        <input type="tel" name="phone" required class="w-full px-4 py-2.5 input-modern rounded-xl focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Experience (Years)</label>
                        <input type="text" name="experience" class="w-full px-4 py-2.5 input-modern rounded-xl focus:outline-none">
                    </div>
                    <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-3 rounded-xl font-semibold hover:shadow-lg transition-all">
                        Submit Application <i class="fas fa-paper-plane ml-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <!-- ========== MODERN FOOTER ========== -->
    <footer class="footer">
        <div class="max-w-7xl mx-auto px-4 py-12">
            <!-- Main Footer Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
                <!-- Company Info -->
