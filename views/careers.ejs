                        <li><a href="/needs/valuation" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> Property Valuation</a></li>
                        <li><a href="/needs/homeloan" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> Home Loans</a></li>
                        <li><a href="/needs/legal-support" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> Legal Support</a></li>
                    </ul>
                </div>
                
                <!-- Support -->
                <div>
                    <h3 class="footer-heading">Support</h3>
                    <ul class="space-y-2">
                        <li><a href="/about" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> About Us</a></li>
                        <li><a href="/contact" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> Contact Us</a></li>
                        <li><a href="/faq" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> FAQ</a></li>
                        <li><a href="/careers" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas fa-chevron-right text-xs text-blue-400"></i> Careers</a></li>
                        <li><a href="/blog" class="text-gray-400 hover:text-white text-sm flex items-center gap-2"><i class="fas-chevron-right text-xs text-blue-400"></i> Blog</a></li>
                    </ul>
                </div>
                
                <!-- Newsletter -->
                <div>
                    <h3 class="footer-heading">Newsletter</h3>
                    <p class="text-gray-400 text-sm mb-3">Subscribe to get updates on new properties and real estate insights.</p>
                    <form action="/newsletter" method="POST" class="flex flex-col gap-3">
                        <input type="email" name="email" placeholder="Your email address" class="newsletter-input" required>
                        <button type="submit" class="newsletter-btn text-white">Subscribe <i class="fas fa-paper-plane ml-2"></i></button>
