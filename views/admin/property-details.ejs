                </div>
                
                <!-- Selected Fields Summary -->
                <div class="mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200">
                    <div class="flex items-center mb-2">
                        <i class="fas fa-clipboard-check text-blue-500 mr-2"></i>
                        <span class="font-medium text-blue-800">Selected Fields Summary</span>
                    </div>
                    <div id="selectedFieldsSummary" class="text-sm text-blue-700">
                        No fields selected yet. Select fields from above.
                    </div>
                    <div class="mt-2 text-sm text-blue-600">
                        <i class="fas fa-clock mr-1"></i>
                        Edit Duration: <span id="durationSummary">168 hours (7 days)</span>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div class="flex justify-end space-x-3">
                    <button onclick="closeRequestChangesModal()" 
                            class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">
                        Cancel
                    </button>
                    <button onclick="confirmRequestChangesWithLimitedAccess()" 
                            class="px-4 py-2 bg-yellow-600 text-white rounded-lg text-sm font-medium hover:bg-yellow-700 flex items-center">
                        <i class="fas fa-paper-plane mr-2"></i>
                        Send with Limited Edit Access
                    </button>
                </div>
            </div>
        </div>
    </div>

   


    <!-- Reject Modal -->
    <div id="rejectModal" class="modal">
        <div class="modal-content">
            <div class="mt-3">
                <div class="flex items-center mb-4">
                    <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center mr-3">
                        <i class="fas fa-times text-red-600"></i>
                    </div>
                    <h3 class="text-lg font-medium text-gray-900">Reject Property</h3>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        Reason for rejection
                    </label>
                    <textarea id="rejectReason" rows="4" 
                              class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500" 
                              placeholder="Provide a clear reason for rejection. Example:
• Property details are inaccurate
• Images do not match the property
• Missing required documents
• Violates platform guidelines
• Seller has multiple policy violations"></textarea>
                    <p class="text-xs text-gray-500 mt-1">
                        This is a final rejection. Seller will NOT be able to edit or resubmit.
                    </p>
                </div>
                <div class="flex justify-end space-x-3">
                    <button onclick="closeRejectModal()" 
                            class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50">
                        Cancel
                    </button>
                    <button onclick="confirmReject()" 
                            class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 flex items-center">
                        <i class="fas fa-ban mr-2"></i>
                        Confirm Reject
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Field selection functions
        function selectAllFields() {
            const checkboxes = document.querySelectorAll('.field-checkbox');
            checkboxes.forEach(cb => cb.checked = true);
            updateSelectedFieldsSummary();
        }
        
        function selectEssentialFields() {
            const checkboxes = document.querySelectorAll('.field-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            
            // Essential fields
            const essentialFields = ['title', 'description', 'price', 'images', 'bedrooms', 'bathrooms', 'built_up_area'];
            checkboxes.forEach(cb => {
                if (essentialFields.includes(cb.value)) {
                    cb.checked = true;
                }
            });
            updateSelectedFieldsSummary();
        }
        
        function selectPriceOnly() {
            const checkboxes = document.querySelectorAll('.field-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            
            const priceFields = ['price', 'price_type', 'maintenance_charges', 'deposit'];
            checkboxes.forEach(cb => {
                if (priceFields.includes(cb.value)) {
                    cb.checked = true;
                }
            });
            updateSelectedFieldsSummary();
        }
        
        function selectImagesOnly() {
            const checkboxes = document.querySelectorAll('.field-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            
            const mediaFields = ['images', 'video_url'];
            checkboxes.forEach(cb => {
                if (mediaFields.includes(cb.value)) {
                    cb.checked = true;
                }
            });
            updateSelectedFieldsSummary();
        }
        
        function deselectAllFields() {
            const checkboxes = document.querySelectorAll('.field-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            updateSelectedFieldsSummary();
        }
        
        function updateSelectedFieldsSummary() {
            const selectedFields = Array.from(document.querySelectorAll('.field-checkbox:checked'))
                .map(cb => {
                    const label = cb.parentElement.querySelector('span').textContent;
                    return label;
                });
            
            const summaryElement = document.getElementById('selectedFieldsSummary');
            if (selectedFields.length > 0) {
                summaryElement.innerHTML = `
                    <div class="flex flex-wrap gap-1">
                        ${selectedFields.map(field => `<span class="px-2 py-1 bg-blue-100 text-blue-800 rounded text-xs">${field}</span>`).join('')}
                    </div>
                    <div class="mt-1 text-xs">
                        Total: ${selectedFields.length} field(s) selected
                    </div>
                `;
            } else {
                summaryElement.textContent = 'No fields selected yet. Select fields from above.';
            }
        }
        
        // Duration functions
        function selectDuration(hours) {
            const options = document.querySelectorAll('.duration-option');
            options.forEach(opt => opt.classList.remove('selected'));
            event.currentTarget.classList.add('selected');
            document.getElementById('selectedDuration').value = hours;
            updateDurationSummary();
        }
        
        function setCustomDuration() {
            const customInput = document.getElementById('customDuration');
            const hours = parseInt(customInput.value);
            
            if (hours >= 1 && hours <= 720) {
                const options = document.querySelectorAll('.duration-option');
                options.forEach(opt => opt.classList.remove('selected'));
                document.getElementById('selectedDuration').value = hours;
                updateDurationSummary();
                
                // Show success feedback
                customInput.classList.remove('border-red-300');
                customInput.classList.add('border-green-300');
                setTimeout(() => {
                    customInput.classList.remove('border-green-300');
                }, 1000);
            } else {
                customInput.classList.add('border-red-300');
            }
        }
        
        function updateDurationSummary() {
            const hours = parseInt(document.getElementById('selectedDuration').value);
            const days = Math.round((hours / 24) * 10) / 10;
            const summary = `${hours} hours (${days} days)`;
            document.getElementById('durationSummary').textContent = summary;
        }
        
        // Initialize field listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Update summary when fields change
            const checkboxes = document.querySelectorAll('.field-checkbox');
            checkboxes.forEach(cb => {
                cb.addEventListener('change', updateSelectedFieldsSummary);
            });
            
            // Initialize duration summary
            updateDurationSummary();
            updateSelectedFieldsSummary();
        });
        
        // Modal functions
        function showRequestChangesModal() {
            document.getElementById('requestChangesModal').classList.remove('hidden');
        }
        
        function closeRequestChangesModal() {
            document.getElementById('requestChangesModal').classList.add('hidden');
            document.getElementById('changesReason').value = '';
        }
        
        function showRejectModal() {
            document.getElementById('rejectModal').classList.remove('hidden');
        }
        
        function closeRejectModal() {
            document.getElementById('rejectModal').classList.add('hidden');
            document.getElementById('rejectReason').value = '';
        }
        
        // Enhanced Request Changes with Limited Access
        function confirmRequestChangesWithLimitedAccess() {
            const reason = document.getElementById('changesReason').value.trim();
            if (!reason || reason.length < 10) {
                alert('Please provide detailed instructions (at least 10 characters).');
                return;
            }
            
            // Get selected fields
            const selectedFields = Array.from(document.querySelectorAll('.field-checkbox:checked'))
                .map(cb => cb.value);
            
            if (selectedFields.length === 0) {
                alert('Please select at least one field that the seller can edit.');
                return;
            }
            
            const durationHours = parseInt(document.getElementById('selectedDuration').value);
            
            // Confirm with admin
            if (confirm(`You are allowing the seller to edit ${selectedFields.length} field(s) for ${durationHours} hours. Continue?`)) {
                showLoading('Sending request with limited edit access...');
                
                fetch(`/admin/api/properties/<%= property._id %>/request-changes-limited`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ 
                        reason: reason,
                        allowed_fields: selectedFields,
                        duration_hours: durationHours,
                        allowEdit: true 
                    })
                })
                .then(response => response.json())
                .then(data => {
                    hideLoading();
                    if (data.success) {
                        alert('Property sent back to seller with limited edit access!');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    hideLoading();
                    alert('Failed to request changes.');
                });
            }
        }
        
        // Original confirmRequestChanges (for backward compatibility)
        function confirmRequestChanges() {
            const reason = document.getElementById('changesReason').value.trim();
            if (!reason || reason.length < 10) {
                alert('Please provide detailed instructions (at least 10 characters).');
                return;
            }
            
            fetch(`/admin/api/properties/<%= property._id %>/request-changes`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    reason: reason,
                    allowEdit: true 
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Property sent back to seller for changes!');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                alert('Failed to request changes.');
            });
        }
        
        function confirmReject() {
            const reason = document.getElementById('rejectReason').value.trim();
            if (!reason || reason.length < 10) {
                alert('Please provide a proper reason (at least 10 characters).');
                return;
            }
            
            fetch(`/admin/api/properties/<%= property._id %>/reject`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ 
                    reason: reason,
                    allowEdit: false 
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Property rejected permanently!');
                    location.reload();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                alert('Failed to reject property.');
            });
        }
        
        // Loading function
        function showLoading(message = 'Processing...') {
            const loading = document.createElement('div');
            loading.id = 'loading-overlay';
            loading.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
            loading.innerHTML = `
                <div class="bg-white p-6 rounded-lg shadow-xl text-center">
                    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
                    <p class="text-gray-700">${message}</p>
                </div>
            `;
            document.body.appendChild(loading);
        }
        
        function hideLoading() {
            const loading = document.getElementById('loading-overlay');
            if (loading) loading.remove();
        }
        
        // Other existing functions (approveProperty, makeLive, etc.)
        function approveProperty() {
            if (confirm('Are you sure you want to approve this property?')) {
                fetch(`/admin/api/properties/<%= property._id %>/approve`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ autoGoLive: true })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Property approved successfully!');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Failed to approve property.');
                });
            }
        }
        
        function makeLive() {
            if (confirm('Make this property live and visible to all users?')) {
                fetch(`/admin/api/properties/<%= property._id %>/make-live`, {
                    method: 'POST'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Property is now live!');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Failed to make property live.');
                });
            }
        }
        
        function suspendProperty() {
            const reason = prompt('Enter reason for suspension (minimum 10 characters):');
            if (reason && reason.length >= 10) {
                fetch(`/admin/api/properties/<%= property._id %>/suspend`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ reason: reason })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Property suspended successfully!');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Failed to suspend property.');
                });
            } else if (reason !== null) {
                alert('Reason must be at least 10 characters.');
            }
        }
        
        function unsuspendProperty() {
            if (confirm('Unsuspend this property?')) {
                fetch(`/admin/api/properties/<%= property._id %>/unsuspend`, {
                    method: 'POST'
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Property unsuspended successfully!');
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Failed to unsuspend property.');
                });
            }
        }
       
        document.addEventListener("DOMContentLoaded", () => {
    const autoId = "<%= typeof autoAssignPropertyId !== 'undefined' ? autoAssignPropertyId : '' %>";

    if (autoId && autoId !== "null") {
        console.log("Auto Assign Modal for Property:", autoId);
    }
});



        function showRequestDocumentsModal() {
            const specificDocuments = prompt('Which specific documents are required?\n\nExample:\n• Ownership Deed\n• Tax Receipts 2024\n• Aadhaar Card\n• Electricity Bill\n• NOC Certificate');
            
            if (specificDocuments && specificDocuments.trim().length >= 10) {
                fetch(`/admin/api/properties/<%= property._id %>/request-documents`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ 
                        required_documents: specificDocuments,
                        message: 'Please upload the following documents for property verification.' 
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert('Document request sent to seller!');
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    alert('Failed to send document request.');
                });
            } else if (specificDocuments !== null) {
                alert('Please specify at least 10 characters.');
            }
        }

        // Close modals when clicking outside
        document.addEventListener('DOMContentLoaded', function() {
            const modals = ['requestChangesModal', 'rejectModal'];
            
            modals.forEach(modalId => {
                const modal = document.getElementById(modalId);
                if (modal) {
                    modal.addEventListener('click', function(e) {
                        if (e.target === modal) {
                            if (modalId === 'requestChangesModal') closeRequestChangesModal();
                            if (modalId === 'rejectModal') closeRejectModal();
                        }
                    });
                }
            });

            // Escape key to close modals
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    if (!document.getElementById('requestChangesModal').classList.contains('hidden')) {
                        closeRequestChangesModal();
                    }
                    if (!document.getElementById('rejectModal').classList.contains('hidden')) {
                        closeRejectModal();
                    }
                }
            });
        });
    </script>
</body>
</html>