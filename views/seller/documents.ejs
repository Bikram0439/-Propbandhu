<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/sellerdashboard.css">
    <style>
        /* Additional styles for document icons */
        .document-icon {
            font-size: 1.5rem;
            margin-right: 0.75rem;
        }
        
        .pdf-icon { color: #ef4444; }
        .doc-icon { color: #2563eb; }
        .image-icon { color: #10b981; }
        .file-icon { color: #6b7280; }
        
        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.025em;
        }
        
        .status-draft { background-color: #f3f4f6; color: #6b7280; }
        .status-pending_approval { background-color: #fef3c7; color: #92400e; }
        .status-approved { background-color: #d1fae5; color: #065f46; }
        .status-live { background-color: #dbeafe; color: #1e40af; }
        .status-changes_requested { background-color: #fee2e2; color: #991b1b; }
        .status-sold { background-color: #ede9fe; color: #5b21b6; }
        
        .action-btn {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            font-weight: 500;
            font-size: 0.875rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        
        .view-btn {
            background-color: #3b82f6;
            color: white;
        }
        
        .view-btn:hover {
            background-color: #2563eb;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
        }
        
        .delete-btn {
            background-color: #ef4444;
            color: white;
        }
        
        .delete-btn:hover {
            background-color: #dc2626;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px -1px rgba(239, 68, 68, 0.3);
        }
        
        .primary-action {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 0.75rem;
            font-weight: 600;
            transition: all 0.3s ease;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        
        .primary-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(102, 126, 234, 0.4);
        }
        
        .primary-action:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        
        .upload-area {
            border: 2px dashed #cbd5e0;
            border-radius: 0.75rem;
            padding: 2rem;
            text-align: center;
            background: #f8fafc;
            transition: all 0.3s ease;
        }
        
        .upload-area:hover {
            border-color: #3b82f6;
            background: #eff6ff;
        }
        
        .file-size {
            color: #6b7280;
            font-size: 0.75rem;
        }
        
        .document-card {
            transition: all 0.2s ease;
            border: 1px solid #e5e7eb;
            border-radius: 0.5rem;
            background: white;
        }
        
        .document-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        
        .nav-link {
            color: #4b5563;
            font-weight: 500;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
        }
        
        .nav-link:hover {
            color: #1f2937;
            background-color: #f3f4f6;
        }
        
        .nav-link.active {
            color: #3b82f6;
            background-color: #eff6ff;
        }
        
        .logout-btn {
            color: #ef4444;
            font-weight: 500;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
        }
        
        .logout-btn:hover {
            background-color: #fef2f2;
        }
        
        /* Notification styles */
        .custom-notification {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1000;
            padding: 16px 24px;
            border-radius: 12px;
            color: white;
            font-weight: 500;
            transform: translateX(100%);
            transition: transform 0.3s ease;
            max-width: 400px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        .custom-notification.success {
            background: #10b981;
        }
        
        .custom-notification.error {
            background: #ef4444;
        }
        
        .custom-notification.info {
            background: #3b82f6;
        }
    </style>
</head>
<body class="bg-gray-50 font-sans">
    <!-- Top Navigation -->
    <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <div class="flex items-center">
                    <a href="/" class="flex items-center space-x-3 no-underline">
                        <div class="w-10 h-10 bg-gradient-to-br from-purple-600 to-blue-500 rounded-xl flex items-center justify-center">
                            <i class="fas fa-home text-white text-xl"></i>
                        </div>
                        <span class="text-2xl font-bold text-gray-900">Propbandhu</span>
                    </a>
                </div>
                <div class="flex items-center space-x-6">
                    <div class="flex items-center space-x-4 bg-gray-100 px-4 py-2 rounded-xl">
                        <div class="w-8 h-8 bg-gradient-to-br from-green-500 to-teal-400 rounded-full flex items-center justify-center text-white font-bold">
                            <%= user.name.charAt(0).toUpperCase() %>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-gray-700">🏠 Seller</p>
                            <p class="text-xs text-gray-600"><%= user.name %></p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-4">
                        <a href="/seller/dashboard" class="nav-link">
                            <i class="fas fa-tachometer-alt mr-2"></i>Dashboard
                        </a>
                        <a href="/seller/properties/add" class="nav-link">
                            <i class="fas fa-plus-circle mr-2"></i>Add Property
                        </a>
                        <a href="/seller/analytics" class="nav-link">
                            <i class="fas fa-chart-line mr-2"></i>Analytics
                        </a>
                        <a href="/seller/documents" class="nav-link active">
                            <i class="fas fa-file-alt mr-2"></i>Documents
                        </a>
                        <a href="/logout" class="logout-btn">
                            <i class="fas fa-sign-out-alt mr-2"></i>Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
        <div class="bg-white rounded-2xl shadow-xl p-6 mb-8">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">Property Documents</h1>
                    <p class="text-gray-600 mt-2">Upload and manage documents for your properties (PDF, DOC, DOCX, JPG, PNG up to 10MB)</p>
                </div>
            </div>

            <% if (!properties || properties.length === 0) { %>
                <div class="empty-state text-center py-12">
                    <i class="fas fa-file-upload text-gray-300 text-6xl mb-4"></i>
                    <h3 class="text-xl font-semibold text-gray-700 mb-2">No properties found</h3>
                    <p class="text-gray-600 mb-6">Add properties first to upload documents</p>
                    <a href="/seller/properties/add" class="primary-action inline-flex">
                        <i class="fas fa-plus mr-2"></i>Add Property
                    </a>
                </div>
            <% } else { %>
                <div class="space-y-6">
                    <% properties.forEach(property => { %>
                    <div class="border border-gray-200 rounded-xl p-6 document-card">
                        <div class="flex justify-between items-center mb-4">
                            <div>
                                <h3 class="font-bold text-xl text-gray-900"><%= property.title %></h3>
                                <p class="text-gray-600 text-sm"><%= property.location || 'No location specified' %></p>
                            </div>
                            <span class="status-badge status-<%= property.status || 'draft' %>">
                                <%= property.status || 'draft' %>
                            </span>
                        </div>
                        
                        <!-- Upload Document Form -->
                        <form id="uploadForm-<%= property._id %>" 
                              class="mb-6" 
                              enctype="multipart/form-data"
                              onsubmit="uploadDocument(event, '<%= property._id %>')">
                            <div class="flex flex-col md:flex-row gap-3">
                                <input type="text" 
                                       name="name" 
                                       placeholder="Document name (e.g., 'Tax Receipt 2024')" 
                                       class="flex-1 px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                       required>
                                <select name="type" 
                                        class="px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white">
                                    <option value="">Select document type</option>
                                    <option value="ownership">Ownership Proof</option>
                                    <option value="tax">Tax Receipts</option>
                                    <option value="approval">Approval Documents</option>
                                    <option value="floor_plan">Floor Plan</option>
                                    <option value="legal">Legal Documents</option>
                                    <option value="other">Other</option>
                                </select>
                                <div class="flex-1">
                                    <input type="file" 
                                           name="document" 
                                           id="file-<%= property._id %>"
                                           accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"
                                           class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                           required
                                           onchange="updateFileName('<%= property._id %>')">
                                    <div id="file-name-<%= property._id %>" class="text-sm text-gray-500 mt-1"></div>
                                </div>
                                <button type="submit" 
                                        class="primary-action px-6 whitespace-nowrap">
                                    <i class="fas fa-upload mr-2"></i>Upload
                                </button>
                            </div>
                        </form>

                        <!-- Documents List -->
                        <% if (property.documents && property.documents.length > 0) { %>
                        <div class="bg-gray-50 rounded-xl p-4">
                            <div class="flex justify-between items-center mb-3">
                                <h4 class="font-bold text-gray-700">Uploaded Documents</h4>
                                <span class="text-sm text-gray-500"><%= property.documents.length %> document(s)</span>
                            </div>
                            <div class="space-y-3">
                                <% property.documents.forEach((doc, index) => { 
                                    // Determine icon based on file type
                                    let iconClass = 'fas fa-file';
                                    let iconColor = 'file-icon';
                                    let fileType = doc.type || 'other';
                                    
                                    if (fileType.includes('pdf') || (doc.original_name && doc.original_name.endsWith('.pdf'))) {
                                        iconClass = 'fas fa-file-pdf';
                                        iconColor = 'pdf-icon';
                                    } else if (fileType.includes('word') || fileType.includes('doc') || 
                                               (doc.original_name && (doc.original_name.endsWith('.doc') || doc.original_name.endsWith('.docx')))) {
                                        iconClass = 'fas fa-file-word';
                                        iconColor = 'doc-icon';
                                    } else if (fileType.includes('image') || 
                                               (doc.original_name && (doc.original_name.endsWith('.jpg') || doc.original_name.endsWith('.jpeg') || 
                                               doc.original_name.endsWith('.png')))) {
                                        iconClass = 'fas fa-file-image';
                                        iconColor = 'image-icon';
                                    }
                                    
                                    // Format file size
                                    let fileSize = '';
                                    if (doc.size) {
                                        if (doc.size < 1024) {
                                            fileSize = doc.size + ' B';
                                        } else if (doc.size < 1024 * 1024) {
                                            fileSize = Math.round(doc.size / 1024) + ' KB';
                                        } else {
                                            fileSize = (doc.size / (1024 * 1024)).toFixed(2) + ' MB';
                                        }
                                    }
                                %>
                                <div class="flex items-center justify-between p-3 bg-white rounded-lg border border-gray-200 hover:border-blue-300 transition-colors">
                                    <div class="flex items-center flex-1 min-w-0">
                                        <i class="<%= iconClass %> <%= iconColor %> document-icon"></i>
                                        <div class="flex-1 min-w-0">
                                            <!-- UPDATED: Document name is now a link to the document viewer -->
                                            <p class="font-medium text-gray-900 truncate">
                                                <a href="/seller/documents/view/<%= property._id %>/<%= index %>" 
                                                   class="text-blue-600 hover:text-blue-900 hover:underline truncate block">
                                                    <%= doc.name %>
                                                </a>
                                            </p>
                                            <div class="flex items-center space-x-3 text-sm text-gray-600">
                                                <span class="truncate"><%= doc.original_name || 'Document' %></span>
                                                <% if (fileSize) { %>
                                                <span class="file-size">• <%= fileSize %></span>
                                                <% } %>
                                                <span class="file-size">• <%= new Date(doc.uploaded_at).toLocaleDateString('en-US', { 
                                                    year: 'numeric', 
                                                    month: 'short', 
                                                    day: 'numeric' 
                                                }) %></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex space-x-2 ml-4 flex-shrink-0">
                                        <!-- View button opens in document viewer -->
                                        <a href="/seller/documents/view/<%= property._id %>/<%= index %>" 
                                           class="action-btn view-btn"
                                           title="View Document Details">
                                            <i class="fas fa-eye mr-2"></i>View
                                        </a>
                                        <!-- Direct download link -->
                                        <a href="<%= doc.url %>" 
                                           target="_blank" 
                                           download="<%= doc.original_name || doc.name %>"
                                           class="action-btn view-btn"
                                           title="Download Document">
                                            <i class="fas fa-download mr-2"></i>Download
                                        </a>
                                        <button onclick="deleteDocument('<%= property._id %>', '<%= index %>')" 
                                                class="action-btn delete-btn"
                                                title="Delete Document">
                                            <i class="fas fa-trash mr-2"></i>Delete
                                        </button>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                        </div>
                        <% } else { %>
                        <div class="bg-gray-50 rounded-xl p-8 text-center upload-area">
                            <i class="fas fa-file-upload text-gray-300 text-4xl mb-3"></i>
                            <p class="text-gray-600 font-medium mb-2">No documents uploaded yet</p>
                            <p class="text-sm text-gray-500">Upload documents to make your property listing more credible</p>
                        </div>
                        <% } %>
                    </div>
                    <% }); %>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        // Show selected file name
        function updateFileName(propertyId) {
            const fileInput = document.getElementById(`file-${propertyId}`);
            const fileNameDisplay = document.getElementById(`file-name-${propertyId}`);
            
            if (fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const fileSize = file.size < 1024 * 1024 
                    ? Math.round(file.size / 1024) + ' KB' 
                    : (file.size / (1024 * 1024)).toFixed(2) + ' MB';
                
                fileNameDisplay.innerHTML = `
                    <i class="fas fa-file text-blue-500 mr-1"></i>
                    ${file.name} (${fileSize})
                `;
            } else {
                fileNameDisplay.innerHTML = '';
            }
        }
        
        // Upload document
        async function uploadDocument(event, propertyId) {
            event.preventDefault();
            
            const form = event.target;
            const formData = new FormData(form);
            
            const submitBtn = form.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerHTML;
            const originalState = submitBtn.disabled;
            
            // Show loading state
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Uploading...';
            submitBtn.disabled = true;
            
            try {
                const response = await fetch(`/seller/api/properties/${propertyId}/documents/upload`, {
                    method: 'POST',
                    body: formData
                    // Don't set Content-Type header for FormData - browser sets it automatically
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Show success message
                    showNotification('Document uploaded successfully!', 'success');
                    // Reload after a short delay to see the message
                    setTimeout(() => {
                        window.location.reload();
                    }, 1500);
                } else {
                    showNotification('Error: ' + data.message, 'error');
                }
            } catch (error) {
                console.error('Upload error:', error);
                showNotification('Failed to upload document. Please check your connection and try again.', 'error');
            } finally {
                // Reset button state
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = originalState;
            }
        }
        
        // Delete document
        async function deleteDocument(propertyId, docIndex) {
            if (!confirm('Are you sure you want to delete this document?\nThis action cannot be undone.')) {
                return;
            }
            
            try {
                const response = await fetch(`/seller/api/properties/${propertyId}/documents/${docIndex}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    showNotification('Document deleted successfully!', 'success');
                    // Reload after a short delay
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    showNotification('Error: ' + data.message, 'error');
                }
            } catch (error) {
                console.error('Delete error:', error);
                showNotification('Failed to delete document. Please try again.', 'error');
            }
        }
        
        // Notification function
        function showNotification(message, type = 'info') {
            // Remove existing notifications
            const existingNotifications = document.querySelectorAll('.custom-notification');
            existingNotifications.forEach(notification => notification.remove());
            
            // Create notification element
            const notification = document.createElement('div');
            notification.className = `custom-notification ${type}`;
            
            // Add icon
            let icon = 'fas fa-info-circle';
            if (type === 'success') icon = 'fas fa-check-circle';
            if (type === 'error') icon = 'fas fa-exclamation-circle';
            
            notification.innerHTML = `
                <div class="flex items-center justify-between">
                    <div class="flex items-center">
                        <i class="${icon} mr-3"></i>
                        <span>${message}</span>
                    </div>
                    <button onclick="this.parentElement.parentElement.remove()" class="ml-4 text-white hover:text-gray-200">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
            `;
            
            // Add to DOM
            document.body.appendChild(notification);
            
            // Animate in
            requestAnimationFrame(() => {
                notification.style.transform = 'translateX(0)';
            });
            
            // Auto remove after 5 seconds
            setTimeout(() => {
                notification.style.transform = 'translateX(100%)';
                setTimeout(() => {
                    if (notification.parentNode) {
                        notification.parentNode.removeChild(notification);
                    }
                }, 300);
            }, 5000);
            
            // Click to dismiss
            notification.addEventListener('click', (e) => {
                if (e.target.tagName !== 'BUTTON' && !e.target.closest('button')) {
                    notification.style.transform = 'translateX(100%)';
                    setTimeout(() => {
                        if (notification.parentNode) {
                            notification.parentNode.removeChild(notification);
                        }
                    }, 300);
                }
            });
        }
        
        // Initialize file name displays
        document.addEventListener('DOMContentLoaded', function() {
            <% if (properties) { %>
                <% properties.forEach(property => { %>
                    const fileInput<%= property._id %> = document.getElementById('file-<%= property._id %>');
                    if (fileInput<%= property._id %>) {
                        fileInput<%= property._id %>.addEventListener('change', () => updateFileName('<%= property._id %>'));
                    }
                <% }); %>
            <% } %>
        });
    </script>
</body>
</html>