<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/seller/dashboard" class="flex items-center">
                        <span class="text-xl font-bold text-blue-600">Propbandhu</span>
                        <span class="text-gray-600 ml-2">Browse Properties</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/seller/dashboard" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-arrow-left mr-1"></i>Back to Dashboard
                    </a>
                    <a href="/seller/properties" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-building mr-1"></i>My Properties
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Debug Info (remove in production) -->
    <% if (properties.length === 0) { %>
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mb-4">
        <div class="flex">
            <div class="flex-shrink-0">
                <i class="fas fa-info-circle text-yellow-400"></i>
            </div>
            <div class="ml-3">
                <p class="text-sm text-yellow-700">
                    No properties found. There might be no other sellers' properties available, 
                    or your filters are too strict.
                </p>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Browse Properties</h1>
            <p class="text-gray-600 mt-2">Discover amazing properties from other sellers</p>
        </div>

        <!-- Filters -->
        <div class="bg-white rounded-xl shadow p-6 mb-8">
            <form method="GET" action="/seller/browse" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <!-- Property Type -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Property Type</label>
                    <select name="property_type" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                        <option value="all">All Types</option>
                        <% propertyTypes.forEach(type => { %>
                            <option value="<%= type %>" <%= query.property_type === type ? 'selected' : '' %>>
                                <%= type %>
                            </option>
                        <% }); %>
                    </select>
                </div>

                <!-- Location -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Location</label>
                    <input type="text" name="location" value="<%= query.location || '' %>" 
                           placeholder="City or Area" 
                           class="w-full border border-gray-300 rounded-lg px-3 py-2">
                </div>

                <!-- Bedrooms -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Bedrooms</label>
                    <select name="bedrooms" class="w-full border border-gray-300 rounded-lg px-3 py-2">
                        <option value="all">Any</option>
                        <option value="1" <%= query.bedrooms === '1' ? 'selected' : '' %>>1 BHK</option>
                        <option value="2" <%= query.bedrooms === '2' ? 'selected' : '' %>>2 BHK</option>
                        <option value="3" <%= query.bedrooms === '3' ? 'selected' : '' %>>3 BHK</option>
                        <option value="4" <%= query.bedrooms === '4' ? 'selected' : '' %>>4+ BHK</option>
                    </select>
                </div>

                <!-- Price Range -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Price Range</label>
                    <div class="flex space-x-2">
                        <input type="number" name="min_price" value="<%= query.min_price || '' %>" 
                               placeholder="Min" 
                               class="w-1/2 border border-gray-300 rounded-lg px-3 py-2">
                        <input type="number" name="max_price" value="<%= query.max_price || '' %>" 
                               placeholder="Max" 
                               class="w-1/2 border border-gray-300 rounded-lg px-3 py-2">
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="md:col-span-4 flex justify-end space-x-3 mt-4">
                    <button type="submit" 
                            class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 flex items-center">
                        <i class="fas fa-filter mr-2"></i>Apply Filters
                    </button>
                    <a href="/seller/browse" 
                       class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400 flex items-center">
                        <i class="fas fa-times mr-2"></i>Clear Filters
                    </a>
                </div>
            </form>
        </div>

        <!-- Properties Grid -->
        <% if (properties.length > 0) { %>
            <div class="mb-4">
                <p class="text-gray-600">
                    Showing <%= properties.length %> of <%= total %> properties from other sellers
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% properties.forEach(property => { %>
                    <div class="bg-white rounded-xl shadow overflow-hidden hover:shadow-lg transition-shadow duration-300">
                        <!-- Property Image -->
                        <div class="relative h-48 overflow-hidden">
                            <img src="<%= property.primary_image %>" 
                                 alt="<%= property.title %>" 
                                 class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
                            
                            <!-- Verified Badge -->
                            <% if (property.is_verified) { %>
                                <div class="absolute top-3 left-3 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded">
                                    <i class="fas fa-check-circle mr-1"></i>Verified
                                </div>
                            <% } %>
                        </div>

                        <!-- Property Details -->
                        <div class="p-4">
                            <h3 class="text-lg font-bold text-gray-900 mb-2 truncate">
                                <%= property.title %>
                            </h3>
                            
                            <p class="text-gray-600 text-sm mb-3 flex items-center">
                                <i class="fas fa-map-marker-alt text-gray-400 mr-2"></i>
                                <%= property.location_text %>
                            </p>
                            
                            <div class="flex items-center justify-between mb-4">
                                <div>
                                    <span class="text-2xl font-bold text-blue-600">
                                        <%= property.formatted_price %>
                                    </span>
                                </div>
                                <div class="text-right">
                                    <span class="text-sm text-gray-500">
                                        <%= property.property_type %>
                                    </span>
                                </div>
                            </div>
                            
                            <!-- Property Features -->
                            <div class="flex items-center justify-between text-sm text-gray-600 border-t border-gray-100 pt-4">
                                <div class="flex items-center">
                                    <i class="fas fa-bed text-gray-400 mr-1"></i>
                                    <span><%= property.bedrooms || 'NA' %> Beds</span>
                                </div>
                                <div class="flex items-center">
                                    <i class="fas fa-bath text-gray-400 mr-1"></i>
                                    <span><%= property.bathrooms || 'NA' %> Baths</span>
                                </div>
                                <div class="flex items-center">
                                    <i class="fas fa-vector-square text-gray-400 mr-1"></i>
                                    <span><%= property.built_up_area || 'NA' %> <%= property.area_unit || 'sq ft' %></span>
                                </div>
                            </div>
                            
                            <!-- Seller Info -->
                            <div class="flex items-center justify-between mt-4 pt-4 border-t border-gray-100">
                                <div class="flex items-center">
                                    <% if (property.seller?.profile_pic) { %>
                                        <img src="<%= property.seller.profile_pic %>" 
                                             alt="<%= property.seller.name %>" 
                                             class="w-8 h-8 rounded-full mr-2">
                                    <% } else { %>
                                        <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center mr-2">
                                            <i class="fas fa-user text-blue-600"></i>
                                        </div>
                                    <% } %>
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">
                                            <%= property.seller?.name || 'Seller' %>
                                        </p>
                                        <% if (property.seller?.company_name) { %>
                                            <p class="text-xs text-gray-500">
                                                <%= property.seller.company_name %>
                                            </p>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <!-- View Details Button -->
                                <a href="/seller/properties/<%= property._id %>?view=public" 
                                   class="bg-blue-600 text-white text-sm px-3 py-1 rounded hover:bg-blue-700 flex items-center">
                                    <i class="fas fa-eye mr-1"></i>View
                                </a>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="flex justify-center mt-8">
                    <div class="flex items-center space-x-2">
                        <% if (currentPage > 1) { %>
                            <a href="/seller/browse?page=<%= currentPage - 1 %>" 
                               class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                                <i class="fas fa-chevron-left mr-1"></i>Previous
                            </a>
                        <% } %>
                        
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <% if (i === currentPage) { %>
                                <span class="px-4 py-2 bg-blue-600 text-white rounded-lg">
                                    <%= i %>
                                </span>
                            <% } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
                                <a href="/seller/browse?page=<%= i %>" 
                                   class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                                    <%= i %>
                                </a>
                            <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
                                <span class="px-4 py-2">...</span>
                            <% } %>
                        <% } %>
                        
                        <% if (currentPage < totalPages) { %>
                            <a href="/seller/browse?page=<%= currentPage + 1 %>" 
                               class="px-4 py-2 border border-gray-300 rounded-lg hover:bg-gray-50">
                                Next<i class="fas fa-chevron-right ml-1"></i>
                            </a>
                        <% } %>
                    </div>
                </div>
            <% } %>
        <% } else { %>
            <!-- No Properties Found -->
            <div class="text-center py-12">
                <i class="fas fa-home text-gray-300 text-6xl mb-4"></i>
                <h3 class="text-xl font-medium text-gray-900 mb-2">No Properties Found</h3>
                <p class="text-gray-600 mb-6">Try adjusting your filters or check back later for new listings.</p>
                <div class="space-x-4">
                    <a href="/seller/browse" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
                        <i class="fas fa-redo mr-2"></i>Reset Filters
                    </a>
                    <a href="/seller/dashboard" class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400">
                        <i class="fas fa-arrow-left mr-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        <% } %>
    </div>

    <script>
        // Auto-submit when select values change
        document.addEventListener('DOMContentLoaded', function() {
            const selects = document.querySelectorAll('select');
            selects.forEach(select => {
                select.addEventListener('change', function() {
                    this.form.submit();
                });
            });
        });
    </script>
</body>
</html>