<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .status-badge {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .draft { background-color: #f3f4f6; color: #374151; border: 1px solid #d1d5db; }
        .pending_approval { background-color: #fef3c7; color: #92400e; border: 1px solid #fbbf24; }
        .changes_requested { background-color: #fef3c7; color: #92400e; border: 1px dashed #f59e0b; }
        .approved { background-color: #d1fae5; color: #065f46; border: 1px solid #10b981; }
        .live { background-color: #10b981; color: white; border: 1px solid #10b981; }
        .rejected { background-color: #fee2e2; color: #991b1b; border: 1px solid #ef4444; }
        
        .property-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
        }
        
        .action-btn {
            padding: 6px 12px;
            font-size: 12px;
            border-radius: 6px;
            transition: all 0.2s ease;
        }
        
        .action-btn:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/" class="flex items-center">
                        <span class="text-xl font-bold text-gray-900">Propbandhu</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <a href="/seller/dashboard" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-home mr-1"></i>Dashboard
                    </a>
                    <a href="/seller/properties" class="text-blue-600 font-medium">
                        <i class="fas fa-building mr-1"></i>Properties
                    </a>
                    <a href="/seller/analytics" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-chart-line mr-1"></i>Analytics
                    </a>
                    <a href="/seller/properties/add" class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600">
                        <i class="fas fa-plus mr-1"></i>Add Property
                    </a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600">
                        <i class="fas fa-sign-out-alt mr-1"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">My Properties</h1>
            <p class="text-gray-600">Manage all your listed properties</p>
        </div>

        <!-- Stats Overview -->
        <div class="grid grid-cols-2 md:grid-cols-6 gap-4 mb-6">
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <div class="text-2xl font-bold text-blue-600"><%= properties.length %></div>
                <p class="text-sm text-gray-600 mt-1">Total</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <div class="text-2xl font-bold text-green-600"><%= properties.filter(p => p.status === 'live').length %></div>
                <p class="text-sm text-gray-600 mt-1">Live</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <div class="text-2xl font-bold text-yellow-600"><%= properties.filter(p => p.status === 'pending_approval').length %></div>
                <p class="text-sm text-gray-600 mt-1">Pending</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <div class="text-2xl font-bold text-orange-500"><%= properties.filter(p => p.status === 'changes_requested').length %></div>
                <p class="text-sm text-gray-600 mt-1">Changes Needed</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <div class="text-2xl font-bold text-red-600"><%= properties.filter(p => p.status === 'rejected').length %></div>
                <p class="text-sm text-gray-600 mt-1">Rejected</p>
            </div>
            <div class="bg-white rounded-lg shadow p-4 text-center">
                <div class="text-2xl font-bold text-purple-600"><%= properties.filter(p => p.cart_status?.in_cart).length %></div>
                <p class="text-sm text-gray-600 mt-1">In Cart</p>
            </div>
        </div>

        <!-- Filters and Actions -->
        <div class="bg-white rounded-xl shadow mb-6 p-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between space-y-4 md:space-y-0">
                <div class="flex items-center space-x-4">
                    <button onclick="filterProperties('all')" class="px-4 py-2 rounded-lg bg-blue-100 text-blue-700 font-medium">
                        All (<%= properties.length %>)
                    </button>
                    <button onclick="filterProperties('live')" class="px-4 py-2 rounded-lg border text-gray-700 hover:bg-gray-50">
                        Live (<%= properties.filter(p => p.status === 'live').length %>)
                    </button>
                    <button onclick="filterProperties('pending')" class="px-4 py-2 rounded-lg border text-gray-700 hover:bg-gray-50">
                        Pending (<%= properties.filter(p => p.status === 'pending_approval').length %>)
                    </button>
                    <button onclick="filterProperties('changes_requested')" class="px-4 py-2 rounded-lg border text-gray-700 hover:bg-gray-50">
                        Changes Needed (<%= properties.filter(p => p.status === 'changes_requested').length %>)
                    </button>
                </div>
                <div>
                    <a href="/seller/add-property" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 flex items-center">
                        <i class="fas fa-plus mr-2"></i> Add New Property
                    </a>
                </div>
            </div>
        </div>

        <!-- Properties Grid -->
        <% if (properties.length === 0) { %>
        <div class="text-center py-12 bg-white rounded-xl shadow">
            <i class="fas fa-building text-gray-300 text-6xl mb-4"></i>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">No Properties Yet</h3>
            <p class="text-gray-600 mb-6">Start by adding your first property to get listed</p>
            <a href="/seller/add-property" class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 inline-flex items-center">
                <i class="fas fa-plus mr-2"></i> Add Your First Property
            </a>
        </div>
        <% } else { %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="properties-grid">
            <% properties.forEach(property => { %>
            <div class="property-card bg-white rounded-xl shadow overflow-hidden border border-gray-200">
                <!-- Property Image -->
                <div class="h-48 bg-gray-200 relative overflow-hidden">
                    <% if (property.images && property.images.length > 0) { 
                        const primaryImage = property.images.find(img => img.is_primary) || property.images[0];
                    %>
                        <img src="<%= primaryImage.url %>" alt="<%= property.title %>" 
                             class="w-full h-full object-cover hover:scale-105 transition-transform duration-300">
                    <% } else { %>
                        <div class="w-full h-full flex items-center justify-center bg-gray-100">
                            <i class="fas fa-home text-gray-400 text-4xl"></i>
                        </div>
                    <% } %>
                    
                    <!-- Status Badge -->
                    <div class="absolute top-3 left-3">
                        <span class="status-badge <%= property.status %>">
                            <%= property.status.replace('_', ' ') %>
                        </span>
                    </div>
                    
                    <!-- Cart Lock Badge -->
                    <% if (property.cart_status?.in_cart) { %>
                    <div class="absolute top-3 right-3">
                        <span class="status-badge bg-purple-100 text-purple-800 border border-purple-300">
                            <i class="fas fa-shopping-cart mr-1"></i>In Cart
                        </span>
                    </div>
                    <% } %>
                    
                    <!-- Price Tag -->
                    <div class="absolute bottom-3 left-3 right-3">
                        <div class="bg-black bg-opacity-70 text-white px-3 py-2 rounded-lg">
                            <div class="font-bold text-lg">₹<%= property.price.toLocaleString() %></div>
                            <% if (property.price_type) { %>
                            <div class="text-xs opacity-90"><%= property.price_type %></div>
                            <% } %>
                        </div>
                    </div>
                </div>
                
                <!-- Property Details -->
                <div class="p-4">
                    <h3 class="font-bold text-gray-900 text-lg mb-2 truncate"><%= property.title %></h3>
                    
                    <!-- Location -->
                    <div class="flex items-center text-gray-600 mb-3">
                        <i class="fas fa-map-marker-alt mr-2 text-gray-400"></i>
                        <span class="text-sm truncate">
                            <% if (property.address) { %>
                                <%= property.address.city || 'Location not specified' %>
                            <% } else { %>
                                Location not specified
                            <% } %>
                        </span>
                    </div>
                    
                    <!-- Property Stats -->
                    <div class="grid grid-cols-3 gap-2 mb-4">
                        <div class="text-center">
                            <div class="font-bold text-gray-900"><%= property.bedrooms || 0 %></div>
                            <div class="text-xs text-gray-500">Beds</div>
                        </div>
                        <div class="text-center">
                            <div class="font-bold text-gray-900"><%= property.bathrooms || 0 %></div>
                            <div class="text-xs text-gray-500">Baths</div>
                        </div>
                        <div class="text-center">
                            <div class="font-bold text-gray-900"><%= property.built_up_area || 0 %></div>
                            <div class="text-xs text-gray-500">Sq. Ft.</div>
                        </div>
                    </div>
                    
                    <!-- Additional Info -->
                    <div class="flex justify-between text-sm text-gray-600 mb-4">
                        <div>
                            <i class="fas fa-eye mr-1"></i>
                            <span><%= property.views || 0 %> views</span>
                        </div>
                        <div>
                            <i class="fas fa-calendar-alt mr-1"></i>
                            <span><%= new Date(property.createdAt).toLocaleDateString() %></span>
                        </div>
                    </div>
                    
                    <!-- Action Buttons -->
                    <div class="flex space-x-2">
                        <!-- View Button -->
                        <a href="/seller/properties/<%= property._id %>" 
                           class="flex-1 action-btn bg-blue-50 text-blue-700 hover:bg-blue-100 text-center">
                            <i class="fas fa-eye mr-1"></i> View
                        </a>
                        
                        <!-- Edit Button (Conditional) -->
                        <% if (property.status === 'draft' || property.status === 'changes_requested') { %>
                            <a href="/seller/properties/<%= property._id %>/edit" 
                               class="flex-1 action-btn bg-green-50 text-green-700 hover:bg-green-100 text-center">
                                <i class="fas fa-edit mr-1"></i> Edit
                            </a>
                        <% } else if (property.cart_status?.in_cart) { %>
                            <a href="/seller/properties/<%= property._id %>/cart-details" 
                               class="flex-1 action-btn bg-purple-50 text-purple-700 hover:bg-purple-100 text-center">
                                <i class="fas fa-shopping-cart mr-1"></i> Cart
                            </a>
                        <% } else if (['pending_approval', 'approved', 'live'].includes(property.status)) { %>
                            <button onclick="requestEditAccess('<%= property._id %>')" 
                                    class="flex-1 action-btn bg-yellow-50 text-yellow-700 hover:bg-yellow-100 text-center">
                                <i class="fas fa-unlock-alt mr-1"></i> Request Edit
                            </button>
                        <% } %>
                        
                        <!-- Submit Button (for drafts) -->
                        <% if (property.status === 'draft') { %>
                            <button onclick="submitForApproval('<%= property._id %>')" 
                                    class="flex-1 action-btn bg-blue-50 text-blue-700 hover:bg-blue-100 text-center">
                                <i class="fas fa-paper-plane mr-1"></i> Submit
                            </button>
                        <% } %>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
        
        <!-- Empty State Template (for filtering) -->
        <div id="empty-state" class="hidden text-center py-12 bg-white rounded-xl shadow">
            <i class="fas fa-filter text-gray-300 text-6xl mb-4"></i>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">No Properties Found</h3>
            <p class="text-gray-600">No properties match your current filter</p>
        </div>
    </div>

    <script>
        // Filter properties by status
        function filterProperties(status) {
            const allCards = document.querySelectorAll('.property-card');
            const emptyState = document.getElementById('empty-state');
            const propertiesGrid = document.getElementById('properties-grid');
            let visibleCount = 0;
            
            allCards.forEach(card => {
                const statusBadge = card.querySelector('.status-badge');
                const cardStatus = statusBadge ? statusBadge.textContent.trim().replace(' ', '_').toLowerCase() : '';
                
                if (status === 'all' || cardStatus === status) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            // Show empty state if no properties visible
            if (visibleCount === 0) {
                propertiesGrid.classList.add('hidden');
                emptyState.classList.remove('hidden');
            } else {
                propertiesGrid.classList.remove('hidden');
                emptyState.classList.add('hidden');
            }
            
            // Update active filter button
            document.querySelectorAll('button[onclick^="filterProperties"]').forEach(btn => {
                btn.classList.remove('bg-blue-100', 'text-blue-700');
                btn.classList.add('border', 'text-gray-700', 'hover:bg-gray-50');
            });
            
            const activeBtn = document.querySelector(`button[onclick="filterProperties('${status}')"]`);
            if (activeBtn) {
                activeBtn.classList.remove('border', 'text-gray-700', 'hover:bg-gray-50');
                activeBtn.classList.add('bg-blue-100', 'text-blue-700');
            }
        }
        
        // Submit property for approval
        async function submitForApproval(propertyId) {
            const result = await Swal.fire({
                title: 'Submit for Approval?',
                text: 'This will send your property to admin for review. You cannot edit it while pending approval.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, submit!',
                cancelButtonText: 'Cancel'
            });
            
            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/seller/properties/${propertyId}/submit`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        Swal.fire({
                            title: 'Submitted!',
                            text: data.message,
                            icon: 'success',
                            confirmButtonColor: '#3085d6'
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#d33'
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Failed to submit property',
                        icon: 'error',
                        confirmButtonColor: '#d33'
                    });
                }
            }
        }
        
        // Request edit access
        async function requestEditAccess(propertyId) {
            const { value: reason } = await Swal.fire({
                title: 'Request Edit Access',
                input: 'textarea',
                inputLabel: 'Reason for edit request',
                inputPlaceholder: 'Explain why you need to edit this property...',
                inputAttributes: {
                    'aria-label': 'Type your reason here'
                },
                showCancelButton: true,
                confirmButtonText: 'Submit Request',
                cancelButtonText: 'Cancel',
                inputValidator: (value) => {
                    if (!value) {
                        return 'Please provide a reason for the edit request';
                    }
                }
            });
            
            if (reason) {
                try {
                    const response = await fetch(`/seller/properties/${propertyId}/request-edit`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ reason })
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        Swal.fire({
                            title: 'Request Sent!',
                            text: data.message,
                            icon: 'success',
                            confirmButtonColor: '#3085d6'
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#d33'
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Failed to submit edit request',
                        icon: 'error',
                        confirmButtonColor: '#d33'
                    });
                }
            }
        }
        
        // Delete property
        async function deleteProperty(propertyId) {
            const result = await Swal.fire({
                title: 'Are you sure?',
                text: 'This will permanently delete the property and all its images.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            });
            
            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/seller/properties/${propertyId}/delete`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        }
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        Swal.fire({
                            title: 'Deleted!',
                            text: data.message,
                            icon: 'success',
                            confirmButtonColor: '#3085d6'
                        }).then(() => {
                            location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: 'Error!',
                            text: data.message,
                            icon: 'error',
                            confirmButtonColor: '#d33'
                        });
                    }
                } catch (error) {
                    Swal.fire({
                        title: 'Error!',
                        text: 'Failed to delete property',
                        icon: 'error',
                        confirmButtonColor: '#d33'
                    });
                }
            }
        }
    </script>
</body>
</html>