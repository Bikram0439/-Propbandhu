                        <% } %>
                    </div>
                    <% } %>
                </div>

                <!-- Form Actions -->
                <div class="flex flex-wrap justify-between border-t pt-6 gap-4">
                    <div class="flex space-x-3">
                        <a href="/broker/properties/<%= property._id %>" 
                           class="bg-gray-300 text-gray-700 px-6 py-2 rounded-lg hover:bg-gray-400 flex items-center">
                            <i class="fas fa-times mr-2"></i> Cancel
                        </a>
                        
                        <a href="/broker/dashboard" 
                           class="bg-gray-200 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-300 flex items-center">
                            <i class="fas fa-tachometer-alt mr-2"></i> Dashboard
                        </a>
                    </div>
                    
                    <div class="flex space-x-3">
                        <!-- Different submit buttons based on state -->
                        <% if (canEdit) { %>
                            <% if (isChangesRequested) { %>
                            <button type="submit" 
                                    class="bg-orange-600 text-white px-6 py-2 rounded-lg hover:bg-orange-700 flex items-center shadow-md submit-btn">
                                <i class="fas fa-check-circle mr-2"></i> Save & Resubmit for Approval
                            </button>
                            <% } else if (isDraft) { %>
                            <button type="button" onclick="saveAsDraft()"
                                    class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 flex items-center submit-btn">
                                <i class="fas fa-save mr-2"></i> Save Draft
                            </button>
                            <button type="button" onclick="submitForApproval('<%= property._id %>')"
                                    class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 flex items-center submit-btn">
                                <i class="fas fa-paper-plane mr-2"></i> Submit for Approval
                            </button>
                            <% } else { %>
                            <!-- ✅ Submit button for limited/full edit mode -->
                            <button type="button" onclick="saveChanges()"
                                    class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 flex items-center shadow-md submit-btn">
                                <i class="fas fa-save mr-2"></i> Save Changes
                            </button>
                            <% } %>
                        <% } else if (isPendingApproval) { %>
                        <button type="button" onclick="requestEditAccess('<%= property._id %>')"
                                class="bg-yellow-600 text-white px-6 py-2 rounded-lg hover:bg-yellow-700 flex items-center submit-btn">
                            <i class="fas fa-unlock mr-2"></i> Request Edit Access
                        </button>
                        <% } else if (isRejected) { %>
                        <button type="button" onclick="createNewFromRejected('<%= property._id %>')"
                                class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 flex items-center submit-btn">
                            <i class="fas fa-plus-circle mr-2"></i> Create New from Rejected
                        </button>
                        <% } %>
                        
                        <!-- Request extension if editing -->
                        <% if (canEdit && editExpiryInfo) { %>
                        <button type="button" onclick="requestExtension('<%= property._id %>')"
                                class="bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 flex items-center submit-btn">
                            <i class="fas fa-clock mr-2"></i> Request More Time
                        </button>
                        <% } %>
                    </div>
                </div>
                
                <!-- Form Help Text -->
                <div class="mt-4 pt-4 border-t border-gray-200">
                    <p class="text-sm text-gray-600">
                        <i class="fas fa-info-circle text-gray-400 mr-1"></i>
                        <% if (canEditAll) { %>
                            You have <strong>full edit access</strong> to all fields.
                        <% } else if (canEditLimited) { %>
                            You have <strong>limited edit access</strong> to specific fields only. Other fields are read-only.
                        <% } else if (isPendingApproval) { %>
                            This property is <strong>under admin review</strong>. You cannot edit until admin completes review or grants edit access.
                        <% } else if (isRejected) { %>
                            This property was <strong>rejected</strong> by admin. You cannot edit it, but can create a new listing.
                        <% } else { %>
                            Edit permissions are currently <strong>restricted</strong>.
                        <% } %>
                        <% if (property.broker_info) { %>
                        <br>
                        <span class="text-blue-600">
                            <i class="fas fa-user-tie mr-1"></i>
                            Added as broker with <%= (brokerInfo.commission_rate * 100) || 1 %>% commission
                        </span>
                        <% } %>
                    </p>
                </div>
            </form>
        </div>

        <!-- Seller Edit Modal -->
        <div id="sellerEditModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
            <div class="relative top-20 mx-auto p-5 border w-full max-w-md shadow-lg rounded-md bg-white">
                <div class="mt-3">
                    <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">
                        Update Seller Information
                    </h3>
                    
                    <form id="sellerEditForm">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    Seller Name
                                </label>
                                <input type="text" name="seller_name" value="<%= sellerInfo.name || '' %>"
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg">
                            </div>
                            
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    Seller Phone
                                </label>
                                <input type="tel" name="seller_phone" value="<%= sellerInfo.phone || '' %>"
                                       class="w-full px-4 py-2 border border-gray-300 rounded-lg">
