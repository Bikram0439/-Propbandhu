        <!-- Notes Edit Modal -->
        <div id="notesEditModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden z-50">
            <div class="relative top-20 mx-auto p-5 border w-full max-w-md shadow-lg rounded-md bg-white">
                <div class="mt-3">
                    <h3 class="text-lg font-medium leading-6 text-gray-900 mb-4">
                        Edit Internal Notes
                    </h3>
                    
                    <form id="notesEditForm">
                        <div class="space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 mb-1">
                                    Internal Notes
                                </label>
                                <textarea name="broker_notes" rows="4"
                                          class="w-full px-4 py-2 border border-gray-300 rounded-lg"
                                          placeholder="Any internal notes, seller preferences, or special instructions..."><%= brokerInfo.internal_notes || '' %></textarea>
                            </div>
                        </div>
                        
                        <div class="flex justify-end space-x-3 mt-6">
                            <button type="button" onclick="hideNotesEditModal()"
                                    class="bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400">
                                Cancel
                            </button>
                            <button type="submit"
                                    class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700">
                                Save Notes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            let selectedImage = null;
            const brokerId = '<%= broker.broker_id %>';
            const commissionRate = <%= brokerInfo.commission_rate || 0.01 %>;
            
            // Property type to sub-type mapping
            const propertyTypes = {
                'Residential': ['Apartment', 'Independent House', 'Villa', 'Penthouse', 'Studio', 'Farmhouse'],
                'Commercial': ['Office Space', 'Shop', 'Showroom', 'Warehouse', 'Industrial Building'],
                'Plot': ['Residential Plot', 'Commercial Plot', 'Agricultural Land', 'Industrial Plot'],
                'Agricultural': ['Farm Land', 'Orchard', 'Plantation'],
                'Industrial': ['Factory', 'Manufacturing Unit', 'Storage Unit']
            };
            
            // City to Locations mapping
            const cityLocationMap = {
                Noida: [
                    "Sector 62", "Sector 18", "Sector 15", "Sector 50",
                    "Sector 76", "Sector 137", "Sector 128",
                    "Sector 44", "Greater Noida West", "Noida Extension"
                ],
                Ghaziabad: [
                    "Indirapuram", "Vaishali", "Raj Nagar",
                    "Raj Nagar Extension", "Crossings Republik",
                    "Kavi Nagar", "Sanjay Nagar", "Shastri Nagar",
                    "Mohan Nagar", "Vasundhara"
                ],
                Gorakhpur: [
                    "Golghar", "Medical Road", "Rustampur",
                    "Taramandal", "Chargawan", "Basharatpur",
                    "Betiahata", "Civil Lines", "Transport Nagar",
                    "Padri Bazar"
                ]
            };
            
            // City to State mapping
            const cityStateMap = {
                'Noida': 'Uttar Pradesh',
                'Ghaziabad': 'Uttar Pradesh',
                'Gorakhpur': 'Uttar Pradesh'
            };
            
            // ========== IMAGE HANDLING ==========
            
            function handleImageUpload(input) {
                if (input.files && input.files[0]) {
                    const file = input.files[0];
                    
                    if (file.size > 10 * 1024 * 1024) {
                        alert('File is too large. Maximum size is 10MB.');
                        input.value = '';
                        return;
                    }
                    
                    if (!file.type.match('image.*')) {
                        alert('Please select an image file.');
                        input.value = '';
                        return;
                    }
                    
                    selectedImage = file;
                    
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const placeholder = document.getElementById('imagePlaceholder');
                        if (placeholder) {
                            placeholder.classList.add('hidden');
                        }
                        
                        const preview = document.getElementById('imagePreview');
                        if (preview) {
                            preview.src = e.target.result;
                            preview.classList.remove('hidden');
                        } else {
                            const container = document.querySelector('.image-preview-container');
                            const img = document.createElement('img');
                            img.id = 'imagePreview';
                            img.className = 'image-preview';
                            img.src = e.target.result;
                            container.appendChild(img);
                        }
                        
                        const removeBtn = document.getElementById('removeImageBtn');
                        if (removeBtn) {
                            removeBtn.classList.remove('hidden');
                        }
                    };
                    reader.readAsDataURL(file);
                }
            }
            
            function removeImage() {
                const input = document.getElementById('imageInput');
                const preview = document.getElementById('imagePreview');
                const placeholder = document.getElementById('imagePlaceholder');
                const removeBtn = document.getElementById('removeImageBtn');
                
                if (input) input.value = '';
                if (preview) {
                    preview.src = '';
                    preview.classList.add('hidden');
                }
                if (placeholder) placeholder.classList.remove('hidden');
                if (removeBtn) removeBtn.classList.add('hidden');
                selectedImage = null;
            }
            
            // ========== MODAL FUNCTIONS ==========
            
            function showSellerEditModal() {
                document.getElementById('sellerEditModal').classList.remove('hidden');
            }
            
            function hideSellerEditModal() {
                document.getElementById('sellerEditModal').classList.add('hidden');
            }
            
            function showNotesEditModal() {
                document.getElementById('notesEditModal').classList.remove('hidden');
            }
            
            function hideNotesEditModal() {
                document.getElementById('notesEditModal').classList.add('hidden');
            }
            
            // Handle seller edit form
            document.getElementById('sellerEditForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData();
                formData.append('seller_name', this.seller_name.value);
                formData.append('seller_phone', this.seller_phone.value);
                formData.append('seller_email', this.seller_email.value);
                formData.append('property_id', '<%= property._id %>');
                
                try {
                    const response = await fetch('/broker/api/properties/<%= property._id %>/update-seller', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const data = await response.json();
                    if (data.success) {
                        alert('Seller information updated successfully!');
                        hideSellerEditModal();
                        window.location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                } catch (error) {
                    console.error('Error updating seller:', error);
                    alert('Failed to update seller information');
                }
            });
            
            // Handle notes edit form
            document.getElementById('notesEditForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const formData = new FormData();
                formData.append('broker_notes', this.broker_notes.value);
                formData.append('property_id', '<%= property._id %>');
                
                try {
                    const response = await fetch('/broker/api/properties/<%= property._id %>/update-notes', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const data = await response.json();
                    if (data.success) {
                        alert('Notes updated successfully!');
                        hideNotesEditModal();
                        window.location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                } catch (error) {
                    console.error('Error updating notes:', error);
                    alert('Failed to update notes');
                }
            });
            
            // ========== HELPER FUNCTIONS ==========
            
            function getFormData() {
                const form = document.getElementById('editForm');
                const formData = new FormData();
                
                const inputs = form.querySelectorAll('input, select, textarea');
                inputs.forEach(input => {
                    if (input.name && !input.disabled) {
                        if (input.type === 'checkbox') {
                            if (input.checked) {
                                formData.append(input.name, input.value);
                            }
                        } else if (input.tagName === 'SELECT' && input.multiple) {
                            const selectedOptions = Array.from(input.selectedOptions).map(option => option.value);
                            if (selectedOptions.length > 0) {
                                formData.append(input.name, JSON.stringify(selectedOptions));
                            }
                        } else {
                            formData.append(input.name, input.value);
                        }
                    }
                });
                
                return formData;
            }
            
            function getAddressData() {
                return {
                    street: document.querySelector('input[name="address[street]"]')?.value || '',
                    landmark: document.querySelector('input[name="address[landmark]"]')?.value || '',
                    city: document.querySelector('select[name="address[city]"]')?.value || '',
                    state: document.querySelector('input[name="address[state]"]')?.value || '',
                    pincode: document.querySelector('input[name="address[pincode]"]')?.value || '',
                    areas: Array.from(document.querySelector('select[name="address[areas][]"]')?.selectedOptions || [])
                            .map(opt => opt.value)
                };
            }
            
            function updateCommission() {
                const priceInput = document.querySelector('input[name="price"]');
                const commissionAmount = document.getElementById('commissionAmount');
                
                if (priceInput && commissionAmount) {
                    const price = parseFloat(priceInput.value) || 0;
                    const commission = price * commissionRate;
                    commissionAmount.textContent = commission.toLocaleString('en-IN');
                }
            }
            
            // ========== FORM VALIDATION ==========
            
            function validateForm() {
                const title = document.querySelector('input[name="title"]')?.value.trim() || '';
                const description = document.querySelector('textarea[name="description"]')?.value.trim() || '';
                const price = document.querySelector('input[name="price"]')?.value;
                const propertyType = document.querySelector('select[name="property_type"]')?.value;
                
                let errors = [];
                
                if (!title) {
                    errors.push('Property title is required');
                }
                
                if (!description || description.length < 50) {
                    errors.push('Description must be at least 50 characters');
                }
                
                if (!price || parseFloat(price) < 1000) {
                    errors.push('Valid price is required (minimum ₹1000)');
                }
                
                if (!propertyType) {
                    errors.push('Property type is required');
                }
                
                if (errors.length > 0) {
                    showNotification(errors.join('. '), 'error');
                    return false;
                }
                
                return true;
            }
            
            // ========== SUBMIT FUNCTIONS ==========
            
            async function saveAsDraft() {
                console.log('Saving as draft...');
                
                if (!validateForm()) {
                    return;
                }
                
                try {
                    showLoading('Saving draft...');
                    
                    const formData = getFormData();
                    formData.append('property_id', '<%= property._id %>');
                    
                    const amenities = [];
                    document.querySelectorAll('input[name="amenities"]:checked').forEach(checkbox => {
                        amenities.push(checkbox.value);
                    });
                    
                    formData.delete('amenities');
                    if (amenities.length > 0) {
                        formData.append('amenities', JSON.stringify(amenities));
                    }
                    
                    const address = getAddressData();
                    formData.append('location', JSON.stringify(address));
                    
                    if (selectedImage) {
                        formData.append('image', selectedImage);
                    }
                    
                    const response = await fetch('/broker/properties/<%= property._id %>/edit', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    console.log('Save result:', result);
                    hideLoading();
                    
                    if (result.success) {
                        showNotification('Draft saved successfully!', 'success');
                        
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500);
                    } else {
                        if (result.deniedFields) {
                            showNotification(`Some fields cannot be edited. Contact admin for access.`, 'warning');
                        } else {
                            showNotification('Error: ' + result.message, 'error');
                        }
                    }
                } catch (error) {
                    console.error('Error saving draft:', error);
                    hideLoading();
                    showNotification('Failed to save draft. Please try again.', 'error');
                }
            }
            
            async function saveChanges() {
                console.log('Saving changes...');
                
                if (!validateForm()) {
                    return;
                }
                
                try {
                    showLoading('Saving changes...');
                    
                    const formData = getFormData();
                    formData.append('property_id', '<%= property._id %>');
                    
                    const amenities = [];
                    document.querySelectorAll('input[name="amenities"]:checked').forEach(checkbox => {
                        amenities.push(checkbox.value);
                    });
                    
                    formData.delete('amenities');
                    if (amenities.length > 0) {
                        formData.append('amenities', JSON.stringify(amenities));
                    }
                    
                    const address = getAddressData();
                    formData.append('location', JSON.stringify(address));
                    
                    if (selectedImage) {
                        formData.append('image', selectedImage);
                    }
                    
                    console.log('Submitting changes...');
                    
                    const response = await fetch('/broker/properties/<%= property._id %>/edit', {
                        method: 'POST',
                        body: formData
                    });
                    
                    const result = await response.json();
                    console.log('Save result:', result);
                    hideLoading();
                    
                    if (result.success) {
                        showNotification('Changes saved successfully!', 'success');
                        
                        setTimeout(() => {
                            window.location.href = result.redirectUrl || `/broker/properties/<%= property._id %>`;
                        }, 1500);
                    } else {
                        if (result.deniedFields) {
                            showNotification(`Some fields cannot be edited. You can only edit: ${result.allowedFields?.join(', ') || 'specific fields'}`, 'warning');
                        } else {
                            showNotification('Error: ' + result.message, 'error');
                        }
                    }
                } catch (error) {
                    console.error('Error saving changes:', error);
                    hideLoading();
                    showNotification('Failed to save changes. Please try again.', 'error');
                }
            }
            
            // Form submission for changes_requested status
            document.getElementById('editForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                
                <% if (isChangesRequested) { %>
                    console.log('Submitting changes_requested property...');
                    
                    if (!validateForm()) {
                        return;
                    }
                    
                    try {
                        showLoading('Saving property and submitting for approval...');
                        
                        const formData = getFormData();
                        formData.append('property_id', '<%= property._id %>');
                        formData.append('submit_for_approval', 'true');
                        
                        const amenities = [];
                        document.querySelectorAll('input[name="amenities"]:checked').forEach(checkbox => {
                            amenities.push(checkbox.value);
                        });
                        
                        formData.delete('amenities');
                        if (amenities.length > 0) {
                            formData.append('amenities', JSON.stringify(amenities));
                        }
                        
                        const address = getAddressData();
                        formData.append('location', JSON.stringify(address));
                        
                        if (selectedImage) {
                            formData.append('image', selectedImage);
                        }
                        
                        console.log('Submitting for approval...');
                        
                        const response = await fetch('/broker/properties/<%= property._id %>/edit', {
                            method: 'POST',
                            body: formData
                        });
                        
                        const result = await response.json();
                        console.log('Submit result:', result);
                        hideLoading();
                        
                        if (result.success) {
                            showNotification('Property updated and submitted for approval!', 'success');
                            
                            setTimeout(() => {
                                window.location.href = '/broker/dashboard';
                            }, 1500);
                        } else {
                            if (result.deniedFields) {
                                showNotification(`Some fields cannot be edited. Contact admin for access.`, 'warning');
                            } else {
                                showNotification('Error: ' + result.message, 'error');
                            }
                        }
                    } catch (error) {
                        console.error('Error submitting:', error);
                        hideLoading();
                        showNotification('Failed to update property. Please try again.', 'error');
                    }
                <% } %>
            });
            
            function submitForApproval(propertyId) {
                console.log('Submitting for approval...');
                
                if (!validateForm()) {
                    return;
                }
                
                if (confirm('Submit this property for admin approval?\n\nOnce submitted, you cannot edit until admin reviews it.')) {
                    showLoading('Submitting for approval...');
                    
                    fetch(`/broker/properties/${propertyId}/submit`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        console.log('Submit response:', data);
                        hideLoading();
                        if (data.success) {
                            showNotification('Property submitted for approval! Admin will review it soon.', 'success');
                            setTimeout(() => {
                                window.location.href = '/broker/dashboard';
                            }, 2000);
                        } else {
                            showNotification('Error: ' + data.message, 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error submitting:', error);
                        hideLoading();
                        showNotification('Failed to submit property', 'error');
                    });
                }
            }
            
            function requestEditAccess(propertyId) {
                const reason = prompt('Please provide a reason for requesting edit access:\n\nExample: "I entered wrong price by mistake"');
                
                if (reason && reason.trim()) {
                    showLoading('Submitting request...');
                    
                    fetch(`/broker/properties/${propertyId}/request-edit`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ reason: reason.trim() })
                    })
                    .then(response => response.json())
                    .then(data => {
                        hideLoading();
                        if (data.success) {
                            showNotification('Edit request submitted to admin. You will be notified when approved.', 'success');
                            setTimeout(() => {
                                window.location.reload();
                            }, 2000);
                        } else {
                            if (data.message && data.message.includes('already sent recently')) {
                                showNotification('You already requested edit access recently. Please wait.', 'warning');
                            } else {
                                showNotification('Error: ' + data.message, 'error');
                            }
                        }
                    })
                    .catch(error => {
                        hideLoading();
                        console.error('Error:', error);
                        showNotification('Failed to submit request', 'error');
                    });
                }
            }
            
            function requestExtension(propertyId) {
                const reason = prompt('Why do you need more time to edit?\n\nExample: "I need more time to upload better quality images"');
                
                if (reason && reason.trim()) {
                    showLoading('Requesting extension...');
                    
                    fetch(`/broker/properties/${propertyId}/request-extension`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({ reason: reason.trim() })
                    })
                    .then(response => response.json())
                    .then(data => {
                        hideLoading();
                        if (data.success) {
                            showNotification('Extension request submitted to admin.', 'success');
                        } else {
                            showNotification('Error: ' + data.message, 'error');
                        }
                    })
                    .catch(error => {
                        hideLoading();
                        console.error('Error:', error);
                        showNotification('Failed to submit request', 'error');
                    });
                }
            }
            
            function createNewFromRejected(propertyId) {
                if (confirm('Create a new listing from this rejected property?\n\nThis will copy all details to a new draft that you can edit and resubmit.')) {
                    showLoading('Creating new listing...');
                    
                    fetch(`/broker/properties/${propertyId}/duplicate`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        hideLoading();
                        if (data.success && data.propertyId) {
                            showNotification('New draft created from rejected property!', 'success');
                            setTimeout(() => {
                                window.location.href = `/broker/properties/${data.propertyId}/edit`;
                            }, 1500);
                        } else {
                            showNotification('Error: ' + data.message, 'error');
                        }
                    })
                    .catch(error => {
                        hideLoading();
                        console.error('Error:', error);
                        showNotification('Failed to create new listing', 'error');
                    });
                }
            }
            
            // ========== UTILITY FUNCTIONS ==========
            
            function showNotification(message, type = 'info') {
                const notification = document.createElement('div');
                notification.className = `fixed top-4 right-4 px-4 py-3 rounded-lg shadow-lg z-50 
                    ${type === 'success' ? 'bg-green-100 text-green-800 border border-green-300' : 
                      type === 'error' ? 'bg-red-100 text-red-800 border border-red-300' : 
                      'bg-blue-100 text-blue-800 border border-blue-300'}`;
                notification.innerHTML = `
                    <div class="flex items-center">
                        <i class="fas ${type === 'success' ? 'fa-check-circle' : type === 'error' ? 'fa-exclamation-circle' : 'fa-info-circle'} mr-2"></i>
                        <span>${message}</span>
                    </div>
                `;
                
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.style.opacity = '0';
                    notification.style.transition = 'opacity 0.5s';
                    setTimeout(() => notification.remove(), 500);
                }, 5000);
            }
            
            function showLoading(message = 'Processing...') {
                const loading = document.createElement('div');
                loading.id = 'loading-overlay';
                loading.className = 'fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50';
                loading.innerHTML = `
                    <div class="bg-white p-6 rounded-lg shadow-xl text-center">
                        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
                        <p class="text-gray-700">${message}</p>
                    </div>
                `;
                
                document.body.appendChild(loading);
            }
            
            function hideLoading() {
                const loading = document.getElementById('loading-overlay');
                if (loading) {
                    loading.remove();
                }
            }
            
            function updateLocations() {
                const city = document.getElementById('citySelect').value;
                const locationSelect = document.getElementById('locationSelect');
                const locationCount = document.getElementById('locationCount');
                const stateInput = document.getElementById('stateInput');
                
                locationSelect.innerHTML = '';
                
                if (city && cityLocationMap[city]) {
                    locationSelect.disabled = false;
                    
                    cityLocationMap[city].forEach(location => {
                        const option = document.createElement('option');
                        option.value = location;
                        option.textContent = location;
                        
                        const currentAreas = '<%= currentAreas %>'.split(',');
                        if (currentAreas.includes(location)) {
                            option.selected = true;
                        }
                        
                        locationSelect.appendChild(option);
                    });
                    
                    if (cityStateMap[city] && !stateInput.value) {
                        stateInput.value = cityStateMap[city];
                    }
                    
                    updateLocationCount();
                } else {
                    locationSelect.disabled = true;
                    const option = document.createElement('option');
                    option.value = '';
                    option.textContent = 'Please select a city first';
                    locationSelect.appendChild(option);
                    locationCount.textContent = 'Hold Ctrl (Windows) / Cmd (Mac) to select multiple locations';
                }
            }
            
            function updateLocationCount() {
                const locationSelect = document.getElementById('locationSelect');
                const locationCount = document.getElementById('locationCount');
                const selectedCount = locationSelect ? 
                    Array.from(locationSelect.selectedOptions).filter(opt => opt.value).length : 0;
                
                if (selectedCount > 0) {
                    locationCount.textContent = `${selectedCount} location(s) selected. Hold Ctrl (Windows) / Cmd (Mac) to select multiple`;
                } else {
                    locationCount.textContent = 'Hold Ctrl (Windows) / Cmd (Mac) to select multiple locations';
                }
            }
            
            document.querySelector('textarea[name="description"]').addEventListener('input', function(e) {
                const count = e.target.value.length;
                const descCount = document.getElementById('descCount');
                if (descCount) {
                    descCount.textContent = `${count}/5000`;
                }
            });
            
            document.getElementById('propertyTypeSelect').addEventListener('change', function(e) {
                const type = e.target.value;
                const subTypeSelect = document.getElementById('subTypeSelect');
                
                subTypeSelect.innerHTML = '<option value="">Select Sub Type</option>';
                
                if (type && propertyTypes[type]) {
                    subTypeSelect.disabled = false;
                    propertyTypes[type].forEach(subType => {
                        const option = document.createElement('option');
                        option.value = subType;
                        option.textContent = subType;
                        subTypeSelect.appendChild(option);
                    });
                } else {
                    subTypeSelect.disabled = true;
                }
            });
            
            // Update commission when price changes
            document.querySelector('input[name="price"]')?.addEventListener('input', updateCommission);
            
            document.addEventListener('DOMContentLoaded', function() {
                console.log('Page loaded, initializing...');
                
                updateLocations();
                
                const locationSelect = document.getElementById('locationSelect');
                if (locationSelect) {
                    locationSelect.addEventListener('change', updateLocationCount);
                }
                
                const citySelect = document.getElementById('citySelect');
                if (citySelect) {
                    citySelect.addEventListener('change', function() {
                        updateLocations();
                        const stateInput = document.getElementById('stateInput');
                        const city = this.value;
                        if (cityStateMap[city] && !stateInput.value) {
                            stateInput.value = cityStateMap[city];
                        }
                    });
                }
                
                const imageContainer = document.querySelector('.image-preview-container');
                const imageInput = document.getElementById('imageInput');
                if (imageContainer && imageInput) {
                    imageContainer.addEventListener('click', function() {
                        if (!imageInput.disabled) {
                            imageInput.click();
                        }
                    });
                }
                
                updateCommission();
            });
        </script>
    </body>
</html>