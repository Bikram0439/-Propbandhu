                                   <%= canEditField('contact_name') ? '' : 'disabled readonly' %>
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg 
                                          <%= canEditField('contact_name') ? 'field-enabled' : 'field-disabled' %>">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">
                                Contact Phone
                                <% if (canEditField('contact_phone')) { %>
                                <span class="editable-badge">Editable</span>
                                <% } else { %>
                                <span class="readonly-badge">Read-only</span>
                                <% } %>
                            </label>
                            <input type="tel" name="contact_phone" value="<%= property.contact_phone || '' %>"
                                   <%= canEditField('contact_phone') ? '' : 'disabled readonly' %>
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg 
                                          <%= canEditField('contact_phone') ? 'field-enabled' : 'field-disabled' %>">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-1">
                                Contact Email
                                <% if (canEditField('contact_email')) { %>
                                <span class="editable-badge">Editable</span>
                                <% } else { %>
                                <span class="readonly-badge">Read-only</span>
