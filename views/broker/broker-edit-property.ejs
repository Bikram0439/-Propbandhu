                            <i class="fas fa-edit mr-1"></i> Edit Notes
                        </button>
                        <% } %>
                    </div>
                    <% } %>
                </div>

                <!-- Broker Commission Section -->
                <div class="space-y-6 mb-8">
                    <div class="flex items-center justify-between border-b pb-2">
                        <h2 class="text-xl font-bold text-gray-900">Broker Commission Details</h2>
                        <span class="text-sm text-gray-500">
                            Read-only
                        </span>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="bg-gray-50 p-4 rounded-lg border">
                            <p class="text-sm text-gray-600">Commission Rate</p>
                            <p class="text-lg font-bold text-blue-600">
                                <%= (brokerInfo.commission_rate * 100) || 1 %>%
