<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Property - Broker Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* Field Disabled Styling */
        .field-disabled {
            background-color: #f3f4f6;
            cursor: not-allowed;
            color: #6b7280;
        }
        
        .field-enabled {
            background-color: white;
        }
        
        .readonly-badge {
            background-color: #e5e7eb;
            color: #4b5563;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 8px;
        }
        
        .editable-badge {
            background-color: #10b981;
            color: white;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 8px;
        }
        
        .broker-badge {
            background-color: #3b82f6;
            color: white;
            font-size: 10px;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 8px;
        }
        
        .commission-badge {
            @apply inline-flex items-center px-3 py-1 rounded-full text-sm font-medium;
        }
        
        .commission-adder { @apply bg-blue-100 text-blue-800; }
        .commission-seller { @apply bg-green-100 text-green-800; }
        
        .image-preview-container {
            border: 2px dashed #ccc;
            border-radius: 10px;
            padding: 20px;
            min-height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: border-color 0.3s;
        }
        
        .image-preview-container:hover {
            border-color: #3b82f6;
        }
        
        .image-preview {
            max-width: 100%;
            max-height: 300px;
            border-radius: 8px;
        }
        
        .submit-btn {
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .submit-btn:after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 5px;
            height: 5px;
            background: rgba(255, 255, 255, 0.5);
            opacity: 0;
            border-radius: 100%;
            transform: scale(1, 1) translate(-50%);
            transform-origin: 50% 50%;
        }
        
        .submit-btn:focus:not(:active)::after {
            animation: ripple 1s ease-out;
        }
        
        @keyframes ripple {
            0% {
                transform: scale(0, 0);
                opacity: 0.5;
            }
            100% {
                transform: scale(20, 20);
                opacity: 0;
            }
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/broker/dashboard" class="flex items-center">
                        <span class="text-xl font-bold text-gray-900">Propbandhu Broker</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-blue-700 font-medium">
                        <i class="fas fa-user-tie mr-2"></i><%= broker.name %>
                    </span>
                    <a href="/broker/dashboard" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-tachometer-alt mr-1"></i>Dashboard
                    </a>
                    <a href="/broker/properties" class="text-blue-600 font-medium">
                        <i class="fas fa-home mr-1"></i>Properties
                    </a>
                    <a href="/broker/commission" class="text-gray-600 hover:text-green-600">
                        <i class="fas fa-money-bill-wave mr-1"></i>Commission
                    </a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600">
                        <i class="fas fa-sign-out-alt mr-1"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <!-- ✅ CORRECTED: CALCULATE EDIT PERMISSIONS USING edit_permissions -->
        <% 
        // Determine edit mode
        const isDraft = property.status === 'draft';
        const isChangesRequested = property.status === 'changes_requested';
        const isPendingApproval = property.status === 'pending_approval';
        const isRejected = property.status === 'rejected';
        const isApproved = property.status === 'approved';
        const isPublished = property.status === 'published';
        
        // ✅ FIXED: Use edit_permissions (your actual schema field)
        const editPermissions = property.edit_permissions || {};
        
        // ✅ FIXED: CORRECT LOGIC FOR edit_permissions
        const canEditAll = 
            property.status === 'draft' || 
            (editPermissions.enabled && editPermissions.allowed_fields && editPermissions.allowed_fields.includes('*'));
        
        const canEditLimited = 
            editPermissions.enabled && 
            editPermissions.allowed_fields && 
            editPermissions.allowed_fields.length > 0 &&
            !editPermissions.allowed_fields.includes('*');
        
        const canEdit = canEditAll || canEditLimited;
        
        // Allowed fields for limited edit mode
        const allowedFields = editPermissions.allowed_fields || [];
        
        // ✅ FIXED: Helper function to check if field is editable
        const canEditField = (fieldName) => {
            if (canEditAll) return true;
            if (canEditLimited && allowedFields.includes(fieldName)) return true;
            return false;
        };
        
        // Check if address field is editable
        const canEditAddressField = (addressField) => {
            return canEditField('address') || canEditField(`address.${addressField}`) || canEditField(`address[${addressField}]`);
        };
        
        // Parse property address
        const propertyAddress = property.address || {};
        
        // Broker specific: Seller info
        const sellerInfo = property.seller_info || {};
        const brokerInfo = property.broker_info || {};
        
        // Deadline calculation
        let deadlineInfo = null;
        if (property.admin_review?.deadline) {
            const deadline = new Date(property.admin_review.deadline);
            const now = new Date();
            const daysLeft = Math.ceil((deadline - now) / (1000 * 60 * 60 * 24));
            deadlineInfo = {
                date: deadline,
                daysLeft: daysLeft,
                isUrgent: daysLeft <= 2
            };
        }
        
        // Edit expiry if applicable
        let editExpiryInfo = null;
        if (editPermissions.end_time) {
            const expiry = new Date(editPermissions.end_time);
            const now = new Date();
            const hoursLeft = Math.ceil((expiry - now) / (1000 * 60 * 60));
            editExpiryInfo = {
                date: expiry,
                hoursLeft: hoursLeft,
                isExpiringSoon: hoursLeft <= 6
            };
        }
        
        // Property type to sub-type mapping
        const propertyTypes = {
            'Residential': ['Apartment', 'Independent House', 'Villa', 'Penthouse', 'Studio', 'Farmhouse'],
            'Commercial': ['Office Space', 'Shop', 'Showroom', 'Warehouse', 'Industrial Building'],
            'Plot': ['Residential Plot', 'Commercial Plot', 'Agricultural Land', 'Industrial Plot'],
            'Agricultural': ['Farm Land', 'Orchard', 'Plantation'],
            'Industrial': ['Factory', 'Manufacturing Unit', 'Storage Unit']
        };
        
        // City to Locations mapping
        const cityLocationMap = {
            Noida: [
                "Sector 62", "Sector 18", "Sector 15", "Sector 50",
                "Sector 76", "Sector 137", "Sector 128",
                "Sector 44", "Greater Noida West", "Noida Extension"
            ],
            Ghaziabad: [
                "Indirapuram", "Vaishali", "Raj Nagar",
                "Raj Nagar Extension", "Crossings Republik",
                "Kavi Nagar", "Sanjay Nagar", "Shastri Nagar",
                "Mohan Nagar", "Vasundhara"
            ],
            Gorakhpur: [
                "Golghar", "Medical Road", "Rustampur",
                "Taramandal", "Chargawan", "Basharatpur",
                "Betiahata", "Civil Lines", "Transport Nagar",
                "Padri Bazar"
            ]
        };
        
        // City to State mapping
        const cityStateMap = {
            'Noida': 'Uttar Pradesh',
            'Ghaziabad': 'Uttar Pradesh',
            'Gorakhpur': 'Uttar Pradesh'
        };
        
        // Parse current areas from property
        let currentAreas = [];
        if (propertyAddress.areas && Array.isArray(propertyAddress.areas)) {
            currentAreas = propertyAddress.areas;
        } else if (propertyAddress.areas && typeof propertyAddress.areas === 'string') {
            currentAreas = propertyAddress.areas.split(',').map(area => area.trim());
        }
        
        // Commission calculation
        let commissionAmount = 0;
        if (property.price) {
            commissionAmount = property.price * (brokerInfo.commission_rate || 0.01);
        }
        %>
        
        <!-- Page Header -->
        <div class="mb-8">
            <div class="flex justify-between items-start">
                <div>
                    <h1 class="text-2xl font-bold text-gray-900 mb-2">
                        <% if (isChangesRequested) { %>
                        <i class="fas fa-exclamation-triangle text-yellow-600 mr-2"></i>
                        Fix Requested Changes
                        <% } else if (isDraft) { %>
                        <i class="fas fa-edit text-blue-600 mr-2"></i>
                        Edit Property (Broker Mode)
                        <% } else { %>
                        <i class="fas fa-edit text-gray-600 mr-2"></i>
                        Edit Property
                        <% } %>
                    </h1>
                    <p class="text-gray-600">Editing: <span class="font-medium"><%= property.title %></span></p>
                    <div class="flex items-center space-x-2 mt-2">
                        <span class="broker-badge">
                            <i class="fas fa-user-tie mr-1"></i>Broker Added
                        </span>
                        <% if (brokerInfo.commission_rate) { %>
                        <span class="commission-badge commission-adder">
                            <i class="fas fa-percentage mr-1"></i>
                            <%= (brokerInfo.commission_rate * 100) %>% Commission
                        </span>
                        <% } %>
                    </div>
                </div>
                <div class="flex flex-col items-end space-y-2">
                    <!-- ✅ FIXED: Use correct edit permission status -->
                    <span class="px-3 py-1 rounded-full text-sm font-medium 
                        <%= canEdit ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800' %>">
                        <%= canEditAll ? 'Full Edit Mode' : canEditLimited ? 'Limited Edit Mode' : 'Edit Restricted' %>
                    </span>
                    
                    <!-- Status Badge -->
                    <span class="px-3 py-1 rounded-full text-sm font-medium 
                        <%= isDraft ? 'bg-blue-100 text-blue-800' : 
                           isPendingApproval ? 'bg-yellow-100 text-yellow-800' :
                           isChangesRequested ? 'bg-orange-100 text-orange-800' :
                           isApproved ? 'bg-green-100 text-green-800' :
                           isPublished ? 'bg-purple-100 text-purple-800' :
                           'bg-red-100 text-red-800' %>">
                        <%= property.status ? property.status.replace('_', ' ') : 'draft' %>
                    </span>
                </div>
            </div>
            
            <!-- Commission Info Box (Broker Only) -->
            <div class="mt-4 p-4 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg shadow-sm">
                <div class="flex flex-col md:flex-row md:items-center justify-between">
                    <div>
                        <h3 class="font-bold text-blue-800 text-lg mb-1">
                            <i class="fas fa-money-bill-wave mr-2"></i>
                            Broker Commission Info
                        </h3>
                        <div class="space-y-1">
                            <p class="text-blue-700">
                                <i class="fas fa-percentage mr-2"></i>
                                Commission Rate: <strong><%= (brokerInfo.commission_rate * 100) || 1 %>%</strong>
                            </p>
                            <p class="text-blue-700">
                                <i class="fas fa-rupee-sign mr-2"></i>
                                Potential Commission: <strong>₹<%= commissionAmount.toLocaleString('en-IN') %></strong>
                                (on ₹<%= property.price?.toLocaleString('en-IN') || '0' %>)
                            </p>
                            <% if (brokerInfo.agreement_type) { %>
                            <p class="text-blue-700">
                                <i class="fas fa-file-contract mr-2"></i>
                                Agreement: <%= brokerInfo.agreement_type.replace('_', ' ') %>
                            </p>
                            <% } %>
                        </div>
                    </div>
                    <div class="mt-4 md:mt-0 text-right">
                        <div class="bg-white p-3 rounded-lg border border-blue-200 inline-block">
                            <p class="text-sm text-gray-600">Added by</p>
                            <p class="font-medium text-blue-900">
                                <i class="fas fa-user-tie mr-2"></i>
                                <%= broker.name %>
                            </p>
                            <p class="text-xs text-gray-500">Broker ID: <%= broker.broker_id %></p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Seller Info Box (Broker Only) -->
            <% if (sellerInfo.name) { %>
            <div class="mt-4 p-4 bg-gradient-to-r from-gray-50 to-gray-100 border border-gray-300 rounded-lg">
                <h3 class="font-bold text-gray-800 text-lg mb-2">
                    <i class="fas fa-user mr-2"></i>
                    Seller Information
                </h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div>
                        <p class="text-sm text-gray-600">Seller Name</p>
                        <p class="font-medium text-gray-900"><%= sellerInfo.name %></p>
                    </div>
                    <% if (sellerInfo.phone) { %>
                    <div>
                        <p class="text-sm text-gray-600">Phone</p>
                        <p class="font-medium text-gray-900">
                            <i class="fas fa-phone-alt mr-2 text-gray-500"></i>
                            <%= sellerInfo.phone %>
                        </p>
                    </div>
                    <% } %>
                    <% if (sellerInfo.email) { %>
                    <div>
                        <p class="text-sm text-gray-600">Email</p>
                        <p class="font-medium text-gray-900">
                            <i class="fas fa-envelope mr-2 text-gray-500"></i>
                            <%= sellerInfo.email %>
                        </p>
                    </div>
                    <% } %>
                </div>
                <% if (canEditField('seller_info')) { %>
                <div class="mt-3 pt-3 border-t border-gray-300">
                    <button type="button" onclick="showSellerEditModal()" 
                            class="text-blue-600 hover:text-blue-800 text-sm">
                        <i class="fas fa-edit mr-1"></i> Update Seller Information
                    </button>
                </div>
                <% } %>
            </div>
            <% } %>
            
            <!-- ✅ ADMIN CHANGES REQUESTED BANNER -->
            <% if (isChangesRequested && property.admin_review?.remark) { %>
            <div class="mt-4 p-4 bg-gradient-to-r from-yellow-50 to-orange-50 border border-yellow-300 rounded-lg shadow-sm">
                <div class="flex items-start">
                    <i class="fas fa-exclamation-circle text-yellow-600 text-xl mr-3 mt-1"></i>
                    <div class="flex-1">
                        <h3 class="font-bold text-yellow-800 text-lg mb-1">
                            Admin Requested Changes
                        </h3>
                        <div class="bg-white p-3 rounded-lg border border-yellow-200 mb-3">
                            <p class="text-gray-800">
                                <i class="fas fa-comment-alt text-gray-400 mr-2"></i>
                                <%= property.admin_review.remark %>
                            </p>
                        </div>
                        
                        <% if (deadlineInfo) { %>
                        <div class="flex flex-wrap items-center justify-between">
                            <div class="flex items-center">
                                <i class="fas fa-clock text-yellow-600 mr-2"></i>
                                <span class="text-yellow-700 font-medium">
                                    Deadline: <%= deadlineInfo.date.toLocaleDateString() %>
                                    <% if (deadlineInfo.isUrgent) { %>
                                    <span class="bg-red-600 text-white px-2 py-1 rounded-full text-xs font-bold ml-2">
                                        <i class="fas fa-fire mr-1"></i>URGENT: <%= deadlineInfo.daysLeft %> day<%= deadlineInfo.daysLeft === 1 ? '' : 's' %> left
                                    </span>
                                    <% } else { %>
                                    <span class="text-sm font-normal">(<%= deadlineInfo.daysLeft %> days left)</span>
                                    <% } %>
                                </span>
                            </div>
                            <div class="mt-2 md:mt-0">
                                <span class="text-sm <%= canEdit ? 'text-green-600' : 'text-red-600' %> font-medium">
                                    <i class="fas fa-edit mr-1"></i>
                                    <%= canEditAll ? 'You can edit all fields' : 
                                       canEditLimited ? 'You can edit specific fields only' : 
                                       'Contact admin for edit permissions' %>
                                </span>
                            </div>
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
            <% } %>
            
            <!-- ✅ EDIT PERMISSIONS INFORMATION -->
            <% if (editPermissions.enabled && editExpiryInfo) { %>
            <div class="mt-4 p-3 <%= canEditAll ? 'bg-blue-50 border-blue-200' : 'bg-green-50 border-green-200' %> border rounded-lg">
                <div class="flex items-center">
                    <i class="fas <%= canEditAll ? 'fa-unlock text-blue-600' : 'fa-filter text-green-600' %> mr-2"></i>
                    <div>
                        <p class="text-sm <%= canEditAll ? 'text-blue-800' : 'text-green-800' %> font-medium">
                            <strong><%= canEditAll ? 'Full edit access' : 'Limited edit access' %> granted</strong>
                            <% if (canEditLimited && allowedFields.length > 0) { %>
                            — You can edit: <span class="font-semibold"><%= allowedFields.map(f => f.replace('_', ' ')).join(', ') %></span>
                            <% } %>
                        </p>
                        <p class="text-sm <%= canEditAll ? 'text-blue-700' : 'text-green-700' %> mt-1">
                            Access until: <span class="font-bold"><%= editExpiryInfo.date.toLocaleString() %></span>
                            <% if (editExpiryInfo.isExpiringSoon) { %>
                            <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded text-xs font-bold ml-2">
                                <i class="fas fa-clock mr-1"></i>Expires in <%= editExpiryInfo.hoursLeft %> hours
                            </span>
                            <% } %>
                        </p>
                    </div>
                </div>
            </div>
            <% } else if (isDraft) { %>
            <div class="mt-4 p-3 bg-blue-50 border border-blue-200 rounded-lg">
                <div class="flex items-center">
                    <i class="fas fa-pencil-alt text-blue-600 mr-2"></i>
                    <p class="text-sm text-blue-800">
                        <strong>Draft Mode</strong> — You have full edit access. Submit when ready for admin approval.
                    </p>
                </div>
            </div>
            <% } else if (!canEdit && isPendingApproval) { %>
            <div class="mt-4 p-3 bg-gray-100 border border-gray-300 rounded-lg">
                <div class="flex items-center">
                    <i class="fas fa-lock text-gray-500 mr-2"></i>
                    <p class="text-sm text-gray-700">
                        <strong>Property is under admin review</strong> — Editing is locked. 
                        If you need to make changes, 
                        <button onclick="requestEditAccess('<%= property._id %>')" class="text-blue-600 hover:underline font-medium">
                            request edit access from admin
                        </button>.
                    </p>
                </div>
            </div>
            <% } %>
            
            <!-- ✅ FIELD EDIT STATUS SUMMARY -->
            <% if (canEditLimited && allowedFields.length > 0) { %>
            <div class="mt-4 p-3 bg-gray-50 border border-gray-200 rounded-lg">
                <p class="text-sm text-gray-700 mb-2">
                    <i class="fas fa-info-circle text-gray-500 mr-1"></i>
                    <span class="font-medium"><%= allowedFields.length %></span> fields are editable, 
                    others are read-only
                </p>
                <div class="flex flex-wrap gap-2">
                    <% 
                    const allFieldNames = [
                        'title', 'description', 'short_description', 'price', 'price_type', 'bedrooms', 
                        'bathrooms', 'balconies', 'built_up_area', 'carpet_area', 'area_unit', 'furnishing', 
                        'property_type', 'sub_type', 'ownership', 'floor_number', 'total_floors', 'age_of_property',
                        'facing', 'parking', 'amenities', 'images', 'contact_name', 
                        'contact_phone', 'contact_email', 'address.street', 'address.landmark', 'address.city',
                        'address.areas', 'address.state', 'address.pincode'
                    ];
                    
                    allFieldNames.forEach(field => {
                        const isEditable = canEditField(field);
                    %>
                    <span class="text-xs px-2 py-1 rounded <%= isEditable ? 'bg-green-100 text-green-800' : 'bg-gray-200 text-gray-600' %>">
                        <%= field.replace('_', ' ').replace('.', ' - ') %>
                        <% if (isEditable) { %>
                        <i class="fas fa-check ml-1"></i>
                        <% } else { %>
                        <i class="fas fa-lock ml-1"></i>
                        <% } %>
                    </span>
                    <% }); %>
                </div>
            </div>
            <% } %>
        </div>

        <!-- Edit Form -->
        <form id="editForm" class="bg-white rounded-xl shadow p-6" enctype="multipart/form-data">
            <!-- Basic Information -->
            <div class="space-y-6 mb-8">
                <div class="flex items-center justify-between border-b pb-2">
                    <h2 class="text-xl font-bold text-gray-900">Basic Information</h2>
                    <span class="text-sm text-gray-500">
                        <%= canEditField('title') || canEditField('description') || canEditField('short_description') ? 'Editable' : 'Read-only' %>
                    </span>
                </div>
                
                <!-- Property Title -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">
                        Property Title
                        <% if (canEditField('title')) { %>
                        <span class="editable-badge">Editable</span>
                        <% } else { %>
                        <span class="readonly-badge">Read-only</span>
                        <% } %>
                    </label>
                    <input type="text" name="title" value="<%= property.title %>"
                           <%= canEditField('title') ? '' : 'disabled readonly' %>
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg 
                                  <%= canEditField('title') ? 'field-enabled' : 'field-disabled' %>"
                           placeholder="e.g., Luxury 3BHK Apartment in Prime Location">
                </div>

                <!-- Property Type & Sub Type -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Property Type
                            <% if (canEditField('property_type')) { %>
                            <span class="editable-badge">Editable</span>
                            <% } else { %>
                            <span class="readonly-badge">Read-only</span>
                            <% } %>
                        </label>
                        <select name="property_type" id="propertyTypeSelect"
                                <%= canEditField('property_type') ? '' : 'disabled' %>
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg 
                                       <%= canEditField('property_type') ? 'field-enabled' : 'field-disabled' %>">
                            <option value="">Select Type</option>
                            <option value="Residential" <%= property.property_type === 'Residential' ? 'selected' : '' %>>Residential</option>
                            <option value="Commercial" <%= property.property_type === 'Commercial' ? 'selected' : '' %>>Commercial</option>
                            <option value="Plot" <%= property.property_type === 'Plot' ? 'selected' : '' %>>Plot</option>
                            <option value="Agricultural" <%= property.property_type === 'Agricultural' ? 'selected' : '' %>>Agricultural</option>
                            <option value="Industrial" <%= property.property_type === 'Industrial' ? 'selected' : '' %>>Industrial</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">
                            Sub Type
                            <% if (canEditField('sub_type')) { %>
                            <span class="editable-badge">Editable</span>
                            <% } else { %>
                            <span class="readonly-badge">Read-only</span>
                            <% } %>
                        </label>
                        <select name="sub_type" id="subTypeSelect"
                                <%= canEditField('sub_type') ? '' : 'disabled' %>
                                class="w-full px-4 py-2 border border-gray-300 rounded-lg 
                                       <%= canEditField('sub_type') ? 'field-enabled' : 'field-disabled' %>">
                            <option value="">Select Sub Type</option>
                            <% if (property.property_type && propertyTypes[property.property_type]) { 
                                propertyTypes[property.property_type].forEach(subType => { %>
                                <option value="<%= subType %>" <%= property.sub_type === subType ? 'selected' : '' %>><%= subType %></option>
