                        <% if (brokerInfo.agreement_date) { %>
                        <div>
                            <p class="text-sm text-gray-600">Agreement Date</p>
                            <p class="font-medium text-gray-800">
                                <%= new Date(brokerInfo.agreement_date).toLocaleDateString() %>
                            </p>
