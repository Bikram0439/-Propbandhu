                            </label>
                            
                            <!-- Security Amenities -->
                            <label class="flex items-center space-x-2 <%= canEditField('amenities') ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                                <input type="checkbox" name="amenities" value="24/7 Security"
                                       <%= property.amenities && property.amenities.includes('24/7 Security') ? 'checked' : '' %>
                                       <%= canEditField('amenities') ? '' : 'disabled' %>
                                       class="rounded text-blue-600 focus:ring-blue-500">
                                <span class="text-sm <%= canEditField('amenities') ? 'text-gray-700' : 'text-gray-400' %>">24/7 Security</span>
                            </label>
                            <label class="flex items-center space-x-2 <%= canEditField('amenities') ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                                <input type="checkbox" name="amenities" value="CCTV Surveillance"
                                       <%= property.amenities && property.amenities.includes('CCTV Surveillance') ? 'checked' : '' %>
                                       <%= canEditField('amenities') ? '' : 'disabled' %>
                                       class="rounded text-blue-600 focus:ring-blue-500">
                                <span class="text-sm <%= canEditField('amenities') ? 'text-gray-700' : 'text-gray-400' %>">CCTV Surveillance</span>
                            </label>
                            <label class="flex items-center space-x-2 <%= canEditField('amenities') ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                                <input type="checkbox" name="amenities" value="Security Guard"
                                       <%= property.amenities && property.amenities.includes('Security Guard') ? 'checked' : '' %>
                                       <%= canEditField('amenities') ? '' : 'disabled' %>
