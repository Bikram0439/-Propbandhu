<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu Broker</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .document-icon { font-size: 1.5rem; margin-right: 0.75rem; }
        .pdf-icon { color: #ef4444; }
        .doc-icon { color: #2563eb; }
        .image-icon { color: #10b981; }
        .file-icon { color: #6b7280; }
        
        .status-badge {
            display: inline-block;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
        }
        
        .status-pending_approval { background-color: #fef3c7; color: #92400e; }
        .status-approved { background-color: #d1fae5; color: #065f46; }
        .status-live { background-color: #dbeafe; color: #1e40af; }
        .status-changes_requested { background-color: #fee2e2; color: #991b1b; }
        
        .action-btn {
            display: inline-flex;
            align-items: center;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            font-weight: 500;
            font-size: 0.875rem;
            transition: all 0.2s ease;
            border: none;
            cursor: pointer;
        }
        
        .view-btn { background-color: #3b82f6; color: white; }
        .view-btn:hover { background-color: #2563eb; transform: translateY(-1px); }
        
        .delete-btn { background-color: #ef4444; color: white; }
        .delete-btn:hover { background-color: #dc2626; transform: translateY(-1px); }
        
        .upload-area {
            border: 2px dashed #cbd5e0;
            border-radius: 0.75rem;
            padding: 2rem;
            text-align: center;
            background: #f8fafc;
            transition: all 0.3s ease;
        }
        
        .upload-area:hover { border-color: #3b82f6; background: #eff6ff; }
        
        .nav-link {
            color: #4b5563;
            font-weight: 500;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
        }
        
        .nav-link:hover { color: #1f2937; background-color: #f3f4f6; }
        .nav-link.active { color: #3b82f6; background-color: #eff6ff; }
        
        /* Spinner animation */
        .fa-spinner {
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Broker Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/broker/dashboard" class="flex items-center">
                        <span class="text-xl font-bold text-gray-900">Propbandhu Broker</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-gray-700 font-medium">🤝 Broker: <%= user.name %></span>
                    <a href="/broker/dashboard" class="nav-link">
                        <i class="fas fa-tachometer-alt mr-1"></i>Dashboard
                    </a>
                    <a href="/broker/properties" class="nav-link">
                        <i class="fas fa-home mr-1"></i>Properties
                    </a>
                    <a href="/broker/documents" class="nav-link active">
                        <i class="fas fa-file-alt mr-1"></i>Documents
                    </a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600">
                        <i class="fas fa-sign-out-alt mr-1"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Property Documents</h1>
            <p class="text-gray-600 mt-2">Upload and manage documents for your broker properties</p>
            
            <!-- REMOVED TEST BUTTON - NO CHANGES TO JAVASCRIPT FUNCTIONS -->
        </div>

        <% 
            // CHANGE 1: Filter to show only properties added by this broker
            // Keep the original properties array but filter it
            const brokerAddedProperties = properties.filter(property => property.isAddedByBroker);
        %>
        
        <% if (brokerAddedProperties.length === 0) { %>
            <div class="bg-white rounded-xl shadow-lg p-12 text-center">
                <i class="fas fa-file-upload text-gray-300 text-6xl mb-4"></i>
                <h3 class="text-xl font-semibold text-gray-700 mb-2">No properties found</h3>
                <p class="text-gray-600 mb-6">You haven't added any properties yet</p>
                <a href="/broker/properties" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700">
                    <i class="fas fa-list mr-2"></i>View Properties
                </a>
            </div>
        <% } else { %>
            <div class="space-y-6">
                <!-- CHANGE 1: Loop through filtered properties instead of all properties -->
                <% brokerAddedProperties.forEach(property => { %>
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                    <div class="p-6">
                        <!-- Property Header -->
                        <div class="flex flex-col md:flex-row md:items-center justify-between mb-6">
                            <div class="mb-4 md:mb-0">
                                <div class="flex items-center mb-2">
                                    <h3 class="text-xl font-bold text-gray-900 mr-3"><%= property.title %></h3>
                                    <span class="status-badge status-<%= property.status || 'pending_approval' %>">
                                        <%= property.status || 'pending_approval' %>
                                    </span>
                                </div>
                                <div class="flex items-center text-gray-600 text-sm">
                                    <i class="fas fa-map-marker-alt mr-2"></i>
                                    <span><%= property.location || 'No location' %></span>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-sm text-gray-500 mb-1">Documents</div>
                                <div class="text-2xl font-bold text-blue-600">
                                    <%= property.documents ? property.documents.length : 0 %>
                                </div>
                            </div>
                        </div>

                        <!-- Upload Document Form -->
                        <div class="mb-8">
                            <h4 class="font-bold text-gray-700 mb-3">Upload New Document</h4>
                            <div class="bg-gray-50 rounded-xl p-4">
                                <div class="grid grid-cols-1 md:grid-cols-12 gap-3">
                                    <div class="md:col-span-4">
                                        <input type="text" 
                                               id="name-<%= property._id %>"
                                               placeholder="Document name*" 
                                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                               required>
                                    </div>
                                    <div class="md:col-span-3">
                                        <select id="type-<%= property._id %>" 
                                                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent bg-white"
                                                required>
                                            <option value="">Document type*</option>
                                            <option value="ownership">Ownership Proof</option>
                                            <option value="tax">Tax Receipts</option>
                                            <option value="approval">Approval Docs</option>
                                            <option value="floor_plan">Floor Plan</option>
                                            <option value="legal">Legal Docs</option>
                                            <option value="broker_agreement">Broker Agreement</option>
                                            <option value="commission_agreement">Commission Agreement</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="md:col-span-3">
                                        <input type="file" 
                                               id="file-<%= property._id %>"
                                               name="document"
                                               accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"
                                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                               required>
                                        <div id="file-name-<%= property._id %>" class="text-xs text-gray-500 mt-1">No file selected</div>
                                    </div>
                                    <div class="md:col-span-2">
                                        <button type="button" 
                                                onclick="uploadDocumentForProperty('<%= property._id %>')"
                                                id="upload-btn-<%= property._id %>"
                                                class="w-full bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-700 transition">
                                            <i class="fas fa-upload mr-2"></i>Upload
                                        </button>
                                    </div>
                                </div>
                                <div id="upload-status-<%= property._id %>" class="mt-2 text-sm"></div>
                                <p class="text-xs text-gray-500 mt-2">
                                    <i class="fas fa-info-circle mr-1"></i>
                                    Max file size: 10MB • Allowed: PDF, DOC, DOCX, JPG, PNG
                                </p>
                            </div>
                        </div>

                        <!-- Documents List -->
                        <% if (property.documents && property.documents.length > 0) { %>
                        <div>
                            <h4 class="font-bold text-gray-700 mb-3">Uploaded Documents</h4>
                            <div class="space-y-3">
                                <% property.documents.forEach((doc, index) => { 
                                    let iconClass = 'fas fa-file';
                                    let iconColor = 'text-gray-500';
                                    let typeLabel = 'Other';
                                    
                                    // Map document type to label
                                    const typeMap = {
                                        'ownership': 'Ownership Proof',
                                        'tax': 'Tax Receipt',
                                        'approval': 'Approval Doc',
                                        'floor_plan': 'Floor Plan',
                                        'legal': 'Legal Doc',
                                        'broker_agreement': 'Broker Agreement',
                                        'commission_agreement': 'Commission Agreement',
                                        'other': 'Other'
                                    };
                                    typeLabel = typeMap[doc.type] || doc.type;
                                    
                                    // File icon
                                    if (doc.original_name) {
                                        if (doc.original_name.toLowerCase().endsWith('.pdf')) {
                                            iconClass = 'fas fa-file-pdf';
                                            iconColor = 'text-red-500';
                                        } else if (doc.original_name.toLowerCase().endsWith('.doc') || doc.original_name.toLowerCase().endsWith('.docx')) {
                                            iconClass = 'fas fa-file-word';
                                            iconColor = 'text-blue-500';
                                        } else if (doc.original_name.toLowerCase().endsWith('.jpg') || doc.original_name.toLowerCase().endsWith('.jpeg') || doc.original_name.toLowerCase().endsWith('.png')) {
                                            iconClass = 'fas fa-file-image';
                                            iconColor = 'text-green-500';
                                        }
                                    }
                                    
                                    // File size
                                    let fileSize = 'N/A';
                                    if (doc.size) {
                                        if (doc.size < 1024) {
                                            fileSize = doc.size + ' B';
                                        } else if (doc.size < 1024 * 1024) {
                                            fileSize = Math.round(doc.size / 1024) + ' KB';
                                        } else {
                                            fileSize = (doc.size / (1024 * 1024)).toFixed(2) + ' MB';
                                        }
                                    }
                                %>
                                <div class="flex items-center justify-between p-3 bg-gray-50 rounded-lg">
                                    <div class="flex items-center flex-1 min-w-0">
                                        <i class="<%= iconClass %> <%= iconColor %> mr-3 text-lg"></i>
                                        <div class="flex-1 min-w-0">
                                            <p class="font-medium text-gray-900 truncate">
                                                <a href="/broker/documents/view/<%= property._id %>/<%= index %>" 
                                                   class="text-blue-600 hover:text-blue-900 hover:underline">
                                                    <%= doc.name %>
                                                </a>
                                            </p>
                                            <div class="flex items-center space-x-3 text-sm text-gray-600">
                                                <span><%= doc.original_name || 'Document' %></span>
                                                <span>•</span>
                                                <span><%= fileSize %></span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex space-x-2 ml-4">
                                        <a href="/broker/documents/view/<%= property._id %>/<%= index %>" 
                                           class="action-btn view-btn">
                                            <i class="fas fa-eye mr-2"></i>View
                                        </a>
                                        <a href="/broker/documents/download/<%= property._id %>/<%= index %>" 
   target="_blank"
   class="action-btn view-btn">
  <i class="fas fa-download mr-2"></i>Download
</a>

                                        <button onclick="deleteDocumentFromProperty('<%= property._id %>', '<%= index %>')" 
                                                class="action-btn delete-btn">
                                            <i class="fas fa-trash mr-2"></i>Delete
                                        </button>
                                    </div>
                                </div>
                                <% }); %>
                            </div>
                        </div>
                        <% } else { %>
                        <div class="upload-area">
                            <i class="fas fa-file-upload text-gray-300 text-4xl mb-3"></i>
                            <p class="text-gray-600 font-medium mb-2">No documents uploaded yet</p>
                            <p class="text-sm text-gray-500">Upload documents to make this property listing more credible</p>
                        </div>
                        <% } %>
                    </div>
                </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <!-- SIMPLE JAVASCRIPT - PLACE THIS BEFORE CLOSING BODY TAG -->
    <script>
        // ==================== TEST FUNCTION ====================
        window.testFunction = function() {
            console.log('✅ Test button clicked! JavaScript is working.');
            alert('✅ JavaScript is working! Check console for logs.');
        }
        
        // ==================== FILE NAME DISPLAY ====================
        window.updateFileName = function(propertyId) {
            const fileInput = document.getElementById('file-' + propertyId);
            const fileNameDisplay = document.getElementById('file-name-' + propertyId);
            
            if (fileInput && fileInput.files.length > 0) {
                const file = fileInput.files[0];
                const fileSize = file.size < 1024 * 1024 
                    ? Math.round(file.size / 1024) + ' KB' 
                    : (file.size / (1024 * 1024)).toFixed(2) + ' MB';
                
                fileNameDisplay.textContent = file.name + ' (' + fileSize + ')';
                fileNameDisplay.className = 'text-xs text-green-600 mt-1';
            } else if (fileNameDisplay) {
                fileNameDisplay.textContent = 'No file selected';
                fileNameDisplay.className = 'text-xs text-gray-500 mt-1';
            }
        }
        
        // ==================== UPLOAD FUNCTION ====================
        window.uploadDocumentForProperty = async function(propertyId) {
            console.log('🚀 UPLOAD FUNCTION CALLED for property:', propertyId);
            
            // Get form elements
            const nameInput = document.getElementById('name-' + propertyId);
            const typeInput = document.getElementById('type-' + propertyId);
            const fileInput = document.getElementById('file-' + propertyId);
            const uploadBtn = document.getElementById('upload-btn-' + propertyId);
            
            // Validate inputs
            if (!nameInput || !nameInput.value.trim()) {
                alert('⚠️ Please enter document name');
                nameInput?.focus();
                return;
            }
            
            if (!typeInput || !typeInput.value) {
                alert('⚠️ Please select document type');
                typeInput?.focus();
                return;
            }
            
            if (!fileInput || !fileInput.files || fileInput.files.length === 0) {
                alert('⚠️ Please select a file to upload');
                return;
            }
            
            const file = fileInput.files[0];
            console.log('📄 File selected:', file.name, 'Size:', file.size);
            
            // Check file size (10MB limit)
            if (file.size > 10 * 1024 * 1024) {
                alert('❌ File size exceeds 10MB limit');
                return;
            }
            
            // Create FormData
            const formData = new FormData();
            formData.append('name', nameInput.value.trim());
            formData.append('type', typeInput.value);
            formData.append('document', file);
            
            // Show loading state
            if (uploadBtn) {
                const originalText = uploadBtn.innerHTML;
                uploadBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i>Uploading...';
                uploadBtn.disabled = true;
                
                try {
                    console.log('📤 Sending upload request...');
                    
                    // Send request
                    const response = await fetch('/broker/api/properties/' + propertyId + '/documents/upload', {
                        method: 'POST',
                        body: formData
                    });
                    
                    console.log('📥 Response status:', response.status);
                    const data = await response.json();
                    console.log('📦 Response data:', data);
                    
                    if (data.success) {
                        alert('✅ Document uploaded successfully!');
                        
                        // Clear form
                        nameInput.value = '';
                        typeInput.value = '';
                        fileInput.value = '';
                        updateFileName(propertyId);
                        
                        // Reload page
                        setTimeout(() => {
                            window.location.reload();
                        }, 1000);
                    } else {
                        alert('❌ Upload failed: ' + (data.message || 'Unknown error'));
                    }
                } catch (error) {
                    console.error('❌ Upload error:', error);
                    alert('❌ Network error. Please try again.');
                } finally {
                    // Reset button
                    uploadBtn.innerHTML = originalText;
                    uploadBtn.disabled = false;
                }
            }
        }
        
        // ==================== DELETE FUNCTION ====================
        window.deleteDocumentFromProperty = async function(propertyId, docIndex) {
            console.log('🗑️ DELETE FUNCTION CALLED:', propertyId, docIndex);
            
            if (!confirm('Are you sure you want to delete this document?\nThis action cannot be undone.')) {
                return;
            }
            
            try {
                console.log('📤 Sending delete request...');
                
                const response = await fetch('/broker/api/properties/' + propertyId + '/documents/' + docIndex, {
                    method: 'DELETE'
                });
                
                console.log('📥 Response status:', response.status);
                const data = await response.json();
                console.log('📦 Response data:', data);
                
                if (data.success) {
                    alert('✅ Document deleted successfully!');
                    setTimeout(() => {
                        window.location.reload();
                    }, 1000);
                } else {
                    alert('❌ Delete failed: ' + (data.message || 'Unknown error'));
                }
            } catch (error) {
                console.error('❌ Delete error:', error);
                alert('❌ Network error. Please try again.');
            }
        }
        
        // ==================== INITIALIZE ====================
        document.addEventListener('DOMContentLoaded', function() {
            console.log('📄 Page loaded, JavaScript is ready!');
            
            // Set up file input change listeners
            <% if (properties) { %>
                <% properties.forEach(property => { %>
                    const fileInput<%= property._id %> = document.getElementById('file-<%= property._id %>');
                    if (fileInput<%= property._id %>) {
                        fileInput<%= property._id %>.addEventListener('change', function() {
                            updateFileName('<%= property._id %>');
                        });
                    }
                <% }); %>
            <% } %>
        });
    </script>
</body>
</html>