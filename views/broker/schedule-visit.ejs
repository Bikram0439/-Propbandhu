<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Propbandhu Broker</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-gray-50">
    <!-- Broker Navigation -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <a href="/broker/dashboard" class="flex items-center">
                        <span class="text-xl font-bold text-gray-900">Propbandhu Broker</span>
                    </a>
                </div>
                <div class="flex items-center space-x-4">
                    <span class="text-gray-700 font-medium">🤝 Broker: <%= user.name %></span>
                    <a href="/broker/dashboard" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-tachometer-alt mr-1"></i>Dashboard
                    </a>
                    <a href="/broker/properties" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-home mr-1"></i>Properties
                    </a>
                    <a href="/broker/visits" class="text-gray-600 hover:text-blue-600 font-semibold text-blue-600">
                        <i class="fas fa-calendar-day mr-1"></i>Visits
                    </a>
                    <a href="/broker/commissions" class="text-gray-600 hover:text-blue-600">
                        <i class="fas fa-money-bill-wave mr-1"></i>Commissions
                    </a>
                    <a href="/logout" class="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600">
                        <i class="fas fa-sign-out-alt mr-1"></i>Logout
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <!-- Page Header -->
        <div class="mb-8">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-3xl font-bold text-gray-900">Schedule Property Visit</h1>
                    <p class="text-gray-600 mt-2">Coordinate and schedule a visit between buyer and seller</p>
                </div>
                <a href="/broker/visits" class="text-gray-600 hover:text-gray-900">
                    <i class="fas fa-arrow-left mr-2"></i>Back to Visits
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Schedule Form - Left Column -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                    <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-6 py-4">
                        <h2 class="text-xl font-bold text-white flex items-center">
                            <i class="fas fa-home mr-3"></i>
                            Property Details
                        </h2>
                    </div>
                    
                    <div class="p-6">
                        <!-- Property Info Card -->
                        <div class="bg-gray-50 rounded-lg p-4 mb-6">
                            <div class="flex items-start">
                                <% if (property.images && property.images.length > 0) { %>
                                <img src="<%= property.images[0].url %>" 
                                     alt="<%= property.title %>" 
                                     class="w-32 h-32 object-cover rounded-lg mr-4 border-2 border-white shadow-md">
                                <% } else { %>
                                <div class="w-32 h-32 bg-gradient-to-br from-gray-200 to-gray-300 rounded-lg mr-4 flex items-center justify-center border-2 border-white shadow-md">
                                    <i class="fas fa-home text-gray-400 text-4xl"></i>
                                </div>
                                <% } %>
                                
                                <div class="flex-1">
                                    <h3 class="text-xl font-bold text-gray-900 mb-2"><%= property.title %></h3>
                                    
                                    <div class="grid grid-cols-2 gap-4">
                                        <div>
                                            <p class="text-sm text-gray-500 mb-1">
                                                <i class="fas fa-map-marker-alt text-blue-500 w-4 mr-1"></i>Location
                                            </p>
                                            <p class="font-medium text-gray-800">
                                                <%= property.address?.area || property.address?.street || 'Location' %>, 
                                                <%= property.address?.city || 'Not specified' %>
                                            </p>
                                        </div>
                                        <div>
                                            <p class="text-sm text-gray-500 mb-1">
                                                <i class="fas fa-tag text-green-500 w-4 mr-1"></i>Price
                                            </p>
                                            <p class="text-2xl font-bold text-blue-600">
                                                <%= property.formatted_price %>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Urgency Alert -->
                        <% if (daysLeft <= 3) { %>
                        <div class="bg-orange-50 border-l-4 border-orange-500 p-4 mb-6">
                            <div class="flex">
                                <div class="flex-shrink-0">
                                    <i class="fas fa-exclamation-triangle text-orange-500 text-xl"></i>
                                </div>
                                <div class="ml-3">
                                    <h3 class="text-sm font-medium text-orange-800">Limited Time Remaining</h3>
                                    <p class="text-sm text-orange-700 mt-1">
                                        Only <span class="font-bold"><%= daysLeft %> day<%= daysLeft !== 1 ? 's' : '' %></span> left to schedule this visit.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <% } %>

                        <!-- Cart Timeline -->
                        <% if (cartItem) { 
                            const displayDate = cartItem.updatedAt || cartItem.added_at;
                            const addedDate = new Date(displayDate);
                            const expiryDate = new Date(addedDate);
                            expiryDate.setDate(expiryDate.getDate() + 7);
                            const calculatedDaysLeft = Math.ceil((expiryDate - new Date()) / (1000 * 60 * 60 * 24));
                        %>
                        <div class="bg-blue-50 rounded-lg p-4 mb-6">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <i class="fas fa-clock text-blue-600 text-xl mr-3"></i>
                                    <div>
                                        <p class="text-sm text-blue-800">Added to cart</p>
                                        <p class="font-semibold text-blue-900">
                                            <%= new Date(displayDate).toLocaleString('en-IN', {
                                                day: '2-digit',
                                                month: 'short',
                                                year: 'numeric'
                                            }) %>
                                        </p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm text-blue-800">Days remaining</p>
                                    <p class="font-bold text-2xl text-blue-600"><%= calculatedDaysLeft %>/7</p>
                                </div>
                            </div>
                        </div>
                        <% } %>

                        <!-- Buyer Information -->
                        <div class="bg-green-50 rounded-lg p-4 mb-6">
                            <div class="flex items-center mb-3">
                                <i class="fas fa-user text-green-600 text-xl mr-2"></i>
                                <h3 class="font-semibold text-green-900">Buyer Information</h3>
                            </div>
                            
                            <% if (buyer) { %>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div class="flex items-start">
                                    <i class="fas fa-user-circle text-green-600 mt-1 mr-2"></i>
                                    <div>
                                        <p class="text-sm text-green-700">Name</p>
                                        <p class="font-medium text-green-900"><%= buyer.name %></p>
                                    </div>
                                </div>
                                <div class="flex items-start">
                                    <i class="fas fa-phone text-green-600 mt-1 mr-2"></i>
                                    <div>
                                        <p class="text-sm text-green-700">Phone</p>
                                        <p class="font-medium text-green-900"><%= buyer.phone || 'Not provided' %></p>
                                    </div>
                                </div>
                                <% if (buyer.email) { %>
                                <div class="flex items-start md:col-span-2">
                                    <i class="fas fa-envelope text-green-600 mt-1 mr-2"></i>
                                    <div>
                                        <p class="text-sm text-green-700">Email</p>
                                        <p class="font-medium text-green-900"><%= buyer.email %></p>
                                    </div>
                                </div>
                                <% } %>
                            </div>
                            <% } %>
                        </div>

                        <!-- Schedule Form -->
                        <form id="scheduleVisitForm" data-property-id="<%= property._id %>">
                            <div class="space-y-6">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label for="visitDate" class="block text-sm font-medium text-gray-700 mb-2">
                                            <i class="fas fa-calendar-alt text-blue-500 mr-1"></i>
                                            Visit Date <span class="text-red-500">*</span>
                                        </label>
                                        <input type="date" 
                                               id="visitDate" 
                                               name="visitDate" 
                                               required
                                               min="<%= new Date(new Date().setDate(new Date().getDate() + 1)).toISOString().split('T')[0] %>"
                                               max="<%= visitExpiry.toISOString().split('T')[0] %>"
                                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500 mt-1">
                                            Must be scheduled by: <%= visitExpiry.toLocaleDateString('en-IN') %>
                                        </p>
                                    </div>

                                    <div>
                                        <label for="visitTime" class="block text-sm font-medium text-gray-700 mb-2">
                                            <i class="fas fa-clock text-blue-500 mr-1"></i>
                                            Visit Time <span class="text-red-500">*</span>
                                        </label>
                                        <input type="time" 
                                               id="visitTime" 
                                               name="visitTime" 
                                               required
                                               min="09:00"
                                               max="18:00"
                                               value="10:00"
                                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500 mt-1">Available: 9:00 AM - 6:00 PM</p>
                                    </div>
                                </div>

                                <div>
                                    <label for="notes" class="block text-sm font-medium text-gray-700 mb-2">
                                        <i class="fas fa-sticky-note text-blue-500 mr-1"></i>
                                        Visit Notes (Optional)
                                    </label>
                                    <textarea id="notes" 
                                              name="notes" 
                                              rows="3"
                                              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                                              placeholder="Add any special instructions, meeting point details, or notes for the buyer..."></textarea>
                                </div>

                                <!-- Seller Information -->
                                <div class="bg-purple-50 rounded-lg p-4">
                                    <div class="flex items-center mb-3">
                                        <i class="fas fa-user-tie text-purple-600 text-xl mr-2"></i>
                                        <h3 class="font-semibold text-purple-900">Seller Contact Information</h3>
                                    </div>
                                    
                                    <% if (property.seller) { %>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        <div class="flex items-start">
                                            <i class="fas fa-user-circle text-purple-600 mt-1 mr-2"></i>
                                            <div>
                                                <p class="text-sm text-purple-700">Name</p>
                                                <p class="font-medium text-purple-900"><%= property.seller.name %></p>
                                            </div>
                                        </div>
                                        <div class="flex items-start">
                                            <i class="fas fa-phone text-purple-600 mt-1 mr-2"></i>
                                            <div>
                                                <p class="text-sm text-purple-700">Phone</p>
                                                <p class="font-medium text-purple-900"><%= property.seller.phone || 'Not provided' %></p>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>
                                </div>

                                <!-- Terms -->
                                <div class="bg-gray-50 rounded-lg p-4">
                                    <div class="flex items-start">
                                        <div class="flex items-center h-5">
                                            <input type="checkbox" 
                                                   id="terms" 
                                                   name="terms" 
                                                   required
                                                   class="h-4 w-4 text-blue-600 border-gray-300 rounded">
                                        </div>
                                        <div class="ml-3">
                                            <label for="terms" class="text-sm text-gray-700">
                                                I confirm that I have coordinated this visit timing with both the seller and the buyer.
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="flex justify-end space-x-4 pt-6 border-t border-gray-200">
                                    <a href="/broker/visits" class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg font-semibold hover:bg-gray-50 transition">
                                        Cancel
                                    </a>
                                    <button type="submit" id="submitBtn" class="px-6 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 transition disabled:opacity-50">
                                        Schedule Visit
                                        <span id="loadingSpinner" class="hidden ml-2">
                                            <i class="fas fa-spinner fa-spin"></i>
                                        </span>
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden mb-6">
                    <div class="bg-gradient-to-r from-gray-700 to-gray-900 px-6 py-4">
                        <h2 class="text-lg font-bold text-white">Guidelines</h2>
                    </div>
                    <div class="p-6">
                        <div class="space-y-4">
                            <div class="flex items-start">
                                <div class="p-2 bg-blue-100 rounded-lg mr-3">
                                    <i class="fas fa-clock text-blue-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold">Timing</h3>
                                    <p class="text-sm text-gray-600">9 AM - 6 PM on weekdays</p>
                                </div>
                            </div>
                            <div class="flex items-start">
                                <div class="p-2 bg-green-100 rounded-lg mr-3">
                                    <i class="fas fa-calendar-check text-green-600"></i>
                                </div>
                                <div>
                                    <h3 class="font-semibold">7-Day Window</h3>
                                    <p class="text-sm text-gray-600">Schedule within 7 days</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="bg-white rounded-xl shadow-lg overflow-hidden">
                    <div class="bg-gradient-to-r from-gray-700 to-gray-900 px-6 py-4">
                        <h2 class="text-lg font-bold text-white">Quick Actions</h2>
                    </div>
                    <div class="p-6">
                        <div class="space-y-3">
                            <% if (property.seller && property.seller.phone) { %>
                            <a href="tel:<%= property.seller.phone %>" 
                               class="block w-full bg-green-600 text-white text-center py-3 rounded-lg font-semibold hover:bg-green-700 transition">
                                <i class="fas fa-phone mr-2"></i>Call Seller
                            </a>
                            <% } %>
                            <% if (buyer && buyer.phone) { %>
                            <a href="tel:<%= buyer.phone %>" 
                               class="block w-full border-2 border-blue-600 text-blue-600 text-center py-3 rounded-lg font-semibold hover:bg-blue-50 transition">
                                <i class="fas fa-phone mr-2"></i>Call Buyer
                            </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FIXED JAVASCRIPT - Using correct API endpoint -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('scheduleVisitForm');
            const submitBtn = document.getElementById('submitBtn');
            const loadingSpinner = document.getElementById('loadingSpinner');
            
            if (form) {
                form.addEventListener('submit', async function(e) {
                    e.preventDefault();
                    
                    const visitDate = document.getElementById('visitDate').value;
                    const visitTime = document.getElementById('visitTime').value;
                    const notes = document.getElementById('notes').value;
                    const termsChecked = document.getElementById('terms').checked;
                    const propertyId = this.dataset.propertyId;
                    
                    // Get buyer ID from URL
                    const urlParams = new URLSearchParams(window.location.search);
                    const buyerId = urlParams.get('buyer');
                    
                    console.log('Submitting form with data:', { propertyId, buyerId, visitDate, visitTime, notes });
                    
                    // Validations
                    if (!termsChecked) {
                        alert('Please confirm you have coordinated with both parties.');
                        return;
                    }
                    
                    if (!visitDate || !visitTime) {
                        alert('Please select date and time.');
                        return;
                    }
                    
                    if (!buyerId) {
                        alert('Buyer information missing. Please go back and try again.');
                        return;
                    }
                    
                    // Date validation
                    const visitDateTime = new Date(`${visitDate}T${visitTime}`);
                    const now = new Date();
                    
                    if (visitDateTime < now) {
                        alert('Please select a future date and time for the visit.');
                        return;
                    }
                    
                    const hour = visitDateTime.getHours();
                    if (hour < 9 || hour >= 18) {
                        alert('Visits can only be scheduled between 9:00 AM and 6:00 PM.');
                        return;
                    }
                    
                    // Disable button and show spinner
                    submitBtn.disabled = true;
                    if (loadingSpinner) loadingSpinner.classList.remove('hidden');
                    
                    try {
                        // CORRECT API ENDPOINT - matches your route mounting
                        const response = await fetch('/broker/api/visit/schedule', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                propertyId: propertyId,
                                buyerId: buyerId,
                                visitDate: visitDate,
                                visitTime: visitTime,
                                notes: notes || ''
                            }),
                            credentials: 'same-origin'
                        });
                        
                        console.log('Response status:', response.status);
                        
                        if (!response.ok) {
                            const errorText = await response.text();
                            throw new Error(`HTTP ${response.status}: ${errorText.substring(0, 100)}`);
                        }
                        
                        const result = await response.json();
                        console.log('Response data:', result);
                        
                        if (result.success) {
                            alert('✅ Visit scheduled successfully! The buyer has been notified.');
                            window.location.href = '/broker/visits';
                        } else {
                            alert('Error: ' + (result.message || 'Unknown error'));
                            submitBtn.disabled = false;
                            if (loadingSpinner) loadingSpinner.classList.add('hidden');
                        }
                    } catch (error) {
                        console.error('Error:', error);
                        alert('Failed to schedule visit: ' + error.message);
                        submitBtn.disabled = false;
                        if (loadingSpinner) loadingSpinner.classList.add('hidden');
                    }
                });
            }
        });
    </script>
</body>
</html>